---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { publishedGuidesSorted } from '../lib/guide';
import { sortPosts, isPublic, fmtPostDate } from '../lib/blog';
import { BLOG_CATEGORY_LABELS } from '../content/config';

// Read hub — the "words" bucket. Fronts the beginner's Guide and the Blog,
// surfacing a start point for each so the landing page is a real destination
// rather than a menu of two links.
const guides = publishedGuidesSorted(await getCollection('guide'));
const firstGuide = guides[0];
const posts = sortPosts((await getCollection('blog')).filter(isPublic));
const latest = posts[0];
const recent = posts.slice(1, 5);

const title = 'Read — F1 Beginner’s Guide & Blog | f1gures';
const description = 'Learn Formula 1 from scratch with the beginner’s guide, then keep up with race recaps, technical explainers and historic deep-dives on the blog.';
const canonicalPath = '/read/';
const breadcrumb = [
  { name: 'Home', path: '/' },
  { name: 'Read', path: '/read/' },
];

const ORIGIN = 'https://f1gures.app';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Read — Guide & Blog',
  url: ORIGIN + canonicalPath,
  description,
};
---
<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogType="website"
  jsonLd={jsonLd}
  breadcrumb={breadcrumb}
>
  <div class="page hub-page">
    <div class="page-head">
      <div>
        <div class="t-eyebrow">The words</div>
        <h1 class="page-title">Read</h1>
        <p class="page-sub">Start from zero with the beginner’s guide, then follow along with race recaps, technical explainers and historic deep-dives.</p>
      </div>
    </div>

    <div class="hub-pillars">
      <a class="hub-pillar" href="/guide/">
        <div class="hub-pillar-head">
          <span class="hub-pillar-eyebrow">Beginner’s Guide</span>
          <span class="hub-pillar-count">{guides.length}</span>
        </div>
        <h2 class="hub-pillar-title">Learn F1</h2>
        <p class="hub-pillar-desc">{guides.length} short reads that build on each other — the race weekend, points, tyres, DRS, strategy and the rules.</p>
        {firstGuide && (
          <span class="hub-pillar-go">Start with {firstGuide.data.title} <span class="arrow" aria-hidden="true">›</span></span>
        )}
      </a>

      <a class="hub-pillar" href="/blog/">
        <div class="hub-pillar-head">
          <span class="hub-pillar-eyebrow">The Blog</span>
          <span class="hub-pillar-count">{posts.length}</span>
        </div>
        <h2 class="hub-pillar-title">Read the Blog</h2>
        <p class="hub-pillar-desc">Race recaps, technical explainers, driver focus pieces and historic season retrospectives.</p>
        <span class="hub-pillar-go">Browse all posts <span class="arrow" aria-hidden="true">›</span></span>
      </a>
    </div>

    {latest && (
      <section class="hub-latest">
        <div class="section-head">
          <h2>Latest post</h2>
          <span class="section-rule"></span>
        </div>
        <a class="hub-feature" href={`/blog/${latest.slug}/`}>
          <div class="hub-feature-meta">
            <span class="t-eyebrow">{BLOG_CATEGORY_LABELS[latest.data.category]}</span>
            <span class="t-mono hub-feature-date">{fmtPostDate(latest.data.publishedAt)}</span>
          </div>
          <h3 class="hub-feature-title">{latest.data.title}</h3>
          <p class="hub-feature-desc">{latest.data.description}</p>
          <span class="hub-pillar-go">Read <span class="arrow" aria-hidden="true">›</span></span>
        </a>

        {recent.length > 0 && (
          <ul class="hub-recent">
            {recent.map((post) => (
              <li>
                <a class="hub-recent-item" href={`/blog/${post.slug}/`}>
                  <div class="hub-feature-meta">
                    <span class="t-eyebrow">{BLOG_CATEGORY_LABELS[post.data.category]}</span>
                    <span class="t-mono hub-feature-date">{fmtPostDate(post.data.publishedAt)}</span>
                  </div>
                  <span class="hub-recent-title">{post.data.title}</span>
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .hub-pillars {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;
    margin-bottom: 28px;
  }
  .hub-pillar {
    display: flex; flex-direction: column; gap: 10px;
    padding: 22px; text-decoration: none;
    border: 1px solid var(--line-2); background: var(--bg-2);
    transition: border-color var(--mo, 0.15s) ease, transform var(--mo, 0.15s) ease;
  }
  a.hub-pillar:hover { border-color: var(--accent); transform: translateY(-2px); }
  .hub-pillar-head { display: flex; align-items: center; justify-content: space-between; }
  .hub-pillar-eyebrow {
    font-family: var(--f-display); font-weight: 600; font-size: 10px;
    letter-spacing: 0.18em; text-transform: uppercase; color: var(--fg-3);
  }
  .hub-pillar-count {
    font-family: var(--f-mono, monospace); font-weight: 700; font-size: 28px;
    line-height: 1; color: var(--accent);
  }
  .hub-pillar-title {
    font-family: var(--f-display); font-weight: 800; font-size: 24px;
    letter-spacing: 0; text-transform: uppercase; color: var(--fg-1); line-height: 1.05;
  }
  .hub-pillar-desc { color: var(--fg-2); font-size: 14px; line-height: 1.5; }
  .hub-pillar-go {
    margin-top: auto; font-family: var(--f-display); font-weight: 700;
    font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--fg-1);
  }
  .hub-pillar-go .arrow { color: var(--accent); }

  .hub-latest { margin-top: 8px; }
  .hub-feature {
    display: flex; flex-direction: column; gap: 8px;
    padding: 20px; margin: 14px 0; text-decoration: none;
    border: 1px solid var(--line-2); background: var(--bg-2);
    transition: border-color var(--mo, 0.15s) ease;
  }
  .hub-feature:hover { border-color: var(--accent); }
  .hub-feature-meta { display: flex; align-items: center; gap: 12px; }
  .hub-feature-date { color: var(--fg-3); font-size: 12px; }
  .hub-feature-title {
    font-family: var(--f-display); font-weight: 800; font-size: 22px;
    text-transform: uppercase; letter-spacing: 0; color: var(--fg-1); line-height: 1.08;
  }
  .hub-feature-desc { color: var(--fg-2); font-size: 14px; line-height: 1.5; }

  .hub-recent {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;
  }
  .hub-recent-item {
    display: flex; flex-direction: column; gap: 6px;
    padding: 14px 16px; text-decoration: none;
    border: 1px solid var(--line-1); background: var(--bg-1);
    transition: border-color var(--mo, 0.15s) ease;
  }
  .hub-recent-item:hover { border-color: var(--line-3); }
  .hub-recent-title {
    font-family: var(--f-display); font-weight: 700; font-size: 15px;
    text-transform: uppercase; letter-spacing: 0.02em; color: var(--fg-1); line-height: 1.15;
  }

  @media (max-width: 720px) {
    .hub-pillars { grid-template-columns: 1fr; }
    .hub-recent { grid-template-columns: 1fr; }
  }
</style>
