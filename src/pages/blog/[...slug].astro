---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BLOG_CATEGORY_LABELS } from '../../content/config';
import { isPublic, sortPosts, fmtPostDate } from '../../lib/blog';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter(isPublic);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const categoryLabel = BLOG_CATEGORY_LABELS[post.data.category];
const canonicalPath = `/blog/${post.slug}/`;
const ogImage = post.data.heroImage || '/images/og-default.png';

const allPosts = sortPosts((await getCollection('blog')).filter(isPublic));
const idx = allPosts.findIndex((p) => p.slug === post.slug);
const newer = idx > 0 ? allPosts[idx - 1] : null;
const older = idx >= 0 && idx < allPosts.length - 1 ? allPosts[idx + 1] : null;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishedAt.toISOString(),
  ...(post.data.updatedAt ? { dateModified: post.data.updatedAt.toISOString() } : {}),
  author: { '@type': 'Organization', name: post.data.author, url: 'https://f1gures.app/' },
  publisher: {
    '@type': 'Organization',
    name: 'f1gures',
    url: 'https://f1gures.app/',
    logo: {
      '@type': 'ImageObject',
      url: 'https://f1gures.app/images/og-default.png',
    },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `https://f1gures.app${canonicalPath}` },
  articleSection: categoryLabel,
  image: ogImage.startsWith('http') ? ogImage : `https://f1gures.app${ogImage}`,
};

const breadcrumb = [
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/blog/' },
  { name: categoryLabel, path: `/blog/category/${post.data.category}/` },
  { name: post.data.title, path: canonicalPath },
];
---
<BaseLayout
  title={`${post.data.title} | f1gures`}
  description={post.data.description}
  canonicalPath={canonicalPath}
  ogType="article"
  ogImage={ogImage}
  ogImageAlt={post.data.heroImageAlt || post.data.title}
  publishedTime={post.data.publishedAt.toISOString()}
  jsonLd={jsonLd}
  breadcrumb={breadcrumb}
>
  <article class="page blog-article">
    <a class="btn btn-ghost btn-sm" style="margin-bottom: 12px" href="/blog/">← Blog</a>

    {post.data.heroImage ? (
      <div class="blog-article-hero-wrap">
        <img
          class="blog-article-hero"
          src={post.data.heroImage}
          alt={post.data.heroImageAlt || post.data.title}
          loading="eager"
        />
        <div class="blog-article-head blog-article-head--over">
          <a class="t-eyebrow blog-article-cat" href={`/blog/category/${post.data.category}/`}>
            {categoryLabel}
          </a>
          <h1 class="page-title blog-article-title">{post.data.title}</h1>
          <div class="blog-article-meta">
            <span class="t-mono">{fmtPostDate(post.data.publishedAt)}</span>
            {post.data.updatedAt && (
              <>
                <span class="sep">·</span>
                <span class="t-mono">Updated {fmtPostDate(post.data.updatedAt)}</span>
              </>
            )}
          </div>
        </div>
      </div>
    ) : (
      <div class="blog-article-head">
        <a class="t-eyebrow blog-article-cat" href={`/blog/category/${post.data.category}/`}>
          {categoryLabel}
        </a>
        <h1 class="page-title blog-article-title">{post.data.title}</h1>
        <div class="blog-article-meta">
          <span class="t-mono">{fmtPostDate(post.data.publishedAt)}</span>
          {post.data.updatedAt && (
            <>
              <span class="sep">·</span>
              <span class="t-mono">Updated {fmtPostDate(post.data.updatedAt)}</span>
            </>
          )}
        </div>
      </div>
    )}

    <div class="blog-article-body">
      <Content />
    </div>

    {(newer || older) && (
      <nav class="blog-article-nav" aria-label="More posts">
        {newer ? (
          <a class="panel blog-article-nav-link" href={`/blog/${newer.slug}/`}>
            <span class="t-eyebrow">Newer</span>
            <span class="blog-article-nav-title">{newer.data.title}</span>
          </a>
        ) : <span></span>}
        {older ? (
          <a class="panel blog-article-nav-link blog-article-nav-older" href={`/blog/${older.slug}/`}>
            <span class="t-eyebrow">Older</span>
            <span class="blog-article-nav-title">{older.data.title}</span>
          </a>
        ) : <span></span>}
      </nav>
    )}
  </article>
</BaseLayout>
