---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BLOG_CATEGORY_LABELS } from '../../content/config';
import { sortPosts, isPublic, fmtPostDate } from '../../lib/blog';
import TriviaBoard from '../../components/islands/screens/TriviaBoard.jsx';

const posts = sortPosts((await getCollection('blog')).filter(isPublic));

const title = 'Blog - F1 Race Recaps, History & Analysis | f1gures';
const description = 'Race recaps, technical explainers, driver focus pieces and historic season retrospectives from f1gures.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': 'https://f1gures.app/blog/#blog',
  url: 'https://f1gures.app/blog/',
  name: 'f1gures Blog',
  description,
  inLanguage: 'en-GB',
  publisher: {
    '@type': 'Organization',
    name: 'f1gures',
    url: 'https://f1gures.app/',
  },
  blogPost: posts.slice(0, 20).map((p) => ({
    '@type': 'BlogPosting',
    headline: p.data.title,
    description: p.data.description,
    datePublished: p.data.publishedAt.toISOString(),
    url: `https://f1gures.app/blog/${p.slug}/`,
  })),
};

const breadcrumb = [
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/blog/' },
];
---
<BaseLayout
  title={title}
  description={description}
  canonicalPath="/blog/"
  ogType="website"
  jsonLd={jsonLd}
  breadcrumb={breadcrumb}
>
  <div class="page">
    <div class="page-head blog-index-head">
      <div>
        <div class="t-eyebrow">f1gures</div>
        <h1 class="page-title blog-index-title">The Blog</h1>
        <p class="page-sub">Race recaps, technical explainers and historic deep-dives.</p>
      </div>
    </div>

    <TriviaBoard client:visible />

    {posts.length === 0 ? (
      <div class="panel">
        <div class="panel-body">
          <p>No posts yet — first ones coming soon.</p>
        </div>
      </div>
    ) : (
      <>
        <div class="blog-filter" role="tablist" aria-label="Filter posts by category">
          <button class="blog-filter-tab is-active" type="button" data-cat="all" aria-selected="true">All</button>
          {Object.entries(BLOG_CATEGORY_LABELS).map(([slug, label]) => (
            <button class="blog-filter-tab" type="button" data-cat={slug} aria-selected="false">{label}</button>
          ))}
          <a class="blog-filter-rss" href="/blog/rss.xml">RSS</a>
        </div>

        {/* Two-post lede: a larger "major" card beside a smaller "minor" one.
            Text-forward, so it never depends on a hero image. Hidden by the
            filter script whenever a single category is selected. */}
        <div class="blog-lede" id="blog-lede">
          {posts.slice(0, 2).map((post, i) => (
            <article class={`panel blog-card blog-lede-card ${i === 0 ? 'blog-lede-card--major' : 'blog-lede-card--minor'}`}>
              {post.data.heroImage ? (
                <div class="blog-card-img blog-lede-img">
                  <a class="blog-card-img-link" href={`/blog/${post.slug}/`} aria-hidden="true" tabindex="-1">
                    <img src={post.data.heroImage} alt={post.data.heroImageAlt || post.data.title} />
                  </a>
                  <div class="blog-card-over blog-lede-over">
                    <div class="blog-card-meta">
                      <a class="t-eyebrow blog-card-cat" href={`/blog/category/${post.data.category}/`}>{BLOG_CATEGORY_LABELS[post.data.category]}</a>
                      <span class="t-mono blog-card-date">{fmtPostDate(post.data.publishedAt)}</span>
                    </div>
                    <h2 class="blog-card-title blog-lede-title"><a class="blog-card-title-link" href={`/blog/${post.slug}/`}>{post.data.title}</a></h2>
                    {i === 0 && <p class="blog-lede-desc">{post.data.description}</p>}
                  </div>
                </div>
              ) : (
                <div class="blog-card-body blog-lede-text">
                  <div class="blog-card-meta">
                    <a class="t-eyebrow blog-card-cat" href={`/blog/category/${post.data.category}/`}>{BLOG_CATEGORY_LABELS[post.data.category]}</a>
                    <span class="t-mono blog-card-date">{fmtPostDate(post.data.publishedAt)}</span>
                  </div>
                  <h2 class="blog-card-title blog-lede-title"><a class="blog-card-title-link" href={`/blog/${post.slug}/`}>{post.data.title}</a></h2>
                  {i === 0 && <p class="blog-card-desc">{post.data.description}</p>}
                </div>
              )}
            </article>
          ))}
        </div>

        <ul class="blog-list" id="blog-list">
          {posts.map((post, i) => (
            <li class="blog-list-item" data-category={post.data.category} data-in-lede={i < 2 ? '1' : undefined} hidden={i < 2 ? true : undefined}>
              <div class="panel blog-card">
                {post.data.heroImage ? (
                  <div class="blog-card-img">
                    <a class="blog-card-img-link" href={`/blog/${post.slug}/`} aria-hidden="true" tabindex="-1">
                      <img src={post.data.heroImage} alt={post.data.heroImageAlt || post.data.title} loading="lazy" />
                    </a>
                    <div class="blog-card-over">
                      <div class="blog-card-meta">
                        <a class="t-eyebrow blog-card-cat" href={`/blog/category/${post.data.category}/`}>{BLOG_CATEGORY_LABELS[post.data.category]}</a>
                        <span class="t-mono blog-card-date">{fmtPostDate(post.data.publishedAt)}</span>
                      </div>
                      <h2 class="blog-card-title"><a class="blog-card-title-link" href={`/blog/${post.slug}/`}>{post.data.title}</a></h2>
                    </div>
                  </div>
                ) : (
                  <div class="blog-card-body">
                    <div class="blog-card-meta">
                      <a class="t-eyebrow blog-card-cat" href={`/blog/category/${post.data.category}/`}>{BLOG_CATEGORY_LABELS[post.data.category]}</a>
                      <span class="t-mono blog-card-date">{fmtPostDate(post.data.publishedAt)}</span>
                    </div>
                    <h2 class="blog-card-title"><a class="blog-card-title-link" href={`/blog/${post.slug}/`}>{post.data.title}</a></h2>
                  </div>
                )}
                <div class="blog-card-body">
                  <p class="blog-card-desc">{post.data.description}</p>
                </div>
              </div>
            </li>
          ))}
        </ul>
        <p class="blog-filter-empty" id="blog-empty" hidden>No posts in this category yet.</p>
      </>
    )}
  </div>

  <script is:inline>
    (function () {
      var tabs = Array.prototype.slice.call(document.querySelectorAll('.blog-filter-tab'));
      var items = Array.prototype.slice.call(document.querySelectorAll('#blog-list .blog-list-item'));
      var lede = document.getElementById('blog-lede');
      var empty = document.getElementById('blog-empty');
      if (!tabs.length || !items.length) return;
      tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          var cat = tab.getAttribute('data-cat');
          var all = cat === 'all';
          tabs.forEach(function (t) {
            var on = t === tab;
            t.classList.toggle('is-active', on);
            t.setAttribute('aria-selected', on ? 'true' : 'false');
          });
          // The lede shows the two latest posts; in the All view they're served
          // there, so their grid duplicates stay hidden. A category filter hides
          // the lede and lets those posts flow back into the filtered grid.
          if (lede) lede.hidden = !all;
          var shown = 0;
          items.forEach(function (li) {
            var inLede = li.hasAttribute('data-in-lede');
            var match = all ? !inLede : li.getAttribute('data-category') === cat;
            li.hidden = !match;
            if (match) shown++;
          });
          if (empty) empty.hidden = shown !== 0;
        });
      });
    })();
  </script>
</BaseLayout>
