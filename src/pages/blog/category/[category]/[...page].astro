---
import { getCollection } from 'astro:content';
import type { GetStaticPaths, Page } from 'astro';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import {
  BLOG_CATEGORIES,
  BLOG_CATEGORY_LABELS,
  BLOG_CATEGORY_DESCRIPTIONS,
} from '../../../../content/config';
import { isPublic, sortPosts, fmtPostDate } from '../../../../lib/blog';
import BlogPager from '../../../../components/blog/BlogPager.astro';

// getStaticPaths is hoisted above module scope, so pageSize is inlined here.
export const getStaticPaths = (async ({ paginate }) => {
  const all = sortPosts((await getCollection('blog')).filter(isPublic));
  return BLOG_CATEGORIES.flatMap((category) =>
    paginate(all.filter((p) => p.data.category === category), {
      params: { category },
      props: { category },
      pageSize: 14,
    }),
  );
}) satisfies GetStaticPaths;

type Post = Awaited<ReturnType<typeof getCollection<'blog'>>>[number];
const { category } = Astro.props as { category: (typeof BLOG_CATEGORIES)[number] };
const { page } = Astro.props as { page: Page<Post> };

const label = BLOG_CATEGORY_LABELS[category];
const categoryDescription = BLOG_CATEGORY_DESCRIPTIONS[category];

const basePath = `/blog/category/${category}/`;
const isFirst = page.currentPage === 1;
const canonicalPath = isFirst ? basePath : `${basePath}${page.currentPage}/`;

const title = isFirst
  ? `${label} - F1 Blog | f1gures`
  : `${label} (Page ${page.currentPage}) - F1 Blog | f1gures`;
const description = isFirst
  ? `${categoryDescription} Read every ${label.toLowerCase()} post on f1gures.`
  : `${categoryDescription} Page ${page.currentPage} of ${page.lastPage}.`;

const jsonLd = {
  '@type': 'CollectionPage',
  url: `https://f1gures.app${canonicalPath}`,
  name: `${label} - f1gures Blog`,
  description,
  inLanguage: 'en-GB',
  isPartOf: { '@type': 'Blog', '@id': 'https://f1gures.app/blog/#blog' },
};

const breadcrumb = [
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/blog/' },
  { name: label, path: basePath },
  ...(isFirst ? [] : [{ name: `Page ${page.currentPage}`, path: canonicalPath }]),
];
---
<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogType="website"
  jsonLd={jsonLd}
  breadcrumb={breadcrumb}
>
  <div class="page">
    <a class="btn btn-ghost btn-sm" style="margin-bottom: 12px" href="/blog/">← Blog</a>

    <div class="page-head">
      <div>
        <div class="t-eyebrow">Category</div>
        <h1 class="page-title">{label}</h1>
        <p class="page-sub">{categoryDescription}</p>
      </div>
    </div>

    {page.data.length === 0 ? (
      <div class="panel">
        <div class="panel-body">
          <p>No posts in this category yet.</p>
        </div>
      </div>
    ) : (
      <ul class="blog-list">
        {page.data.map((post) => (
          <li class="blog-list-item">
            <div class="panel blog-card">
              {post.data.heroImage ? (
                <div class="blog-card-img">
                  <a class="blog-card-img-link" href={`/blog/${post.slug}/`} aria-hidden="true" tabindex="-1">
                    <img src={post.data.heroImage} alt={post.data.heroImageAlt || post.data.title} loading="lazy" />
                  </a>
                  <div class="blog-card-over">
                    <div class="blog-card-meta">
                      <a class="t-eyebrow blog-card-cat" href={basePath}>{label}</a>
                      <span class="t-mono blog-card-date">{fmtPostDate(post.data.publishedAt)}</span>
                    </div>
                    <h2 class="blog-card-title"><a class="blog-card-title-link" href={`/blog/${post.slug}/`}>{post.data.title}</a></h2>
                  </div>
                </div>
              ) : (
                <div class="blog-card-body">
                  <div class="blog-card-meta">
                    <a class="t-eyebrow blog-card-cat" href={basePath}>{label}</a>
                    <span class="t-mono blog-card-date">{fmtPostDate(post.data.publishedAt)}</span>
                  </div>
                  <h2 class="blog-card-title"><a class="blog-card-title-link" href={`/blog/${post.slug}/`}>{post.data.title}</a></h2>
                </div>
              )}
              <div class="blog-card-body">
                <p class="blog-card-desc">{post.data.description}</p>
              </div>
            </div>
          </li>
        ))}
      </ul>
    )}

    <BlogPager currentPage={page.currentPage} lastPage={page.lastPage} basePath={basePath} />
  </div>
</BaseLayout>
