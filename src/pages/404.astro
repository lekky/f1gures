---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Page Not Found - f1gures';
const description = "Sorry, we couldn't find that page. Browse drivers, races, circuits or constructors from the home page.";
---
<BaseLayout {title} {description} canonicalPath="/404/" robots="noindex" ogImage="/images/og/pages/404.png">
  <div class="page page-404">
    <h1 class="page-title">404</h1>
    <p class="page-404-tagline">We couldn't find that page.</p>
    <p class="page-404-sub">Maybe one of these:</p>
    <ul class="page-404-links">
      <li><a href="/">Home</a></li>
      <li><a href="/standings-drivers/">Driver standings</a></li>
      <li><a href="/standings-constructors/">Constructor standings</a></li>
      <li><a href="/calendar/">Calendar</a></li>
      <li><a href="/circuits/">Circuits</a></li>
    </ul>
  </div>
</BaseLayout>

<style>
  .page-404 { max-width: 640px; margin: 60px auto; text-align: center; }
  .page-title { font-size: 96px; line-height: 1; margin: 0 0 16px 0; color: var(--accent); }
  .page-404-tagline { font-family: var(--f-display); font-weight: 700; font-size: 22px; text-transform: uppercase; letter-spacing: 0.04em; margin: 0 0 32px 0; }
  .page-404-sub { color: var(--fg-3); margin-bottom: 12px; }
  .page-404-links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
  .page-404-links a { display: inline-block; padding: 8px 12px; color: var(--fg-1); text-decoration: none; border-bottom: 1px dotted var(--line-2); }
  .page-404-links a:hover { color: var(--accent); }
</style>
