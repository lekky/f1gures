---
import BaseLayout from '../layouts/BaseLayout.astro';
import RecordHeroCard from '../components/RecordHeroCard.astro';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

// Stats hub — the "numbers" bucket. Leads with the marquee records leaderboards
// (reusing RecordHeroCard, the design-system's colourful leaderboard pattern:
// driver faces, flags, team-colour bars), then signposts the full 17-board set
// and the upcoming head-to-head Compare tool. Reads the prerendered records
// index (same source as /records/) so everything is real.
const indexPath = resolve(process.cwd(), 'public/data/archive/_records-index.json');
const records = JSON.parse(readFileSync(indexPath, 'utf8'));
const groups = records.groups || [];
const totalRecords = groups.reduce((n: number, g: any) => n + (g.records?.length || 0), 0);

// Flat lookup by id so we can hand-pick the marquee cards.
const byId: Record<string, any> = {};
for (const g of groups) for (const r of g.records) byId[r.id] = r;
const FEATURED = ['wins', 'championships', 'poles', 'wins-in-season', 'team-titles', 'podiums'];
const featured = FEATURED.map((id) => byId[id]).filter(Boolean);

const title = 'F1 Stats — Records, Leaderboards & Comparisons | f1gures';
const description = 'The numbers behind Formula 1: 17 all-time and modern-era leaderboards, from wins and poles to streaks and title margins, plus head-to-head comparisons.';
const canonicalPath = '/stats/';
const breadcrumb = [
  { name: 'Home', path: '/' },
  { name: 'Stats', path: '/stats/' },
];

const ORIGIN = 'https://f1gures.app';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'F1 Stats',
  url: ORIGIN + canonicalPath,
  description,
};
---
<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogType="website"
  jsonLd={jsonLd}
  breadcrumb={breadcrumb}
>
  <div class="page hub-page">
    <div class="page-head">
      <div>
        <div class="t-eyebrow">The numbers</div>
        <h1 class="page-title">Stats</h1>
        <p class="page-sub">Every Formula 1 leaderboard worth knowing, plus the tools to settle an argument: records, milestones and head-to-head comparisons, computed from 1950 to the last completed race.</p>
      </div>
    </div>

    <div class="hub-tools">
      <a class="hub-tool" href="/records/">
        <span class="hub-tool-eyebrow">All leaderboards</span>
        <span class="hub-tool-title">Records &amp; Milestones</span>
        <p class="hub-tool-desc">Every board — career, single-season, streaks, milestones, teams and tracks — all-time and modern-era.</p>
        <span class="hub-pillar-go">Browse all {totalRecords} <span class="arrow" aria-hidden="true">›</span></span>
      </a>

      <a class="hub-tool" href="/compare/">
        <span class="hub-tool-eyebrow">Head to head</span>
        <span class="hub-tool-title">Compare</span>
        <p class="hub-tool-desc">Line up any two drivers or teams side by side: points, wins, poles, win rates, season-by-season form and the rivalry between them.</p>
        <span class="hub-pillar-go">Start a comparison <span class="arrow" aria-hidden="true">›</span></span>
      </a>
    </div>

    <section class="records-section hub-featured">
      <div class="section-head records-section-head">
        <h2>Featured records</h2>
        <span class="records-section-count">{totalRecords} leaderboards</span>
      </div>
      <div class="records-section-rule"></div>
      <div class="records-grid">
        {featured.map((r: any) => <RecordHeroCard record={r} />)}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .hub-featured { margin-bottom: 28px; }

  .hub-tools {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;
    margin-bottom: 24px;
  }
  .hub-tool {
    display: flex; flex-direction: column; gap: 8px;
    padding: 20px; text-decoration: none;
    border: 1px solid var(--line-2); background: var(--bg-2);
    transition: border-color var(--mo, 0.15s) ease, transform var(--mo, 0.15s) ease;
  }
  a.hub-tool:hover { border-color: var(--accent); transform: translateY(-2px); }
  .hub-tool.is-soon { opacity: 0.7; }
  .hub-tool-head { display: flex; align-items: center; justify-content: space-between; }
  .hub-tool-eyebrow {
    font-family: var(--f-display); font-weight: 600; font-size: 10px;
    letter-spacing: 0.18em; text-transform: uppercase; color: var(--fg-3);
  }
  .hub-tool-title {
    font-family: var(--f-display); font-weight: 800; font-size: 22px;
    letter-spacing: 0; text-transform: uppercase; color: var(--fg-1); line-height: 1.05;
  }
  .hub-tool-desc { color: var(--fg-2); font-size: 14px; line-height: 1.5; }
  .hub-pillar-pill {
    font-family: var(--f-display); font-weight: 700; font-size: 10px;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--fg-3);
    border: 1px solid var(--line-2); padding: 3px 8px;
  }
  .hub-pillar-go {
    margin-top: auto; font-family: var(--f-display); font-weight: 700;
    font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--fg-1);
  }
  .hub-pillar-go--muted { color: var(--fg-3); }
  .hub-pillar-go .arrow { color: var(--accent); }

  @media (max-width: 720px) {
    .hub-tools { grid-template-columns: 1fr; }
  }
</style>
