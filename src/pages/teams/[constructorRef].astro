---
import { existsSync, readdirSync, readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TeamPage from '../../components/TeamPage.astro';
import { getTeamsIndex, getTeam } from '../../data/archive.js';

// Highest-numbered season bundle in public/data/ is the active championship
// year. Used by TeamPage to flag a team as currently competing.
function getCurrentYear(): number | null {
  try {
    const dir = resolve(process.cwd(), 'public', 'data');
    const years = readdirSync(dir)
      .map(f => /^(\d{4})\.json$/.exec(f)?.[1])
      .filter((y): y is string => !!y)
      .map(Number);
    return years.length ? Math.max(...years) : null;
  } catch {
    return null;
  }
}
const currentYear = getCurrentYear();

// Build-time computation of recent form (last 5 rounds points per driver) and
// current championship standings. Mirrors the algorithm in src/lib/shared.jsx
// and src/data/buildFallback.js so the prerendered HTML matches the React
// MiniChart and Driver Standings table. Bundle results are keyed by driver
// code (e.g. "VER"); we map driverRef → code via bundle.drivers.
const F1_POINTS = [25, 18, 15, 12, 10, 8, 6, 4, 2, 1];
type RecentFormMap = Record<string, number[]>;
type StandingsMap = Record<string, { position: number; points: number; wins: number }>;
type BundleStats = { recentForm: RecentFormMap; standings: StandingsMap };
function buildBundleStats(year: number | null): BundleStats {
  if (!year) return { recentForm: {}, standings: {} };
  const bundlePath = resolve(process.cwd(), 'public', 'data', `${year}.json`);
  if (!existsSync(bundlePath)) return { recentForm: {}, standings: {} };
  const bundle = JSON.parse(readFileSync(bundlePath, 'utf8'));
  const drivers = bundle.drivers || [];
  const results = bundle.results || {};
  const codeByRef = new Map<string, string>();
  const refByCode = new Map<string, string>();
  for (const d of drivers) {
    if (d.jolpicaId && d.id) {
      codeByRef.set(d.jolpicaId, d.id);
      refByCode.set(d.id, d.jolpicaId);
    }
  }
  const allRounds = Object.keys(results)
    .map(Number)
    .filter(n => Number.isFinite(n))
    .sort((a, b) => a - b);
  const recentRounds = allRounds.slice(-5);

  // Recent form
  const form: RecentFormMap = {};
  for (const [ref, code] of codeByRef) {
    form[ref] = recentRounds.map(r => {
      const res = results[r] || results[String(r)];
      if (!res) return 0;
      const order: string[] = res.order || [];
      const pos = order.indexOf(code);
      if (pos === -1) return 0;
      let pts = F1_POINTS[pos] || 0;
      if (res.fastest === code && pos < 10) pts += 1;
      if (res.sprintWinner === code) pts += 8;
      return pts;
    });
  }

  // Full-season points + wins per driver code
  const pts: Record<string, number> = {};
  const wins: Record<string, number> = {};
  for (const r of allRounds) {
    const res = results[r] || results[String(r)];
    if (!res) continue;
    const order: string[] = res.order || [];
    order.forEach((code, i) => {
      pts[code] = pts[code] || 0;
      wins[code] = wins[code] || 0;
      if (i < 10) pts[code] += F1_POINTS[i];
      if (i === 0) wins[code] += 1;
    });
    if (res.fastest && order.indexOf(res.fastest) < 10) {
      pts[res.fastest] = (pts[res.fastest] || 0) + 1;
    }
    if (res.sprintWinner) {
      const sw = res.sprintWinner;
      pts[sw] = (pts[sw] || 0) + 8;
      const others = order.filter((c: string) => c !== sw).slice(0, 7);
      others.forEach((c: string, i: number) => { pts[c] = (pts[c] || 0) + (7 - i); });
    }
  }
  const ranked = [...refByCode.entries()]
    .map(([code, ref]) => ({ ref, code, points: pts[code] || 0, wins: wins[code] || 0 }))
    .sort((a, b) => b.points - a.points || b.wins - a.wins);
  const standings: StandingsMap = {};
  ranked.forEach((row, i) => {
    standings[row.ref] = { position: i + 1, points: row.points, wins: row.wins };
  });

  return { recentForm: form, standings };
}
const { recentForm, standings: currentStandings } = buildBundleStats(currentYear);

export async function getStaticPaths() {
  const index = getTeamsIndex();
  return index.map(entry => ({
    params: { constructorRef: entry.constructorRef },
    props: { team: getTeam(entry.constructorRef) },
  }));
}

const { team } = Astro.props;
const yearsLabel = team.career.firstYear === team.career.lastYear
  ? `${team.career.firstYear}`
  : `${team.career.firstYear}–${team.career.lastYear}`;

const title = `${team.name} - F1 Constructor History, Wins & Championships | f1gures`;
const description = `${team.name} (${team.nationality}, F1 ${yearsLabel}). ${team.career.races} races, ${team.career.wins} wins, ${team.career.podiums} podiums, ${team.career.championships} constructors' championships. Full season-by-season history and notable drivers.`;
const canonicalPath = `/teams/${team.constructorRef}/`;
const ogImagePath = `/images/og/teams/${team.constructorRef}.png`;
const ogImage = existsSync(resolve(process.cwd(), 'public', ogImagePath.slice(1)))
  ? ogImagePath
  : '/images/og-default.png';

const jsonLd: any = {
  '@context': 'https://schema.org',
  '@type': 'SportsTeam',
  name: team.name,
  sport: 'Formula 1',
  identifier: team.constructorRef,
  url: `https://f1gures.app${canonicalPath}`,
  memberOf: {
    '@type': 'SportsOrganization',
    name: 'FIA Formula One World Championship',
  },
};

if (team.career.firstYear) {
  jsonLd.foundingDate = String(team.career.firstYear);
}

const breadcrumb = [
  { name: 'Home', path: '/' },
  { name: 'Constructors', path: '/standings-constructors/' },
  { name: team.name, path: canonicalPath },
];
---
<BaseLayout {title} {description} {canonicalPath} {ogImage} ogType="website" {jsonLd} {breadcrumb}>
  <TeamPage {team} {currentYear} {recentForm} {currentStandings} />
</BaseLayout>
