---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RecordsTopHero from '../../components/RecordsTopHero.astro';
import RecordsTimeline from '../../components/RecordsTimeline.astro';
import RecordHeroCard from '../../components/RecordHeroCard.astro';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const indexPath = resolve(process.cwd(), 'public/data/archive/_records-index.json');
const data = JSON.parse(readFileSync(indexPath, 'utf8'));

const title = 'F1 Records & Milestones - All-Time Leaderboards | f1gures';
const description = 'Every F1 leaderboard, from most race wins to longest podium streaks. All-time and modern-era rankings since 1950.';
const canonicalPath = '/records/';
const breadcrumb = [
  { name: 'Home', path: '/' },
  { name: 'Records', path: '/records/' },
];

const ORIGIN = 'https://f1gures.app';
const allRecords = data.groups.flatMap((g: any) => g.records);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'F1 Records & Milestones',
  url: ORIGIN + canonicalPath,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: allRecords.length,
    itemListElement: allRecords.map((r: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${ORIGIN}/records/${r.id}/`,
      name: r.title,
    })),
  },
};

// Short labels + sub-context for hero stat tiles
const SHORT: Record<string, { label: string; subFromCircuit?: boolean }> = {
  'wins': { label: 'Race wins' },
  'podiums': { label: 'Podiums' },
  'poles': { label: 'Pole positions' },
  'championships': { label: 'Championships' },
  'starts': { label: 'Race starts' },
  'fastest-laps': { label: 'Fastest laps' },
  'wins-in-season': { label: 'Wins in a season' },
  'podium-streak': { label: 'Podium streak' },
  'win-streak': { label: 'Win streak' },
  'title-margin': { label: 'Title margin' },
  'youngest-champion': { label: 'Youngest champion' },
  'oldest-winner': { label: 'Oldest race winner' },
  'team-titles': { label: 'Constructors’ titles' },
  'team-wins': { label: 'Team wins' },
  'team-1-2-finishes': { label: '1-2 finishes' },
  'wins-at-circuit': { label: 'Wins at one circuit', subFromCircuit: true },
  'poles-at-circuit': { label: 'Poles at one circuit', subFromCircuit: true },
};

// Find the "most decorated" - the subject (driver or team) holding the most
// outright #1 spots across all records. Ties at rank 1 are not counted.
type HeroAgg = {
  subjectType: 'driver' | 'team';
  ref: string;
  name: string;
  flag?: string | null;
  country?: string | null;
  teamColor?: string | null;
  records: any[];
};
const candidates = new Map<string, HeroAgg>();
for (const g of data.groups) {
  for (const rec of g.records) {
    const tops = rec.allTime?.top5 || [];
    const tiedAtTop = tops.filter((e: any) => e.rank === 1).length;
    if (tiedAtTop !== 1) continue;
    const t = tops[0];
    if (!t) continue;
    const isTeam = rec.subjectType === 'team';
    const ref = isTeam ? t.constructorRef : t.driverRef;
    if (!ref) continue;
    const key = `${isTeam ? 'team' : 'driver'}:${ref}`;
    const short = SHORT[rec.id];
    const shortLabel = short?.label || rec.title;
    let shortSub: string | undefined;
    if (short?.subFromCircuit && t.circuitName) {
      shortSub = 'at ' + t.circuitName.replace(/\s+Circuit$/i, '').replace(/\s+Grand Prix Circuit$/i, '');
    }
    const entry = {
      id: rec.id,
      title: rec.title,
      valueLabel: t.valueLabel,
      value: t.value,
      context: t.context,
      shortLabel,
      shortSub,
    };
    if (!candidates.has(key)) {
      candidates.set(key, {
        subjectType: isTeam ? 'team' : 'driver',
        ref,
        name: t.name,
        flag: t.flag,
        country: t.country,
        teamColor: t.teamColor,
        records: [entry],
      });
    } else {
      candidates.get(key)!.records.push(entry);
    }
  }
}
const heroEntry = [...candidates.values()].sort((a, b) => b.records.length - a.records.length)[0];

// Build per-section accent: take the team color of the first record's #1 holder
function sectionAccent(g: any): string {
  const t = g.records?.[0]?.allTime?.top5?.[0];
  return t?.teamColor || 'var(--fg-1)';
}

// Blurb describing the hero
function buildBlurb(h: HeroAgg | undefined): string {
  if (!h) return '';
  const verbs = h.records.map(r => r.shortLabel.toLowerCase());
  return h.subjectType === 'team'
    ? `Holds more outright all-time team records than any other constructor on the grid.`
    : `Holds more outright all-time records than any other driver on the grid - the standard against which every modern career is measured.`;
}
const heroBlurb = buildBlurb(heroEntry);
const totalRecords = allRecords.length;
---
<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogType="website"
  jsonLd={jsonLd}
  breadcrumb={breadcrumb}
>
  <main class="records-page records-hub">
    <header class="records-page-head">
      <h1>F1 Records &amp; Milestones</h1>
      <p class="page-sub">Every Formula 1 leaderboard worth knowing - career, single-season, streaks, milestones, teams and tracks. All-time and modern-era (1981+) rankings, computed from 1950 through the last completed season.</p>
    </header>

    {heroEntry && (
      <RecordsTopHero hero={heroEntry} totalRecords={totalRecords} blurb={heroBlurb} />
    )}

    <RecordsTimeline groups={data.groups} />

    {data.groups.map((group: any) => (
      <section class="records-section" style={`--section-accent: ${sectionAccent(group)}`}>
        <div class="section-head records-section-head">
          <h2>{group.label}</h2>
          <span class="records-section-count">{group.records.length} leaderboard{group.records.length === 1 ? '' : 's'}</span>
        </div>
        <div class="records-section-rule"></div>
        <div class="records-grid">
          {group.records.map((r: any) => <RecordHeroCard record={r} />)}
        </div>
      </section>
    ))}
  </main>
</BaseLayout>
