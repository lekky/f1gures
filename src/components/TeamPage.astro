---
// Pure server-rendered constructor (team) detail page. Hero with
// championships, career stats grid, season-by-season summary, top drivers
// list. No React island, no client JS shipped.

import { existsSync } from 'node:fs';
import { resolve } from 'node:path';
import Flag from './Flag.astro';

interface Props {
  currentYear: number | null;
  recentForm: Record<string, number[]>;
  currentStandings: Record<string, { position: number; points: number; wins: number }>;
  team: {
    constructorRef: string;
    name: string;
    nationality: string | null;
    url: string | null;
    color: string;
    short: string;
    career: {
      seasons: number;
      firstYear: number | null;
      lastYear: number | null;
      races: number;
      wins: number;
      podiums: number;
      championships: number;
      driverCount: number;
    };
    perSeason: Array<{
      year: number;
      drivers: Array<{ driverRef: string; name: string; code: string }>;
      position: number | null;
      points: number | null;
      wins: number;
      races: number;
    }>;
    topDrivers: Array<{ driverRef: string; name: string; country?: string | null; flag?: string | null; races: number; wins: number }>;
    bestSeason: {
      year: number;
      position: number | null;
      points: number | null;
      wins: number;
      races: number;
      winRate: number;
      tagline: string;
      drivers: Array<{ driverRef: string; name: string }>;
    } | null;
  };
}

const { team, currentYear, recentForm, currentStandings } = Astro.props;

const CAR_IMAGE_FOR_REF: Record<string, string> = {
  alpine:        'alpine-2026.avif',
  aston:         'astonmartin-2026.avif',
  aston_martin:  'astonmartin-2026.avif',
  audi:          'audi-2026.avif',
  cadillac:      'cadillac-2026.avif',
  ferrari:       'ferrari-2026.avif',
  haas:          'haas-2026.avif',
  mclaren:       'mclaren-2026.avif',
  mercedes:      'mercedes-2026.avif',
  rb:            'racingbulls-2026.avif',
  redbull:       'redbull-2026.avif',
  red_bull:      'redbull-2026.avif',
  williams:      'williams-2026.avif',
};
const carFile = CAR_IMAGE_FOR_REF[team.constructorRef];
const carImagePath = carFile ? `images/cars/${carFile}` : null;
const hasCarImage = carImagePath ? existsSync(resolve(process.cwd(), 'public', carImagePath)) : false;

const logoImagePath = `images/teams/${team.constructorRef}.jpg`;
const hasLogo = existsSync(resolve(process.cwd(), 'public', logoImagePath));

// Mini bar-chart geometry (matches MiniChart in src/lib/shared.jsx).
const CHART_W = 80;
const CHART_H = 22;
const CHART_GAP = 2;
function chartBars(values: number[]) {
  const max = Math.max(...values, 1);
  const barW = (CHART_W - CHART_GAP * (values.length - 1)) / values.length;
  return values.map((v, i) => {
    const bh = max > 0 && v > 0 ? Math.max(2, (v / max) * CHART_H) : 2;
    return {
      x: i * (barW + CHART_GAP),
      y: CHART_H - bh,
      w: barW,
      h: bh,
      v,
    };
  });
}
const yearsLabel = team.career.firstYear === team.career.lastYear
  ? `${team.career.firstYear}`
  : `${team.career.firstYear}–${team.career.lastYear}`;
const fmtNum = (n: number | null | undefined) => (n == null ? '-' : String(n));
const ord = (n: number | null) => (n == null ? '-' : `P${n}`);
const fmtPct = (n: number) => `${(n * 100).toFixed(1)}%`;
const best = team.bestSeason;
const bestIsChampion = best != null && best.position === 1;

// Current-team detection: latest perSeason entry matches the active season
// bundle. perSeason is newest-first from build-archive.mjs.
const latestSeason = team.perSeason[0] ?? null;
const isCurrent = !!(currentYear && latestSeason && latestSeason.year === currentYear);
const currentDrivers = isCurrent ? latestSeason!.drivers : [];
const currentDriverPhotos = currentDrivers.map(d => {
  const headshotPath = `images/drivers/${d.driverRef}.webp`;
  const hasHeadshot = existsSync(resolve(process.cwd(), 'public', headshotPath));
  const recent = (recentForm && recentForm[d.driverRef]) || [];
  const standing = (currentStandings && currentStandings[d.driverRef]) || null;
  return { ...d, headshotPath, hasHeadshot, recent, standing };
});
---

<div class="page">
  <a class="btn btn-ghost btn-sm" style="margin-bottom: 12px" href="/standings-constructors/">← Constructors</a>

  <div class="panel team-hero" style={`border-left: 3px solid ${team.color};`}>
    <div class="team-hero-grid">
      <div class="team-hero-meta">
        <div class="t-eyebrow team-hero-flag" style={`color: ${team.color};`}>
          {team.nationality || '-'}
        </div>
        <div class="team-hero-title-row">
          {hasLogo && (
            <img class="team-hero-logo" src={`/${logoImagePath}`} alt={`${team.name} logo`} width="72" height="72" loading="eager" />
          )}
          <h1 class="page-title team-hero-name">{team.name}</h1>
        </div>
        <div class="team-hero-stats">
          <span class="t-mono">{team.short}</span>
          <span class="sep">·</span>
          <span class="t-mono">{yearsLabel}</span>
          <span class="sep">·</span>
          <span class="t-mono">{team.career.driverCount} drivers</span>
        </div>
      </div>
      <div class="team-hero-champ">
        <div class="t-eyebrow">Constructors' Titles</div>
        <div class={`team-hero-wcc ${team.career.championships > 0 ? 'is-champ' : ''}`}>
          {team.career.championships}
        </div>
      </div>
    </div>
  </div>

  {isCurrent && currentDriverPhotos.length > 0 && (
    <>
      <div class="section-head">
        <h2>Current Drivers</h2>
        <div class="section-rule"></div>
        <span class="t-eyebrow current-drivers-year" style={`color: ${team.color};`}>{currentYear} Season</span>
      </div>
      <div class={`current-drivers-grid count-${currentDriverPhotos.length}`}>
        {currentDriverPhotos.map(d => (
          <a class="panel current-driver-card" href={`/drivers/${d.driverRef}/`} style={`border-left: 3px solid ${team.color};`}>
            {d.hasHeadshot ? (
              <img class="current-driver-photo" src={`/${d.headshotPath}`} alt={d.name} loading="lazy" width="120" height="150" />
            ) : (
              <div class="current-driver-photo silhouette" style={`--team-color: ${team.color};`} aria-hidden="true">
                <svg viewBox="0 0 100 120" xmlns="http://www.w3.org/2000/svg">
                  <path d="M50 12 C28 12 18 28 18 46 L18 60 L14 70 L14 82 L20 88 L20 120 L80 120 L80 88 L86 82 L86 70 L82 60 L82 46 C82 28 72 12 50 12 Z" fill={team.color} />
                </svg>
              </div>
            )}
            <div class="current-driver-meta">
              <div class="t-eyebrow current-driver-code" style={`color: ${team.color};`}>{d.code || '-'}</div>
              <div class="current-driver-name">{d.name}</div>
              {d.recent.length > 0 && (
                <div class="current-driver-form">
                  <span class="t-eyebrow current-driver-form-lbl">Last {d.recent.length}</span>
                  <svg class="current-driver-chart" width={CHART_W} height={CHART_H} viewBox={`0 0 ${CHART_W} ${CHART_H}`} aria-hidden="true">
                    {chartBars(d.recent).map(b => (
                      <rect
                        x={b.x}
                        y={b.y}
                        width={b.w}
                        height={b.h}
                        fill={b.v > 0 ? team.color : 'var(--line-1)'}
                        opacity={b.v > 0 ? 1 : 0.5}
                      />
                    ))}
                  </svg>
                </div>
              )}
            </div>
            {d.standing && (
              <div class="current-driver-right">
                <div class="t-eyebrow">{currentYear} Season</div>
                <div class={`current-driver-pos ${d.standing.position === 1 ? 'is-champ' : ''}`} style={d.standing.position === 1 ? undefined : `color: ${team.color};`}>
                  P{d.standing.position}
                </div>
                <div class="current-driver-pts">{d.standing.points} pts{d.standing.wins ? ` · ${d.standing.wins}W` : ''}</div>
              </div>
            )}
          </a>
        ))}
      </div>
    </>
  )}

  {hasCarImage && (
    <div class="car-showcase panel" style={`border-left: 3px solid ${team.color};`}>
      <div class="t-eyebrow car-showcase-label" style={`color: ${team.color};`}>2026 Car</div>
      <img src={`/${carImagePath}`} alt={`${team.name} 2026 car`} width="800" height="320" loading="eager" />
    </div>
  )}

  <div class="section-head"><h2>Career Stats</h2><div class="section-rule"></div></div>
  <div class="grid team-career-grid">
    <div class="stat"><div class="stat-lbl">Seasons</div><div class="stat-val">{fmtNum(team.career.seasons)}</div></div>
    <div class="stat"><div class="stat-lbl">Races</div><div class="stat-val">{fmtNum(team.career.races)}</div></div>
    <div class="stat"><div class="stat-lbl">Wins</div><div class="stat-val">{fmtNum(team.career.wins)}</div></div>
    <div class="stat"><div class="stat-lbl">Podiums</div><div class="stat-val">{fmtNum(team.career.podiums)}</div></div>
    <div class={`stat ${team.career.championships > 0 ? 'stat-accent' : ''}`}>
      <div class="stat-lbl">WCC</div>
      <div class="stat-val">{fmtNum(team.career.championships)}</div>
    </div>
  </div>

  {best && (
    <>
      <div class="section-head"><h2>Best Season</h2><div class="section-rule"></div></div>
      <div class="panel best-hero" style={`border-left: 3px solid ${team.color};`}>
        <div class="best-hero-left">
          <div class="t-eyebrow best-eyebrow" style={`color: ${team.color};`}>Best Season</div>
          <div class="best-hero-year">{best.year}</div>
          <div class="best-hero-tagline" style={`color: ${team.color};`}>{best.tagline}</div>
          {best.drivers.length > 0 && (
            <div class="best-hero-drivers">
              <div class="t-eyebrow best-hero-drivers-lbl">Drivers</div>
              <div class="best-hero-drivers-chips">
                {best.drivers.map((d) => (
                  <a href={`/drivers/${d.driverRef}/`} class="best-hero-chip">{d.name}</a>
                ))}
              </div>
            </div>
          )}
        </div>
        <div class="best-hero-right">
          <div class="best-hero-stat">
            <div class="best-hero-stat-lbl">Constructors</div>
            <div class={`best-hero-stat-val ${bestIsChampion ? 'is-champ' : ''}`}>{ord(best.position)}</div>
          </div>
          <div class="best-hero-stat">
            <div class="best-hero-stat-lbl">Win Rate</div>
            <div class="best-hero-stat-val">{fmtPct(best.winRate)}</div>
          </div>
          <div class="best-hero-stat">
            <div class="best-hero-stat-lbl">Wins</div>
            <div class="best-hero-stat-val">{best.wins}</div>
          </div>
          <div class="best-hero-stat">
            <div class="best-hero-stat-lbl">Points</div>
            <div class="best-hero-stat-val">{best.points != null ? best.points : '-'}</div>
          </div>
        </div>
      </div>
    </>
  )}

  {team.topDrivers && team.topDrivers.length > 0 && (
    <>
      <div class="section-head"><h2>Notable Drivers</h2><div class="section-rule"></div></div>
      <div class="team-drivers-grid">
        {team.topDrivers.map((d) => (
          <a class="team-driver-card" href={`/drivers/${d.driverRef}/`}>
            <div class="team-driver-name-row">
              {(d.country || d.flag) && (
                <span class="team-driver-flag"><Flag cc={d.country} flag={d.flag} name={d.name} /></span>
              )}
              <span class="team-driver-name">{d.name}</span>
            </div>
            <div class="team-driver-stats">
              <span class="t-mono">{d.races} races</span>
              <span class="sep">·</span>
              <span class={`t-mono team-driver-wins ${d.wins > 0 ? 'has-wins' : ''}`}>{d.wins} wins</span>
            </div>
          </a>
        ))}
      </div>
    </>
  )}

  {team.perSeason.length > 0 && (
    <>
      <div class="section-head"><h2>Season by Season</h2><div class="section-rule"></div></div>
      <div class="panel" style="padding: 0; overflow-x: auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>Year</th>
              <th class="right">Pos</th>
              <th class="right">Points</th>
              <th class="right">Wins</th>
              <th class="right">Races</th>
              <th>Drivers</th>
            </tr>
          </thead>
          <tbody>
            {team.perSeason.map(s => (
              <tr>
                <td class="t-mono">{s.year}</td>
                <td class={`right ${s.position === 1 ? 'is-champ-cell' : ''}`}>{ord(s.position)}</td>
                <td class="right t-mono">{s.points != null ? s.points : '-'}</td>
                <td class="right t-mono">{s.wins}</td>
                <td class="right t-mono">{s.races}</td>
                <td>
                  {s.drivers.map((d, i) => (
                    <>{i > 0 && ', '}<a href={`/drivers/${d.driverRef}/`}>{d.name}</a></>
                  ))}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </>
  )}
</div>

<style>
  .team-hero { padding: 20px; margin-bottom: 20px; }
  .team-hero-grid { display: grid; grid-template-columns: 1fr auto; gap: 20px; align-items: center; }
  .team-hero-flag { margin-bottom: 6px; }
  .team-hero-title-row { display: flex; align-items: center; gap: 16px; margin-bottom: 8px; }
  .team-hero-logo { width: 72px; height: 72px; object-fit: contain; border-radius: 8px; background: #fff; padding: 6px; box-shadow: 0 2px 8px rgba(0,0,0,.08); flex-shrink: 0; }
  .team-hero-name { margin: 0; font-size: 56px; line-height: 1.05; }
  .team-hero-stats { display: flex; gap: 10px; align-items: center; color: var(--fg-3); flex-wrap: wrap; }
  .team-hero-stats .sep { color: var(--fg-4); }
  .team-hero-champ { text-align: right; }
  .team-hero-wcc { font-family: var(--f-display); font-weight: 800; font-size: 56px; line-height: 1; color: var(--fg-1); }
  .team-hero-wcc.is-champ { color: var(--accent); }
  .car-showcase { display: flex; flex-direction: column; align-items: center; padding: 20px; margin-top: 20px; margin-bottom: 20px; gap: 8px; }
  .car-showcase-label { align-self: flex-start; }
  .car-showcase img { max-width: 100%; max-height: 220px; width: auto; height: auto; object-fit: contain; filter: drop-shadow(0 6px 24px rgba(0,0,0,.3)); }

  .team-drivers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 8px;
    margin-bottom: 24px;
  }
  .team-driver-card {
    display: flex; flex-direction: column; gap: 4px;
    padding: 12px 14px;
    border: 1px solid var(--line-1);
    background: var(--bg-2);
    text-decoration: none;
    color: inherit;
    transition: border-color .15s, background .15s, transform .15s;
  }
  .team-driver-card:hover { border-color: var(--line-3); background: var(--bg-3); }
  .team-driver-name-row { display: flex; align-items: center; gap: 8px; min-width: 0; }
  .team-driver-flag { flex-shrink: 0; display: inline-flex; }
  .team-driver-flag :global(.flag-img) { width: 18px; height: 13.5px; border-radius: 1px; display: block; }
  .team-driver-name {
    font-family: var(--f-display); font-weight: 700;
    font-size: 15px; line-height: 1.2;
    color: var(--fg-1);
    min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .team-driver-stats { display: flex; gap: 6px; align-items: baseline; font-size: 12px; color: var(--fg-3); }
  .team-driver-stats .sep { color: var(--fg-4); }
  .team-driver-wins.has-wins { color: var(--accent); font-weight: 600; }
  @media (max-width: 720px) {
    .team-drivers-grid { grid-template-columns: 1fr; }
  }

  .team-career-grid { grid-template-columns: repeat(5, 1fr); }
  @media (max-width: 720px) {
    .team-hero-name { font-size: 32px; }
    .team-hero-grid { grid-template-columns: 1fr; }
    .team-hero-grid.has-car { grid-template-columns: 1fr; }
    .team-hero-car { justify-content: flex-start; }
    .team-hero-car img { max-height: 120px; }
    .team-hero-champ { text-align: left; }
    .team-career-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .stat-accent { border-color: var(--accent); }
  .stat-accent .stat-lbl, .stat-accent .stat-val { color: var(--accent); }

  .data-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .data-table th, .data-table td { padding: 8px 12px; border-bottom: 1px solid var(--line-1); text-align: left; }
  .data-table th { font-family: var(--f-display); font-weight: 600; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--fg-3); background: var(--bg-2); }
  .data-table tr:last-child td { border-bottom: 0; }
  .data-table .right { text-align: right; }
  .data-table .is-win-cell, .data-table .is-champ-cell { color: var(--accent); font-weight: 700; }
  .data-table a { color: inherit; text-decoration: none; border-bottom: 1px dotted var(--line-2); }

  /* Current Drivers section */
  .current-drivers-year { margin-left: auto; font-weight: 600; }
  .current-drivers-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 20px; }
  .current-drivers-grid.count-1 { grid-template-columns: minmax(0, 320px); }
  .current-driver-card { display: flex; align-items: center; gap: 16px; padding: 14px 16px; text-decoration: none; color: inherit; transition: background .15s, border-color .15s; }
  .current-driver-card:hover { background: var(--bg-3); }
  .current-driver-photo { width: 72px; height: 90px; object-fit: cover; border-radius: 4px; background: var(--bg-3); flex-shrink: 0; }
  .current-driver-photo.silhouette { display: flex; align-items: center; justify-content: center; }
  .current-driver-photo.silhouette svg { width: 100%; height: 100%; opacity: 0.55; }
  .current-driver-meta { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .current-driver-code { font-family: var(--f-mono); font-weight: 700; font-size: 12px; letter-spacing: 0.12em; }
  .current-driver-name { font-family: var(--f-display); font-weight: 700; font-size: 20px; line-height: 1.15; color: var(--fg-1); }
  .current-driver-form { display: flex; align-items: center; gap: 8px; margin-top: 4px; }
  .current-driver-form-lbl { font-size: 9px; color: var(--fg-4); }
  .current-driver-chart { display: block; }
  .current-driver-right { margin-left: auto; text-align: right; flex-shrink: 0; padding-left: 8px; }
  .current-driver-pos { font-family: var(--f-display); font-weight: 800; font-size: 36px; line-height: 1; margin-top: 2px; }
  .current-driver-pos.is-champ { color: var(--accent); }
  .current-driver-pts { font-family: var(--f-display); font-size: 11px; font-weight: 600; letter-spacing: 0.06em; color: var(--fg-3); margin-top: 4px; }
  @media (max-width: 720px) {
    .current-driver-pos { font-size: 28px; }
  }
  @media (max-width: 720px) {
    .current-drivers-grid { grid-template-columns: 1fr; }
    .current-driver-name { font-size: 17px; }
    .current-driver-photo { width: 60px; height: 76px; }
  }

  /* Best Season hero card */
  .best-hero { padding: 24px; display: grid; grid-template-columns: 1.1fr 1fr; gap: 32px; align-items: center; }
  .best-hero-left { display: flex; flex-direction: column; }
  .best-hero-left .best-eyebrow { margin-bottom: 6px; }
  .best-hero-year { font-family: var(--f-display); font-weight: 800; font-size: 96px; line-height: 0.95; letter-spacing: -0.01em; color: var(--fg-1); }
  .best-hero-tagline { font-family: var(--f-display); font-weight: 700; font-size: 22px; letter-spacing: 0.04em; text-transform: uppercase; margin-top: 4px; }
  .best-hero-drivers { margin-top: 16px; }
  .best-hero-drivers-lbl { margin-bottom: 8px; }
  .best-hero-drivers-chips { display: flex; flex-wrap: wrap; gap: 6px; }
  .best-hero-chip { display: inline-block; padding: 3px 10px; border: 1px solid var(--line-2); border-radius: 999px; font-size: 12px; font-weight: 600; color: var(--fg-1); text-decoration: none; transition: background .15s, border-color .15s; }
  .best-hero-chip:hover { background: var(--bg-3); border-color: var(--line-3); }
  .best-hero-right { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--line-1); border: 1px solid var(--line-1); }
  .best-hero-stat { background: var(--bg-2); padding: 14px 16px; display: flex; flex-direction: column; gap: 6px; }
  .best-hero-stat-lbl { font-family: var(--f-display); font-weight: 600; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--fg-3); }
  .best-hero-stat-val { font-family: var(--f-display); font-weight: 800; font-size: 34px; line-height: 1; color: var(--fg-1); }
  .best-hero-stat-val.is-champ { color: var(--accent); }
  @media (max-width: 720px) {
    .best-hero { grid-template-columns: 1fr; gap: 20px; padding: 20px; }
    .best-hero-year { font-size: 72px; }
  }
</style>
