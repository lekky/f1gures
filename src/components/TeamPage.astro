---
// Pure server-rendered constructor (team) detail page. Hero with
// championships, current drivers, car render, all-time record, recent
// seasons + notable drivers, best season, lineage and full season history.
// No React island, no client JS shipped.

import { existsSync, readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import Flag from './Flag.astro';
import LineageStrip from './LineageStrip.astro';
import { NATIONALITY } from '../lib/nationality.js';
import TriviaBoard from './islands/screens/TriviaBoard.jsx';

interface Props {
  currentYear: number | null;
  recentForm: Record<string, number[]>;
  currentStandings: Record<string, { position: number; points: number; wins: number }>;
  team: {
    constructorRef: string;
    name: string;
    nationality: string | null;
    url: string | null;
    color: string;
    short: string;
    career: {
      seasons: number;
      firstYear: number | null;
      lastYear: number | null;
      races: number;
      wins: number;
      podiums: number;
      championships: number;
      driverCount: number;
    };
    perSeason: Array<{
      year: number;
      drivers: Array<{ driverRef: string; name: string; code: string; country?: string | null; flag?: string | null; position?: number | null }>;
      position: number | null;
      points: number | null;
      wins: number;
      races: number;
    }>;
    topDrivers: Array<{ driverRef: string; name: string; country?: string | null; flag?: string | null; races: number; wins: number }>;
    bestSeason: {
      year: number;
      position: number | null;
      points: number | null;
      wins: number;
      races: number;
      winRate: number;
      tagline: string;
      drivers: Array<{ driverRef: string; name: string }>;
    } | null;
    lineage?: {
      chainId: string;
      selfIndex: number;
      nodes: Array<{
        ref: string;
        name: string;
        displayNameOverride?: string;
        color: string;
        from: number;
        to: number | null;
        seasons: number;
        wins: number;
        championships: number;
        isSelf: boolean;
      }>;
    };
  };
}

const { team, currentYear, recentForm, currentStandings } = Astro.props;

const CAR_IMAGE_FOR_REF: Record<string, string> = {
  alpine:        'alpine-2026.avif',
  aston:         'astonmartin-2026.avif',
  aston_martin:  'astonmartin-2026.avif',
  audi:          'audi-2026.avif',
  cadillac:      'cadillac-2026.avif',
  ferrari:       'ferrari-2026.avif',
  haas:          'haas-2026.avif',
  mclaren:       'mclaren-2026.avif',
  mercedes:      'mercedes-2026.avif',
  rb:            'racingbulls-2026.avif',
  redbull:       'redbull-2026.avif',
  red_bull:      'redbull-2026.avif',
  williams:      'williams-2026.avif',
};
const carFile = CAR_IMAGE_FOR_REF[team.constructorRef];
const carImagePath = carFile ? `images/cars/${carFile}` : null;
const hasCarImage = carImagePath ? existsSync(resolve(process.cwd(), 'public', carImagePath)) : false;

const logoImagePath = `images/teams/${team.constructorRef}.jpg`;
const hasLogo = existsSync(resolve(process.cwd(), 'public', logoImagePath));

// Flag wash: the team's licensed-nationality flag, right-pinned behind the
// hero and dissolving toward the info on load (mirrors the driver-hero
// treatment). Flag SVG (lipis 4:3) resolved from the constructor's
// nationality demonym via src/lib/nationality.js, with an existsSync guard.
// Inline the flag as a data-URI with preserveAspectRatio="none" so it stretches
// edge-to-edge under `background-size: 100% 100%` instead of letterboxing into a
// centred strip (the lipis SVGs ship `…meet`). See DriverPage.astro.
const teamCountry = team.nationality ? (NATIONALITY[team.nationality]?.country ?? null) : null;
const flagWashSrc = teamCountry
  ? (() => {
      const abs = resolve(process.cwd(), 'public', `images/flags/${teamCountry.toLowerCase()}.svg`);
      if (!existsSync(abs)) return null;
      let svg = readFileSync(abs, 'utf8');
      svg = /preserveAspectRatio=/.test(svg)
        ? svg.replace(/preserveAspectRatio="[^"]*"/, 'preserveAspectRatio="none"')
        : svg.replace(/<svg\b/, '<svg preserveAspectRatio="none"');
      return `data:image/svg+xml,${encodeURIComponent(svg)}`;
    })()
  : null;

const yearsLabel = team.career.firstYear === team.career.lastYear
  ? `${team.career.firstYear}`
  : `${team.career.firstYear}–${team.career.lastYear}`;
const fmtNum = (n: number | null | undefined) => (n == null ? '-' : String(n));
const ord = (n: number | null) => (n == null ? '-' : `P${n}`);
const fmtPct = (n: number) => `${(n * 100).toFixed(1)}%`;
const best = team.bestSeason;
const bestIsChampion = best != null && best.position === 1;

// Current-team detection: latest perSeason entry matches the active season
// bundle. perSeason is newest-first from build-archive.mjs.
const latestSeason = team.perSeason[0] ?? null;
const isCurrent = !!(currentYear && latestSeason && latestSeason.year === currentYear);
const currentDrivers = isCurrent ? latestSeason!.drivers : [];
const currentDriverPhotos = currentDrivers.map(d => {
  const headshotPath = `images/drivers/${d.driverRef}.webp`;
  const hasHeadshot = existsSync(resolve(process.cwd(), 'public', headshotPath));
  const recent = (recentForm && recentForm[d.driverRef]) || [];
  const standing = (currentStandings && currentStandings[d.driverRef]) || null;
  return { ...d, headshotPath, hasHeadshot, recent, standing };
});

// Per-driver year span across the team's seasons - used in the Notable
// Drivers list (e.g. "2013–2024"). Derived from perSeason driver entries.
const driverYears = new Map<string, { from: number; to: number }>();
for (const s of team.perSeason) {
  for (const d of s.drivers) {
    const cur = driverYears.get(d.driverRef);
    if (!cur) driverYears.set(d.driverRef, { from: s.year, to: s.year });
    else { cur.from = Math.min(cur.from, s.year); cur.to = Math.max(cur.to, s.year); }
  }
}
function driverSpan(ref: string): string {
  const y = driverYears.get(ref);
  if (!y) return '';
  if (currentYear && y.to === currentYear) return `${y.from}–now`;
  return y.from === y.to ? `${y.from}` : `${y.from}–${y.to}`;
}

// Recent Seasons - newest 6, with a points-scaled finish bar.
const recentSeasons = team.perSeason.slice(0, 6);
const recentMaxPoints = Math.max(1, ...recentSeasons.map(s => s.points ?? 0));

// Standings-style full season table: podium position cells + proportional
// team-coloured points bars scaled to the team's best-ever season.
const seasonMaxPoints = Math.max(1, ...team.perSeason.map(s => s.points ?? 0));
const posClass = (n: number | null | undefined) => (n != null && n >= 1 && n <= 3 ? `pos pos-${n}` : 'pos');

// Memoized headshot existence check - only ~32 modern drivers ship a WebP.
const faceCache = new Map<string, boolean>();
function hasFace(ref: string): boolean {
  if (!faceCache.has(ref)) {
    faceCache.set(ref, existsSync(resolve(process.cwd(), 'public', `images/drivers/${ref}.webp`)));
  }
  return faceCache.get(ref)!;
}
---

<div class="page">
  <a class="btn btn-ghost btn-sm" style="margin-bottom: 12px" href="/standings-constructors/">← Constructors</a>

  <div class="panel team-hero" style={`--team-color: ${team.color}; border-left: 3px solid ${team.color};`}>
    <span class="team-hero-watermark" aria-hidden="true">{team.short}</span>
    {flagWashSrc && (
      <div class="team-hero-flagwash" style={`background-image: url(${flagWashSrc})`} aria-hidden="true"></div>
    )}
    <div class="team-hero-grid">
      <div class="team-hero-meta">
        <div class="team-hero-overline">
          <span class="team-hero-nat">{team.nationality || '-'}</span>
          <span class="sep">·</span>
          <span class="team-hero-since">Since {team.career.firstYear ?? '-'}</span>
        </div>
        <div class="team-hero-title-row">
          {hasLogo ? (
            <img class="team-hero-logo" src={`/${logoImagePath}`} alt={`${team.name} logo`} width="64" height="64" loading="eager" />
          ) : (
            <span class="team-hero-logo team-hero-logo-text" style={`color: ${team.color};`}>{team.short}</span>
          )}
          <h1 class="page-title team-hero-name">{team.name}</h1>
        </div>
        <div class="team-hero-stats">
          <span class="t-mono">{team.short}</span>
          <span class="sep">·</span>
          <span class="t-mono">{yearsLabel}</span>
          <span class="sep">·</span>
          <span class="t-mono">{team.career.driverCount} drivers</span>
        </div>
      </div>
      <div class="team-hero-champ">
        <div class="t-eyebrow">Constructors' Titles</div>
        <div class={`team-hero-wcc ${team.career.championships > 0 ? 'is-champ' : ''}`} style={team.career.championships > 0 ? `color: ${team.color};` : undefined}>
          {team.career.championships}
        </div>
      </div>
    </div>
  </div>

  {/* Trigger the flag-wash entrance wipe only when the page is visible, so a
      frozen/hidden preview never traps it at its invisible first frame. The
      wash is CSS-visible without this. */}
  <script is:inline>
    (function () {
      function wipe() {
        var els = document.querySelectorAll('.driver-hero-flagwash, .team-hero-flagwash');
        for (var i = 0; i < els.length; i++) els[i].classList.add('is-wiping');
      }
      if (document.visibilityState === 'visible') { wipe(); }
      else {
        document.addEventListener('visibilitychange', function onVis() {
          if (document.visibilityState === 'visible') {
            wipe();
            document.removeEventListener('visibilitychange', onVis);
          }
        });
      }
    })();
  </script>

  <TriviaBoard client:visible />

  {isCurrent && currentDriverPhotos.length > 0 && (
    <>
      <div class="section-head section-head-band">
        <span class="section-head-mark" aria-hidden="true"></span>
        <h2>{currentYear} Drivers</h2>
        <div class="section-rule"></div>
      </div>
      <div class={`current-drivers-grid count-${currentDriverPhotos.length}`}>
        {currentDriverPhotos.map(d => (
          <a class="panel current-driver-card" href={`/drivers/${d.driverRef}/`} style={`border-left: 3px solid ${team.color};`}>
            {d.hasHeadshot ? (
              <img class="current-driver-photo" src={`/${d.headshotPath}`} alt={d.name} loading="lazy" width="120" height="150" />
            ) : (
              <div class="current-driver-photo silhouette" style={`--team-color: ${team.color};`} aria-hidden="true">
                <svg viewBox="0 0 100 120" xmlns="http://www.w3.org/2000/svg">
                  <path d="M50 12 C28 12 18 28 18 46 L18 60 L14 70 L14 82 L20 88 L20 120 L80 120 L80 88 L86 82 L86 70 L82 60 L82 46 C82 28 72 12 50 12 Z" fill={team.color} />
                </svg>
              </div>
            )}
            <div class="current-driver-meta">
              <div class="current-driver-code" style={`color: ${team.color};`}>{d.code || '-'}</div>
              <div class="current-driver-name">{d.name}</div>
              {d.standing && (
                <div class="current-driver-line">{d.standing.points} pts · {d.standing.wins}W</div>
              )}
            </div>
            {d.standing && (
              <div class="current-driver-right">
                <div class={`current-driver-pos ${d.standing.position === 1 ? 'is-champ' : ''}`} style={d.standing.position === 1 ? undefined : `color: ${team.color};`}>
                  P{d.standing.position}
                </div>
              </div>
            )}
          </a>
        ))}
      </div>
    </>
  )}

  {hasCarImage && (
    <>
      <div class="section-head section-head-band"><span class="section-head-mark" aria-hidden="true"></span><h2>{currentYear ?? 2026} Car</h2><div class="section-rule"></div></div>
      <div class="car-showcase panel" style={`border-left: 3px solid ${team.color};`}>
        <img src={`/${carImagePath}`} alt={`${team.name} ${currentYear ?? 2026} car`} width="800" height="320" loading="eager" />
      </div>
    </>
  )}

  {best && (
    <>
      <div class="section-head section-head-band"><span class="section-head-mark" aria-hidden="true"></span><h2>Best Season</h2><div class="section-rule"></div></div>
      <div class="panel best-hero" style={`border-left: 3px solid ${team.color};`}>
        <div class="best-hero-left">
          <div class="t-eyebrow best-eyebrow" style={`color: ${team.color};`}>Best Season</div>
          <div class="best-hero-year">{best.year}</div>
          <div class="best-hero-tagline" style={`color: ${team.color};`}>{best.tagline}</div>
          {best.drivers.length > 0 && (
            <div class="best-hero-drivers">
              <div class="t-eyebrow best-hero-drivers-lbl">Drivers</div>
              <div class="best-hero-drivers-chips">
                {best.drivers.map((d) => (
                  <a href={`/drivers/${d.driverRef}/`} class="best-hero-chip">{d.name}</a>
                ))}
              </div>
            </div>
          )}
        </div>
        <div class="best-hero-right">
          <div class="best-hero-stat">
            <div class="best-hero-stat-lbl">Constructors</div>
            <div class={`best-hero-stat-val ${bestIsChampion ? 'is-champ' : ''}`}>{ord(best.position)}</div>
          </div>
          <div class="best-hero-stat">
            <div class="best-hero-stat-lbl">Win Rate</div>
            <div class="best-hero-stat-val">{fmtPct(best.winRate)}</div>
          </div>
          <div class="best-hero-stat">
            <div class="best-hero-stat-lbl">Wins</div>
            <div class="best-hero-stat-val">{best.wins}</div>
          </div>
          <div class="best-hero-stat">
            <div class="best-hero-stat-lbl">Points</div>
            <div class="best-hero-stat-val">{best.points != null ? best.points : '-'}</div>
          </div>
        </div>
      </div>
    </>
  )}

  <div class="section-head section-head-band"><span class="section-head-mark" aria-hidden="true"></span><h2>All-Time Record</h2><div class="section-rule"></div></div>
  <div class="grid team-record-grid">
    <div class="stat"><div class="stat-lbl">Seasons</div><div class="stat-val">{fmtNum(team.career.seasons)}</div></div>
    <div class="stat"><div class="stat-lbl">Races</div><div class="stat-val">{fmtNum(team.career.races)}</div></div>
    <div class="stat"><div class="stat-lbl">Wins</div><div class="stat-val">{fmtNum(team.career.wins)}</div></div>
    <div class="stat"><div class="stat-lbl">Podiums</div><div class="stat-val">{fmtNum(team.career.podiums)}</div></div>
    <div class={`stat ${team.career.championships > 0 ? 'stat-accent' : ''}`}>
      <div class="stat-lbl">Titles</div>
      <div class="stat-val">{fmtNum(team.career.championships)}</div>
    </div>
  </div>

  {recentSeasons.length > 0 && (
    <>
      <div class="section-head section-head-band"><span class="section-head-mark" aria-hidden="true"></span><h2>Recent Seasons</h2><div class="section-rule"></div></div>
      <div class="panel" style="padding: 0; overflow-x: auto;">
        <table class="tbl tbl-static">
          <thead>
            <tr>
              <th>Year</th>
              <th class="team-finish-col">Finish</th>
              <th class="right">Pts</th>
              <th class="right">Wins</th>
              <th class="right">Races</th>
              <th>Drivers</th>
            </tr>
          </thead>
          <tbody>
            {recentSeasons.map(s => (
              <tr>
                <td class="t-mono">{s.year}</td>
                <td class="team-finish-col">
                  <div class="finish-bar">
                    <div class="finish-bar-track">
                      <div
                        class={`finish-bar-fill ${s.position === 1 ? 'is-champ' : ''}`}
                        style={`width: ${Math.max(8, ((s.points ?? 0) / recentMaxPoints) * 100)}%; ${s.position === 1 ? '' : `background: ${team.color};`}`}
                      ></div>
                    </div>
                    <span class={`finish-bar-lbl ${s.position === 1 ? 'is-champ' : ''}`}>{ord(s.position)}</span>
                  </div>
                </td>
                <td class="right t-mono">{s.points != null ? s.points : '-'}</td>
                <td class="right t-mono">{s.wins}</td>
                <td class="right t-mono">{s.races}</td>
                <td class="team-drivers-cell">
                  {s.drivers.map(d => (
                    <a class="tdrv" href={`/drivers/${d.driverRef}/`}>
                      {(d.country || d.flag) && <span class="tdrv-flag"><Flag cc={d.country} flag={d.flag} name={d.name} /></span>}
                      {hasFace(d.driverRef) && <img class="tdrv-face" src={`/images/drivers/${d.driverRef}.webp`} alt="" width="22" height="22" loading="lazy" />}
                      <span class="tdrv-name">{d.name.split(' ').slice(-1)[0]}</span>
                      {d.position != null && <span class={`tdrv-pos ${d.position >= 1 && d.position <= 3 ? `pos-${d.position}` : ''}`}>P{d.position}</span>}
                    </a>
                  ))}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </>
  )}

  {team.topDrivers && team.topDrivers.length > 0 && (
    <>
      <div class="section-head section-head-band"><span class="section-head-mark" aria-hidden="true"></span><h2>Notable Drivers</h2><div class="section-rule"></div></div>
      <div class="notable-drivers">
        {team.topDrivers.slice(0, 6).map((d) => (
          <a class="notable-driver-card" href={`/drivers/${d.driverRef}/`} style={`border-left: 3px solid ${team.color};`}>
            <div class="notable-driver-name-row">
              {hasFace(d.driverRef) ? (
                <img class="notable-driver-face" src={`/images/drivers/${d.driverRef}.webp`} alt="" width="28" height="28" loading="lazy" />
              ) : (d.country || d.flag) ? (
                <span class="notable-driver-flag"><Flag cc={d.country} flag={d.flag} name={d.name} /></span>
              ) : null}
              <span class="notable-driver-name">{d.name}</span>
            </div>
            <div class="notable-driver-stats">
              {driverSpan(d.driverRef) && <span class="t-mono">{driverSpan(d.driverRef)}</span>}
              {driverSpan(d.driverRef) && <span class="sep">·</span>}
              <span class="t-mono">{d.races} races</span>
              <span class="sep">·</span>
              <span class={`t-mono notable-driver-wins ${d.wins > 0 ? 'has-wins' : ''}`}>{d.wins} wins</span>
            </div>
          </a>
        ))}
      </div>
    </>
  )}

  {team.lineage && team.lineage.nodes.length >= 2 && (
    <LineageStrip lineage={team.lineage} />
  )}

  {team.perSeason.length > 0 && (
    <>
      <div class="section-head section-head-band"><span class="section-head-mark" aria-hidden="true"></span><h2>Season by Season</h2><div class="section-rule"></div></div>
      <div class="panel" style="padding: 0; overflow-x: auto;">
        <table class="tbl tbl-static hist-tbl">
          <thead>
            <tr>
              <th>Year</th>
              <th class="center">Pos</th>
              <th class="right">Points</th>
              <th class="right">Wins</th>
              <th class="right">Races</th>
              <th>Drivers</th>
            </tr>
          </thead>
          <tbody>
            {team.perSeason.map(s => (
              <tr>
                <td class="t-mono">{s.year}</td>
                <td class="center"><div class={posClass(s.position)}>{s.position ?? '-'}</div></td>
                <td class="hist-pts-td">
                  <span class="std-bar" aria-hidden="true" style={`width:${((s.points ?? 0) / seasonMaxPoints) * 100}%; --tc:${team.color}`}></span>
                  <span class="hist-pts-val">{s.points != null ? s.points : '-'}</span>
                </td>
                <td class="right t-mono">{s.wins}</td>
                <td class="right t-mono">{s.races}</td>
                <td class="team-drivers-cell">
                  {s.drivers.map(d => (
                    <a class="tdrv" href={`/drivers/${d.driverRef}/`}>
                      {(d.country || d.flag) && <span class="tdrv-flag"><Flag cc={d.country} flag={d.flag} name={d.name} /></span>}
                      {hasFace(d.driverRef) && <img class="tdrv-face" src={`/images/drivers/${d.driverRef}.webp`} alt="" width="22" height="22" loading="lazy" />}
                      <span class="tdrv-name">{d.name.split(' ').slice(-1)[0]}</span>
                      {d.position != null && <span class={`tdrv-pos ${d.position >= 1 && d.position <= 3 ? `pos-${d.position}` : ''}`}>P{d.position}</span>}
                    </a>
                  ))}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </>
  )}
</div>

<style>
  /* ── Hero ───────────────────────────────────────────────────── */
  .team-hero { position: relative; padding: 22px 24px; margin-bottom: 24px; overflow: hidden; }
  .team-hero-watermark {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--f-display);
    font-weight: 800;
    font-size: 180px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--team-color);
    opacity: 0.08;
    pointer-events: none;
    z-index: 0;
  }
  /* Flag wash — the team's national flag, right-pinned and dissolving toward
     the info (mirrors the driver hero). --wash-op is themed so the entrance
     animation's final opacity follows. Sits below the content grid (z-index 1). */
  .team-hero-flagwash {
    --wash-op: 0.4;
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: var(--wash-op);
    background-repeat: no-repeat;
    background-position: center;
    /* Stretch to fill (not `cover`): the hero is far wider than a 4:3 flag, and
       `cover` would crop horizontal-striped flags (NL, DE, AT…) to one band. */
    background-size: 100% 100%;
    mix-blend-mode: screen;
    pointer-events: none;
    /* Edge-emphasis mask with SOLID colour bands at each edge (0-16% and
       84-100%) fading to a clean centre — colour reads clearly at left + right
       while the name/titles sit over an untinted middle (matches driver hero). */
    -webkit-mask: linear-gradient(90deg, #000 0%, #000 16%, transparent 44%, transparent 74%, #000 84%, #000 100%);
            mask: linear-gradient(90deg, #000 0%, #000 16%, transparent 44%, transparent 74%, #000 84%, #000 100%);
  }
  html.light .team-hero-flagwash { --wash-op: 0.38; mix-blend-mode: multiply; }
  /* Entrance wipe as a progressive enhancement only — the resting state
     (above) is visible on its own. A from-invisible animation with `both` fill
     would trap the wash at its invisible first frame whenever the timeline is
     frozen (backgrounded tab / embedded preview reporting the page hidden), so
     the wipe lives in a run-once class toggled by the inline script only when
     the page is actually visible. See DriverPage.astro for the shared script. */
  @media (prefers-reduced-motion: no-preference) {
    .team-hero-flagwash.is-wiping {
      animation: teamWashIn 1.1s 0.05s both cubic-bezier(0.18, 0.7, 0.16, 1);
    }
  }
  @keyframes teamWashIn {
    from { opacity: 0; clip-path: inset(0 0 0 100%); }
    to   { opacity: var(--wash-op); clip-path: inset(0 0 0 0); }
  }

  .team-hero-grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr auto; gap: 20px; align-items: center; }
  .team-hero-overline { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
