---
// Pure server-rendered circuit detail page. Redesigned to match the current
// race/driver/team treatment: a bordered hero with an animated track-map
// (red racing line + a dot lapping the circuit), the "Did You Know" trivia
// board, band section heads, a boxed outright-lap-record card, and a
// standings-styled historical-winners table with faces + team logos.

interface Props {
  circuit: {
    circuitRef: string;
    name: string;
    location: string;
    country: string;
    countryName: string;
    flag: string;
    lat: number | null;
    lng: number | null;
    raceCount: number;
    firstYear: number | null;
    lastYear: number | null;
    races: Array<{
      year: number;
      round: number;
      name: string;
      date: string | null;
      winnerRef: string | null;
      winnerName: string | null;
      winnerTeam: string | null;
      winnerTeamRef: string | null;
      poleRef: string | null;
      poleName: string | null;
      fastestLapRef: string | null;
      fastestLapTime: string | null;
    }>;
    mostWins: Array<{ driverRef: string; count: number; name: string }>;
    mostPoles: Array<{ driverRef: string; count: number; name: string }>;
  };
}

import { existsSync, readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import { circuitProfiles } from '../data/circuitProfiles.js';
import currentSeason from '../data/currentSeason.js';
import { fmtDateLong } from '../lib/shared.jsx';
import { hasDriverFace } from '../lib/driverFaceExists.js';
import { teamLogoPath } from '../lib/teamLogo.js';
import Flag from './Flag.astro';
import TriviaBoard from './islands/screens/TriviaBoard.jsx';

// /races/<y>/<r>/ pages exist for Ergast (1950-2024) + 2025 full bundle +
// 2026 completed AND upcoming rounds (via holding pages). build-archive.mjs
// emits all of these and adds them to _races-index.json. Future years without
// bundles still fall through to /race.html → /calendar/.
const ARCHIVE_MAX_YEAR = 2026;
function raceUrl(year: number | null, round: number | null): string {
  if (year == null || round == null) return '/calendar/';
  if (year <= ARCHIVE_MAX_YEAR) return `/races/${year}/${round}/`;
  return `/race.html?round=${round}&year=${year}`;
}

const { circuit } = Astro.props;
const yearsLabel = circuit.firstYear === circuit.lastYear
  ? `${circuit.firstYear}`
  : `${circuit.firstYear}–${circuit.lastYear}`;

// Track-map SVGs in public/images/circuits/{black,white}-outline/ use the
// site's internal ids (albert, marina, lasvegas, …) which diverge from
// Ergast's circuitRef in a handful of cases. Map known equivalents; for
// circuits without a curated SVG (the historic 50+) skip the map entirely.
const SVG_FOR_REF: Record<string, string> = {
  albert_park: 'albert',
  americas: 'cota',
  bahrain: 'bahrain',
  baku: 'baku',
  catalunya: 'catalunya',
  hungaroring: 'hungaroring',
  imola: 'imola',
  interlagos: 'interlagos',
  jeddah: 'jeddah',
  losail: 'losail',
  marina_bay: 'marina',
  miami: 'miami',
  monaco: 'monaco',
  monza: 'monza',
  red_bull_ring: 'spielberg',
  rodriguez: 'rodriguez',
  shanghai: 'shanghai',
  silverstone: 'silverstone',
  spa: 'spa',
  suzuka: 'suzuka',
  vegas: 'lasvegas',
  villeneuve: 'montreal',
  yas_marina: 'yas',
  zandvoort: 'zandvoort',
};
const svgName = SVG_FOR_REF[circuit.circuitRef];
const svgPath = svgName
  ? resolve(process.cwd(), 'public', 'images', 'circuits', 'black-outline', `${svgName}.svg`)
  : null;
const hasMap = !!svgPath && existsSync(svgPath);

// Pull the main racing-line path out of the curated SVG so we can re-draw it
// inline (themed red line + a dot lapping the circuit) rather than swapping a
// flat black/white <img>. The first <path> in every track SVG is the outline;
// the rest are start/finish-line ticks. Falls back to the flat <img> swap if
// extraction fails for any reason.
let trackD = '';
let trackVB = '0 0 500 500';
let trackStart: { x: number; y: number } | null = null;
if (hasMap && svgPath) {
  try {
    const raw = readFileSync(svgPath, 'utf8');
    const dMatch = raw.match(/<path[^>]*\sd="([^"]+)"/);
    if (dMatch) trackD = dMatch[1];
    const vb = raw.match(/viewBox="([^"]+)"/);
    const w = raw.match(/\bwidth="(\d+)"/);
    const h = raw.match(/\bheight="(\d+)"/);
    if (vb) trackVB = vb[1];
    else if (w && h) trackVB = `0 0 ${w[1]} ${h[1]}`;
    const m = trackD.match(/^[Mm]\s*(-?[\d.]+)[ ,]+(-?[\d.]+)/);
    if (m) trackStart = { x: parseFloat(m[1]), y: parseFloat(m[2]) };
  } catch {
    // leave trackD empty → flat-img fallback below
  }
}
const hasTrackPath = hasMap && !!trackD;

// Curated track characteristics + blurb live in src/data/circuitProfiles.js.
// Profile keys are the short ids the 2026 fallback grid uses (bahrain,
// albert, marina, …); inverse of HAND_CIRCUIT_ALIAS in
// scripts/build-archive.mjs maps back from Ergast circuitRefs.
const PROFILE_FOR_REF: Record<string, string> = {
  albert_park: 'albert',
  americas: 'cota',
  marina_bay: 'marina',
  red_bull_ring: 'spielberg',
  vegas: 'lasvegas',
  villeneuve: 'montreal',
  yas_marina: 'yas',
};
const profileKey = PROFILE_FOR_REF[circuit.circuitRef] || circuit.circuitRef;
const profile = (circuitProfiles as any)[profileKey] || null;
// Next-race lookup against the real current-season bundle (synced by
// prebuild): this circuit's calendar entry, but only while the race hasn't
// been run - once results exist it's history, not "Next Race".
const nextRace = ((currentSeason.calendar || []) as any[]).find(r =>
  (r.circuitId === circuit.circuitRef || r.circuit === profileKey) &&
  !(currentSeason.results || {})[r.round]
) || null;

// Two-letter monogram for the track-map corner (ISO country code, e.g. BH).
const monogram = (circuit.country || circuit.circuitRef || '').slice(0, 2).toUpperCase();

// Flag wash (mirrors the driver/team/race heroes): the circuit's country flag
// pinned to the right of the info panel, dissolving toward the name.
// circuit.country is an ISO alpha-2 code → the lipis SVG set, inlined as a
// data-URI with preserveAspectRatio="none" so it fills the box.
const washCc = circuit.country ? circuit.country.toLowerCase() : null;
const flagWashSrc = washCc
  ? (() => {
      const abs = resolve(process.cwd(), 'public', `images/flags/${washCc}.svg`);
      if (!existsSync(abs)) return null;
      let svg = readFileSync(abs, 'utf8');
      svg = /preserveAspectRatio=/.test(svg)
        ? svg.replace(/preserveAspectRatio="[^"]*"/, 'preserveAspectRatio="none"')
        : svg.replace(/<svg\b/, '<svg preserveAspectRatio="none"');
      return `data:image/svg+xml,${encodeURIComponent(svg)}`;
    })()
  : null;

// "View race weekend" CTA + the hero "Round NN" eyebrow. Prefer this circuit's
// round in the live season; otherwise feature the most recent race held here.
const seasonYearNum = Number(currentSeason.seasonYear) || null;
const racesByRecent = [...circuit.races].sort((a, b) =>
  (b.year - a.year) || ((b.round ?? 0) - (a.round ?? 0))
);
const thisSeasonRace = seasonYearNum ? racesByRecent.find(r => r.year === seasonYearNum) : null;
const featuredRace = thisSeasonRace || racesByRecent[0] || null;
const roundLabel = thisSeasonRace ? thisSeasonRace.round : null;
const featuredUrl = featuredRace ? raceUrl(featuredRace.year, featuredRace.round) : null;
// CTA label makes the season explicit: the live-season weekend vs the most
// recent past one (the year alone signals current vs. historic).
const featuredYear = featuredRace ? featuredRace.year : null;
const ctaLabel = featuredYear
  ? (thisSeasonRace ? `View ${featuredYear} Race Weekend` : `Latest Weekend · ${featuredYear}`)
  : 'View Race Weekend';

// Weather pill icons - match the legacy mapping.
const WEATHER_ICON: Record<string, string> = {
  'Changeable':     '🌦',
  'Coastal':        '🌊',
  'Cold Night':     '❄',
  'High Altitude':  '🏔',
  'Hot & Dry':      '☀',
  'Hot & Humid':    '💧',
  'Hot Night':      '☀',
  'Mild':           '🌤',
  'Mild & Dry':     '🌤',
  'Mild Night':     '🌙',
  'Wet & Variable': '🌧',
};
const RATING_FILL: Record<string, number> = { Low: 33, Medium: 66, High: 100 };

// Proportional fill for the value bars - each metric scaled against a rough
// real-world maximum so the bar lengths read meaningfully against each other
// (a 7 km lap looks long, a 14-corner circuit looks short, etc).
const BAR_MAX: Record<string, number> = {
  Length: 7.1, Laps: 78, Corners: 27, 'Longest Straight': 2200, 'DRS Zones': 4,
};
function barPct(lbl: string, v: number): number {
  const max = BAR_MAX[lbl] || v || 1;
  return Math.max(10, Math.min(100, (v / max) * 100));
}

type StatRow =
  | { lbl: string; val: string | number; fill: number; type: 'val' }
  | { lbl: string; val: 'Low' | 'Medium' | 'High'; type: 'rating' };

const stats: StatRow[] = profile ? ([
  profile.length          && { lbl: 'Length',           val: `${profile.length.toFixed(3)} km`, fill: barPct('Length', profile.length),                   type: 'val' as const },
  profile.laps            && { lbl: 'Laps',             val: profile.laps,                       fill: barPct('Laps', profile.laps),                       type: 'val' as const },
  profile.corners         && { lbl: 'Corners',          val: profile.corners,                    fill: barPct('Corners', profile.corners),                 type: 'val' as const },
  profile.longestStraight && { lbl: 'Longest Straight', val: `${profile.longestStraight} m`,     fill: barPct('Longest Straight', profile.longestStraight),type: 'val' as const },
  profile.drsZones        && { lbl: 'DRS Zones',        val: profile.drsZones,                   fill: barPct('DRS Zones', profile.drsZones),              type: 'val' as const },
  RATING_FILL[profile.tyreDeg]    && { lbl: 'Tyre Degradation', val: profile.tyreDeg,        type: 'rating' as const },
  RATING_FILL[profile.overtaking] && { lbl: 'Overtaking',       val: profile.overtaking,     type: 'rating' as const },
].filter(Boolean) as StatRow[]) : [];
const firstRatingIdx = stats.findIndex(s => s.type === 'rating');

const lapRecord = profile && profile.lapRecord && profile.lapRecord.driver !== '-' ? profile.lapRecord : null;

// Resolve driver headshots for card-accent holders. Falls back to a
// striped chip when no .webp exists (most historic drivers).
function driverImg(ref: string | null | undefined): string | null {
  if (!ref) return null;
  const rel = `images/drivers/${ref}.webp`;
  return existsSync(resolve(process.cwd(), 'public', rel)) ? `/${rel}` : null;
}
const lapRecordImg = lapRecord ? driverImg(lapRecord.driverRef) : null;

// Initials chip for winners/pole-sitters without a curated headshot.
function initials(name: string | null): string {
  if (!name) return '–';
  return name.trim().split(/\s+/).map(w => w[0]).slice(0, 2).join('').toUpperCase();
}

interface CircuitRecordCard {
  id: 'most-wins' | 'most-poles';
  title: string;
  unit: string;
  top: Array<{ driverRef: string; count: number; name: string }>;
}
const recordCards: CircuitRecordCard[] = [
  circuit.mostWins.length  ? { id: 'most-wins',  title: 'Most Wins',  unit: 'win', top: circuit.mostWins  } : null,
  circuit.mostPoles.length ? { id: 'most-poles', title: 'Most Poles', unit: 'pol', top: circuit.mostPoles } : null,
].filter(Boolean) as CircuitRecordCard[];
---

<div class="page circuit-detail">
  <a class="btn btn-ghost btn-sm" style="margin-bottom: 12px" href="/circuits/">← Circuits</a>

  <TriviaBoard client:visible />

  <div class={`panel circuit-hero ${hasMap ? 'has-map' : ''}`}>
    <div class="circuit-hero-info">
      {flagWashSrc && (
        <div class="circuit-hero-flagwash" style={`background-image: url(${flagWashSrc})`} aria-hidden="true"></div>
      )}
      <div class="t-eyebrow circuit-hero-eyebrow">
        Circuit Profile{roundLabel != null ? ` · Round ${String(roundLabel).padStart(2, '0')}` : ''}
      </div>
      <h1 class="page-title circuit-hero-name">{circuit.name}</h1>
      <div class="circuit-hero-loc">
        <Flag cc={circuit.country} flag={circuit.flag} name={circuit.countryName} class="circuit-hero-flag" />
        <span class="t-mono">{circuit.location.toUpperCase()}, {circuit.countryName.toUpperCase()}</span>
      </div>
      <div class="circuit-hero-pills">
        {circuit.firstYear ? <span class="pill">First F1 · {circuit.firstYear}</span> : null}
        {circuit.raceCount ? <span class="pill">{circuit.raceCount} races held</span> : null}
        {profile && profile.type && profile.type !== '-' && <span class="pill">{profile.type}</span>}
        {profile && profile.weather && profile.weather !== '-' && (
          <span class="pill pill-weather">
            {WEATHER_ICON[profile.weather] && <span style="margin-right: 6px">{WEATHER_ICON[profile.weather]}</span>}
            {profile.weather}
          </span>
        )}
      </div>
      {profile && profile.blurb && (
        <p class="circuit-hero-blurb">{profile.blurb}</p>
      )}
      {featuredUrl && (
        <a class="btn btn-primary circuit-hero-cta" href={featuredUrl}>{ctaLabel} →</a>
      )}
    </div>

    {hasMap && (
      <div class="circuit-hero-map">
        <div class="circuit-map-head">
          <span class="t-mono circuit-map-meta">
            {[profile && profile.type !== '-' ? profile.type : null, profile && profile.corners ? `${profile.corners} corners` : null].filter(Boolean).join(' · ') || 'Track Map'}
          </span>
          <span class="circuit-map-mono" aria-hidden="true">{monogram}</span>
        </div>
        {hasTrackPath ? (
          <svg class="ct-svg" viewBox={trackVB} preserveAspectRatio="xMidYMid meet" role="img" aria-label={`${circuit.name} track map`}>
            <path class="ct-glow" d={trackD} />
            <path class="ct-line" d={trackD} />
            {trackStart && <circle class="ct-start" cx={trackStart.x} cy={trackStart.y} r="9" />}
            <circle class="ct-dot" r="8">
              <animateMotion dur="11s" repeatCount="indefinite" rotate="auto" path={trackD} />
            </circle>
          </svg>
        ) : (
          <div class="circuit-track" aria-hidden="true">
            <img class="circuit-track-dark" src={`/images/circuits/white-outline/${svgName}.svg`} alt="" loading="lazy" />
            <img class="circuit-track-light" src={`/images/circuits/black-outline/${svgName}.svg`} alt="" loading="lazy" />
          </div>
        )}
      </div>
    )}
  </div>

  {/* Trigger the flag-wash entrance wipe only when the page is visible, so a
      frozen/hidden preview never traps it at its invisible first frame. The
      wash is CSS-visible without this. */}
  <script is:inline>
    (function () {
      function wipe() {
        var els = document.querySelectorAll('.circuit-hero-flagwash');
        for (var i = 0; i < els.length; i++) els[i].classList.add('is-wiping');
      }
      if (document.visibilityState === 'visible') { wipe(); }
      else {
        document.addEventListener('visibilitychange', function onVis() {
          if (document.visibilityState === 'visible') {
            wipe();
            document.removeEventListener('visibilitychange', onVis);
          }
        });
      }
    })();
  </script>

  {(stats.length > 0 || lapRecord || nextRace) && (
    <div class="circuit-mid-grid">
      {stats.length > 0 && (
        <div class="circuit-mid-col">
          <div class="section-head section-head-band"><span class="section-head-mark" aria-hidden="true"></span><h2>Track Characteristics</h2><div class="section-rule"></div></div>
          <div class="panel circuit-bars-panel">
            <div class="barset">
              {stats.map((s, i) => (
                <div class={`bar-row${i === firstRatingIdx ? ' bar-row-divide' : ''}`}>
                  <div class="bar-lbl">{s.lbl}</div>
                  {s.type === 'rating' ? (
                    <>
                      <div class="bar-track"><div class="bar-fill" style={`width: ${RATING_FILL[s.val]}%; background: ${s.val === 'High' ? 'var(--neg)' : s.val === 'Medium' ? 'var(--warn)' : 'var(--pos)'}`}></div></div>
                      <div class={`bar-rating ${s.val.toLowerCase()}`}>{s.val}</div>
                    </>
                  ) : (
                    <>
                      <div class="bar-track"><div class="bar-fill" style={`width: ${s.fill}%`}></div></div>
                      <div class="bar-val t-mono">{s.val}</div>
                    </>
                  )}
                </div>
              ))}
            </div>
          </div>
        </div>
      )}

      {(lapRecord || nextRace) && (
        <div class="circuit-mid-col">
          {lapRecord && (
            <>
              <div class="section-head section-head-band"><span class="section-head-mark" aria-hidden="true"></span><h2>Lap Record</h2><div class="section-rule"></div></div>
              <div class="panel circuit-lap-card">
                <span class="t-eyebrow circuit-lap-eyebrow">Outright Lap Record</span>
                <div class="circuit-lap-time">{lapRecord.time}</div>
                <div class="circuit-lap-holder">
                  {lapRecordImg
                    ? <img class="circuit-lap-face" src={lapRecordImg} alt={lapRecord.driver} width="44" height="44" loading="lazy" />
                    : <span class="circuit-lap-face circuit-lap-face-fallback" aria-hidden="true">{initials(lapRecord.driver)}</span>}
                  <div class="circuit-lap-holder-text">
                    <div class="circuit-lap-driver">
                      {lapRecord.driverRef
                        ? <a href={`/drivers/${lapRecord.driverRef}/`} class="inline-link">{lapRecord.driver}</a>
                        : lapRecord.driver}
                    </div>
                    <div class="circuit-lap-sub">Set in {lapRecord.year}</div>
                  </div>
                </div>
                <span class="circuit-lap-clock" aria-hidden="true">◷</span>
              </div>
              {profile && (
                <div class="grid circuit-lap-meta">
                  {profile.type && profile.type !== '-' && (
                    <div class="stat"><div class="stat-lbl">Type</div><div class="stat-val circuit-lap-meta-val">{profile.type}</div></div>
                  )}
                  {profile.weather && profile.weather !== '-' && (
                    <div class="stat"><div class="stat-lbl">Weather</div><div class="stat-val circuit-lap-meta-val">{profile.weather}</div></div>
                  )}
                </div>
              )}
            </>
          )}
          {nextRace && (
            <>
              <div class="section-head section-head-band"><span class="section-head-mark" aria-hidden="true"></span><h2>Next Race</h2><div class="section-rule"></div></div>
              <div class="stat stat-accent circuit-next-race">
                <div class="stat-lbl">Next Race Here</div>
                <div class="stat-val" style="font-size: 22px">{nextRace.name.replace(' Grand Prix', '')}</div>
                <div class="stat-sub">{fmtDateLong(nextRace.date)} · Round {nextRace.round}</div>
              </div>
            </>
          )}
        </div>
      )}
    </div>
  )}

  {recordCards.length > 0 && (
    <>
      <div class="section-head section-head-band"><span class="section-head-mark" aria-hidden="true"></span><h2>All-Time Records</h2><div class="section-rule"></div></div>
      <div class="records-grid">
        {recordCards.map(card => {
          const leader = card.top[0];
          const leaderImg = driverImg(leader.driverRef);
          const maxValue = Math.max(...card.top.map(e => e.count), 1);
          return (
            <a class="card-accent" href={`/drivers/${leader.driverRef}/`}>
              <header class="card-accent-head">
                <span class="card-accent-eyebrow">{card.title} · {circuit.name.replace(/\s+Circuit$/i, '').replace(/\s+Grand Prix Circuit$/i, '')}</span>
                <span class="card-accent-arrow" aria-hidden="true">↗</span>
              </header>

              <div class="card-accent-value">
                <span class="card-accent-num">{leader.count}</span>
                <span class="card-accent-unit">{leader.count === 1 ? card.unit : card.unit + 's'}</span>
              </div>

              <div class="card-accent-holder">
                <div class={`card-accent-avatar${leaderImg ? ' card-accent-avatar-image' : ''}`}>
                  {leaderImg
                    ? <img src={leaderImg} alt="" loading="lazy" />
                    : <span class="card-accent-avatar-tag">DRIVER</span>}
                </div>
                <div class="card-accent-holder-text">
                  <div class="card-accent-holder-name"><span>{leader.name}</span></div>
                  <div class="card-accent-holder-ctx">All-time leader at this circuit</div>
                </div>
              </div>

              <ol class="card-bars">
                {card.top.map((e, i) => {
                  const width = (e.count / maxValue) * 100;
                  const isLead = i === 0;
                  return (
                    <li class={`card-bar${isLead ? ' card-bar-lead' : ''}`}>
                      <span class="card-bar-rank">{i + 1}</span>
                      <span class="card-bar-cc"></span>
                      <div class="card-bar-track">
                        <span class="card-bar-fill" style={`width:${width}%;`}></span>
                        <span class="card-bar-name">{e.name}</span>
                      </div>
                      <span class="card-bar-value">
                        <span class="card-bar-num">{e.count}</span>
                        <span class="card-bar-unit"> {card.unit}</span>
                      </span>
                    </li>
                  );
                })}
              </ol>
            </a>
          );
        })}
      </div>
    </>
  )}

  {circuit.races.length > 0 && (
    <>
      <div class="section-head section-head-band"><span class="section-head-mark" aria-hidden="true"></span><h2>Historical Winners</h2><div class="section-rule"></div></div>
      <div class="panel" style="padding: 0; overflow-x: auto;">
        <table class="tbl tbl-static circuit-winners-tbl">
          <thead>
            <tr>
              <th class="right">Year</th>
              <th>Winner</th>
              <th>Team</th>
              <th>Pole</th>
              <th class="right">Fastest Lap</th>
            </tr>
          </thead>
          <tbody>
            {circuit.races.map(r => {
              const raceHref = raceUrl(r.year, r.round);
              const winnerFace = r.winnerRef && hasDriverFace(r.winnerRef) ? `/images/drivers/${r.winnerRef}.webp` : null;
              const poleFace = r.poleRef && hasDriverFace(r.poleRef) ? `/images/drivers/${r.poleRef}.webp` : null;
              const logo = teamLogoPath(r.winnerTeamRef);
              return (
                <tr>
                  <td class="right t-mono"><a href={raceHref} class="inline-link">{r.year}</a></td>
                  <td>
                    <span class="race-cell">
                      {winnerFace
                        ? <img class="cw-face" src={winnerFace} alt="" width="26" height="26" loading="lazy" />
                        : <span class="cw-face cw-face-fallback" aria-hidden="true">{initials(r.winnerName)}</span>}
                      {r.winnerRef && r.winnerName
                        ? <a href={`/drivers/${r.winnerRef}/`} class="inline-link cw-name">{r.winnerName}</a>
                        : <span class="cw-name">{r.winnerName || '-'}</span>}
                    </span>
                  </td>
                  <td>
                    <span class="race-cell">
                      {logo && <img class="team-logo-sm" src={logo} alt="" width="20" height="20" loading="lazy" />}
                      {r.winnerTeamRef
                        ? <a href={`/teams/${r.winnerTeamRef}/`} class="inline-link">{r.winnerTeam || r.winnerTeamRef}</a>
                        : (r.winnerTeam || '-')}
                    </span>
                  </td>
                  <td>
                    {r.poleName ? (
                      <span class="race-cell">
                        {poleFace
                          ? <img class="cw-face" src={poleFace} alt="" width="26" height="26" loading="lazy" />
                          : <span class="cw-face cw-face-fallback" aria-hidden="true">{initials(r.poleName)}</span>}
                        {r.poleRef
                          ? <a href={`/drivers/${r.poleRef}/`} class="inline-link cw-name">{r.poleName}</a>
                          : <span class="cw-name">{r.poleName}</span>}
                      </span>
                    ) : '-'}
                  </td>
                  <td class="right t-mono">{r.fastestLapTime || '-'}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </>
  )}
</div>

{hasTrackPath && (
  <script is:inline>
    // Respect reduced-motion: pause the SMIL dot-lap animation. The page ships
    // no other client JS; this is a one-shot accessibility guard.
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll('svg.ct-svg').forEach(function (s) {
        if (s.pauseAnimations) s.pauseAnimations();
      });
    }
  </script>
)}

