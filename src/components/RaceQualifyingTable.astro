---
// Standings-styled qualifying table. Same driver cell as the results table, but
// the team-coloured bar shows how close each driver got to pole on their best
// lap, and the gap chip reads "Pole" / "+0.234".

import Flag from './Flag.astro';
import { bestQualiSeconds, parseClock } from '../lib/raceTimings.js';
import { hasDriverFace } from '../lib/driverFaceExists.js';
import { teamLogoPath } from '../lib/teamLogo.js';

interface Row {
  position: number | null;
  driverRef: string | null;
  driverName: string | null;
  code: string | null;
  constructorRef: string | null;
  constructorName: string | null;
  constructorColor?: string | null;
  q1: string | null;
  q2: string | null;
  q3: string | null;
  country?: string | null;
  flag?: string | null;
}

interface Props {
  rows: Row[];
  id: string;
  maxRows?: number;
}

const { rows, id, maxRows = 10 } = Astro.props;

// Modern knockout qualifying: the top 10 contest Q3 and are classified by
// their Q3 lap, so rank/gap them strictly by Q3 time - not their best across
// Q1-Q3. A driver's Q2 lap can be quicker than their own Q3 lap, and a P10 who
// set no Q3 lap would borrow their Q1/Q2 time; either mis-orders the bars vs
// the official result (e.g. Leclerc P10 at 2026 Barcelona showed +0.602, ahead
// of the P8/P9 gaps). A top-10 driver with no Q3 lap has no pole-comparable
// time → "No time". Q1/Q2 knockouts (P11+) keep their best lap. Only triggers
// on knockout sessions (hasAnyQ3), so the pre-2006 single-time format is left
// untouched.
const Q3_CUTOFF = 10;
const hasAnyQ3 = rows.some(r => parseClock(r.q3) != null);
const inQ3Group = (r: Row): boolean =>
  hasAnyQ3 && r.position != null && r.position <= Q3_CUTOFF;
const noQ3Time = (r: Row): boolean => inQ3Group(r) && parseClock(r.q3) == null;

const bests = rows.map(r => (inQ3Group(r) ? parseClock(r.q3) : bestQualiSeconds(r)));
const pole = Math.min(...bests.filter((b): b is number => b != null), Infinity);
const gaps = bests.map(b => (b != null && Number.isFinite(pole) ? b - pole : null));
const maxGap = Math.max(0, ...gaps.filter((g): g is number => g != null && g > 0));
function barPct(gap: number | null): number {
  if (gap == null) return 0;
  if (gap <= 0) return 100;
  if (maxGap <= 0) return 100;
  return Math.max(14, 100 - (gap / maxGap) * 86);
}
function gapChip(gap: number | null): string | null {
  if (gap == null) return null;
  if (gap <= 0) return 'Pole';
  return `+${gap.toFixed(3)}`;
}
// Wrapped in a frontmatter fn: Astro's template compiler misreads an inline
// `<=` in a JSX expression as a tag opener.
const isPole = (gap: number | null): boolean => gap != null && gap <= 0;

const posClass = (n: number | null) => (n != null && n >= 1 && n <= 3 ? `pos pos-${n}` : 'pos');
const overflow = rows.length > maxRows;
function rowCls(i: number): string {
  return i >= maxRows ? 'rr-extra' : '';
}

// ── Mobile "bar + expand" rows (design handoff: Mobile Race Results) ──
// Pole = full bar + "Pole" chip; the field tapers 96% → 26% by gap to pole.
// Drivers with no pole-comparable lap get a striped bar + "No time".
const beWidth = (gap: number | null): number | null => {
  if (gap == null) return null;
  if (gap <= 0 || maxGap <= 0) return 100;
  return Math.max(26, Math.round(96 - (gap / maxGap) * 66));
};
const splitName = (name: string | null) => {
  const parts = (name || '').trim().split(' ');
  return { last: parts.pop() || '–', first: parts.join(' ') };
};
const initials = (r: Row) =>
  r.code || (r.driverName || '?').split(' ').map(w => w[0]).slice(0, 2).join('').toUpperCase();
// Frontmatter helper: inline `<=` in a JSX expression trips the Astro compiler.
const bePodium = (n: number | null) => n != null && n >= 1 && n <= 3;
---

<div class="panel tbl-collapsible" id={id} data-collapsed={overflow ? 'true' : 'false'}>
  <table class="tbl tbl-static rr-tbl">
    <thead>
      <tr>
        <th class="center">Pos</th>
        <th>Driver</th>
        <th>Team</th>
        <th class="right">Q1</th>
        <th class="right">Q2</th>
        <th class="right">Q3</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((r, i) => (
        <tr class={rowCls(i)} style={r.constructorColor ? `--team-color: ${r.constructorColor}` : ''}>
          <td class="center"><div class={posClass(r.position)}>{r.position != null ? r.position : '-'}</div></td>
          <td class="std-name-td">
            <span class="std-bar" aria-hidden="true" style={`width:${barPct(gaps[i])}%; --tc:${r.constructorColor || 'var(--fg-3)'}`}></span>
            <div class="std-name-inner rr-name-inner">
              {r.driverRef ? (
                <a class="std-name-id" href={`/drivers/${r.driverRef}/`}>
                  {hasDriverFace(r.driverRef)
                    ? <img class="rr-face" src={`/images/drivers/${r.driverRef}.webp`} alt="" width="26" height="26" loading="lazy" />
                    : <span class="rr-flag"><Flag cc={r.country} flag={r.flag} name={r.driverName} /></span>}
                  <span class="rr-name">{r.driverName}</span>
                  {r.code && <span class="rr-code t-mono">{r.code}</span>}
                </a>
              ) : (
                <span class="std-name-id">
                  <span class="rr-flag"><Flag cc={r.country} flag={r.flag} name={r.driverName} /></span>
                  <span class="rr-name">{r.driverName || '-'}</span>
                </span>
              )}
              {noQ3Time(r)
                ? <span class="std-gap std-gap-muted">No time</span>
                : gapChip(gaps[i]) && (
                    <span class={`std-gap ${isPole(gaps[i]) ? 'is-leader' : ''}`}>{gapChip(gaps[i])}</span>
                  )}
            </div>
          </td>
          <td>
            <span class="rr-team-cell">
              {teamLogoPath(r.constructorRef) && <img class="team-logo-sm" src={teamLogoPath(r.constructorRef)} alt="" width="20" height="20" loading="lazy" />}
              {r.constructorRef
                ? <a href={`/teams/${r.constructorRef}/`} class="rr-team">{r.constructorName}</a>
                : <span class="rr-team">{r.constructorName || '-'}</span>}
            </span>
          </td>
          <td class="right t-mono">{r.q1 || '-'}</td>
          <td class="right t-mono">{r.q2 || '-'}</td>
          <td class="right t-mono">{r.q3 || '-'}</td>
        </tr>
      ))}
    </tbody>
  </table>
  <div class="belist-wrap rr-belist">
    <div class="be-secline"><span class="yr">Grid order</span><span class="rule"></span><span class="cnt">{rows.length} drivers</span></div>
    <div class="belist">
      {rows.map((r, i) => {
        const noTime = noQ3Time(r) || gaps[i] == null;
        const pole = isPole(gaps[i]);
        const w = beWidth(gaps[i]);
        const { first, last } = splitName(r.driverName);
        const face = r.driverRef && hasDriverFace(r.driverRef) ? `/images/drivers/${r.driverRef}.webp` : null;
        const logo = teamLogoPath(r.constructorRef);
        const tc = r.constructorColor || 'var(--fg-3)';
        return (
        <div class={`berow ${pole ? 'lead' : ''} ${i === 0 ? 'open' : ''} ${rowCls(i)}`} style={`--tc:${tc}`}>
          <button class="behead" type="button" aria-expanded={i === 0 ? 'true' : 'false'}>
            <span class={`be-pos ${bePodium(r.position) ? `p${r.position}` : ''}`}>
              {r.position != null ? r.position : '–'}
            </span>
            <span class="be-main">
              <span class="be-who">
                <span class="tcbar" aria-hidden="true"></span>
                {face
                  ? <img class="be-av" src={face} alt="" width="30" height="30" loading="lazy" />
                  : <span class="be-av" aria-hidden="true">{initials(r)}</span>}
                <span class="rname"><span class="fn">{first}</span> {last}</span>
                <span class="chev" aria-hidden="true">▶</span>
              </span>
              <span class="be-track">
                {noTime || w == null
                  ? <span class="be-fill zero" style="width:100%"></span>
                  : <span class="be-fill" style={`width:${w}%`}></span>}
                {pole
                  ? <span class="be-win">Pole</span>
                  : noTime || gapChip(gaps[i]) == null
                    ? <span class="be-track-status"><span class="be-status fin">No time</span></span>
                    : <span class="be-gap">{gapChip(gaps[i])}</span>}
              </span>
            </span>
          </button>
          <div class="be-panel"><div><div class="be-inner">
            <div class="be-grid c3">
              <div class="c"><div class="l">Q1</div><div class="n mono">{r.q1 || '–'}</div></div>
              <div class="c"><div class="l">Q2</div><div class="n mono">{r.q2 || '–'}</div></div>
              <div class="c"><div class="l">Q3</div><div class="n mono">{r.q3 || '–'}</div></div>
            </div>
            <div class="be-drows">
              <div class="be-drow">
                <span class="k">Team</span>
                <span class="v">
                  {logo && <img class="be-team-logo" src={logo} alt="" width="14" height="14" loading="lazy" />}
                  {r.constructorRef
                    ? <a href={`/teams/${r.constructorRef}/`}>{r.constructorName}</a>
                    : (r.constructorName || '–')}
                </span>
              </div>
            </div>
            {r.driverRef && <a class="be-profile" href={`/drivers/${r.driverRef}/`}>View {last} profile →</a>}
          </div></div></div>
        </div>
        );
      })}
    </div>
  </div>
</div>
{overflow && (
  <button
    class="btn btn-secondary btn-sm tbl-expand"
    data-target={`#${id}`}
    data-more={`Show all ${rows.length}`}
    data-less={`Show top ${maxRows}`}
  >Show all {rows.length}</button>
)}

<style>
  /* Driver reached Q3 but set no Q3 lap - no pole-comparable time. */
  .std-gap-muted { color: var(--fg-4); font-weight: 500; }
</style>
