---
// Server-rendered body for completed races. Top: race-summary card + key-links
// (side by side), then the championship-style podium, then standings-styled
// Race / Qualifying / Sprint tables (each top-10 with a "Show all" expand).
//
// The shell (RacePage.astro) owns the hero, the trivia board, and prev/next nav.

interface Props {
  race: {
    year: number;
    round: number;
    name: string;
    date: string | null;
    time: string | null;
    circuit: any;
    results: Array<any>;
    qualifying: Array<any>;
    sprint: Array<any> | boolean | null;
  };
}

import { buildRaceSummary } from '../lib/buildRaceSummary.js';
import RacePodium from './RacePodium.astro';
import RaceResultsTable from './RaceResultsTable.astro';
import RaceQualifyingTable from './RaceQualifyingTable.astro';

const { race } = Astro.props;
const raceSummary = buildRaceSummary(race);

const winnerRow = race.results.find(r => r.position === 1) || null;
const poleQualifying = race.qualifying?.[0] || null;
const sprintRows = Array.isArray(race.sprint) ? race.sprint : [];

interface KeyLink { label: string; href: string; text: string; }
const keyLinks: KeyLink[] = [];
if (winnerRow?.driverRef && winnerRow?.driverName) {
  keyLinks.push({ label: 'Winner', href: `/drivers/${winnerRow.driverRef}/`, text: winnerRow.driverName });
}
if (poleQualifying?.driverRef && poleQualifying?.driverName && poleQualifying.driverRef !== winnerRow?.driverRef) {
  keyLinks.push({ label: 'Pole', href: `/drivers/${poleQualifying.driverRef}/`, text: poleQualifying.driverName });
}
if (race.circuit?.circuitRef && race.circuit?.name) {
  keyLinks.push({ label: 'Circuit', href: `/circuits/${race.circuit.circuitRef}/`, text: race.circuit.name });
}
if (winnerRow?.constructorRef && winnerRow?.constructorName) {
  keyLinks.push({ label: 'Winning team', href: `/teams/${winnerRow.constructorRef}/`, text: winnerRow.constructorName });
}

const winnerColor = winnerRow?.constructorColor || 'var(--accent)';
---

{(raceSummary || keyLinks.length > 0) && (
  <div class="race-intro">
    {raceSummary && (
      <div class="panel race-summary-card" style={`border-left: 3px solid ${winnerColor};`}>
        <p>{raceSummary}</p>
      </div>
    )}
    {keyLinks.length > 0 && (
      <div class="panel race-keylinks-card">
        <span class="t-eyebrow race-keylinks-title">Key Links</span>
        <ul>
          {keyLinks.map((l) => (
            <li>
              <span class="t-mono race-keylinks-lbl">{l.label}</span>
              <a href={l.href} class="inline-link">{l.text}</a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
)}

{race.results.length > 0 && (
  <RacePodium rows={race.results} />
)}

{race.results.length > 0 && (
  <>
    <div class="section-head section-head-band"><span class="section-head-mark" aria-hidden="true"></span><h2>Race Results</h2><div class="section-rule"></div></div>
    <RaceResultsTable rows={race.results} kind="race" id="rr-race" />
  </>
)}

{race.qualifying.length > 0 && (
  <>
    <div class="section-head section-head-band"><span class="section-head-mark" aria-hidden="true"></span><h2>Qualifying</h2><div class="section-rule"></div></div>
    <RaceQualifyingTable rows={race.qualifying} id="rr-quali" />
  </>
)}

{sprintRows.length > 0 && (
  <>
    <div class="section-head section-head-band"><span class="section-head-mark" aria-hidden="true"></span><h2>Sprint</h2><div class="section-rule"></div></div>
    <RaceResultsTable rows={sprintRows} kind="sprint" id="rr-sprint" />
  </>
)}

<script is:inline>
  // Expand/collapse the top-10 results tables. Each button toggles
  // data-collapsed on its target panel; CSS hides .rr-extra rows while collapsed.
  document.querySelectorAll('.tbl-expand').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var box = document.querySelector(btn.getAttribute('data-target'));
      if (!box) return;
      var collapsed = box.getAttribute('data-collapsed') === 'true';
      box.setAttribute('data-collapsed', collapsed ? 'false' : 'true');
      btn.textContent = collapsed ? btn.getAttribute('data-less') : btn.getAttribute('data-more');
    });
  });
</script>
