---
// Pure-Astro driver detail page. Server-rendered HTML, no React island, no
// client JS shipped - every byte is SEO content. Reuses the existing
// design-system classes (`panel`, `grid`, `stat`, `t-eyebrow`, `t-display`,
// `t-mono`, `section-head`, `page-title`) from css/app.css.

interface Props {
  driver: {
    driverRef: string;
    driverId: string;
    code: string | null;
    number: string | null;
    forename: string;
    surname: string;
    dob: string | null;
    nationality: string | null;
    url: string | null;
    career: {
      seasons: number;
      firstYear: number | null;
      lastYear: number | null;
      races: number;
      wins: number;
      podiums: number;
      poles: number;
      fastestLaps: number;
      championships: number;
    };
    perSeason: Array<{
      year: number;
      constructorRef: string | null;
      constructorName: string | null;
      position: number | null;
      points: number | null;
      wins: number;
      races: number;
      bestFinish: number | null;
    }>;
    perRace: Array<{
      year: number;
      round: number | null;
      raceName: string | null;
      date: string | null;
      constructorRef: string | null;
      constructorName: string | null;
      grid: number | null;
      position: number | null;
      positionText: string | null;
      points: number;
      fastestLapRank: number | null;
      status: string | null;
    }>;
  };
}

import { existsSync, readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import { buildDriverSummary } from '../lib/buildDriverSummary.js';
import { getDriverBio } from '../data/driverBios.js';

const { driver } = Astro.props;
const fullName = `${driver.forename} ${driver.surname}`;
const customBio = getDriverBio(driver.driverRef);
const driverSummary = customBio ? null : buildDriverSummary(driver, new Date().getFullYear());
const yearsLabel = driver.career.firstYear === driver.career.lastYear
  ? `${driver.career.firstYear}`
  : `${driver.career.firstYear}–${driver.career.lastYear}`;
const fmtNum = (n: number | null | undefined) => (n == null ? '-' : String(n));
const ord = (n: number | null) => (n == null ? '-' : `P${n}`);

// Headshot lookup - only ~32 modern drivers have a curated WebP in
// public/images/drivers/. For everyone else (most of the 862 drivers in
// the archive), fall back to a CSS-rendered silhouette placeholder.
const headshotPath = `images/drivers/${driver.driverRef}.webp`;
const hasHeadshot = existsSync(resolve(process.cwd(), 'public', headshotPath));

// Latest season - perSeason arrives newest-first from build-archive.mjs.
const latestSeason = driver.perSeason.length > 0 ? driver.perSeason[0] : null;

// Team colour: look up from the season JSON for the driver's latest year.
// Season JSONs exist for all years (generated from CSV for 1950–2019, hand-
// curated for 2020+). If the file is missing or the team isn't found, fall
// back to the site accent colour.
let teamColor = 'var(--accent)';
let teamRef = latestSeason?.constructorRef ?? null;
let teamName = latestSeason?.constructorName ?? null;

if (latestSeason?.year && teamRef) {
  try {
    const seasonPath = resolve(process.cwd(), 'public', 'data', `${latestSeason.year}.json`);
    const seasonData = JSON.parse(readFileSync(seasonPath, 'utf8'));
    const team = seasonData.teams?.find(
      (t: { id?: string; jolpicaId?: string; color?: string }) =>
        t.id === teamRef || t.jolpicaId === teamRef
    );
    if (team?.color) teamColor = team.color;
  } catch {
    // leave teamColor as accent fallback
  }
}

// Show current-season position/points for drivers active in 2025 or later;
// show seasons count for retired drivers.
const isActive = (driver.career.lastYear ?? 0) >= 2025;
const showSeasonStat = isActive && latestSeason != null;

// /races/<y>/<r>/ pages exist for Ergast (1950-2024) + 2025 full bundle +
// 2026 completed AND upcoming rounds (via holding pages). build-archive.mjs
// emits all of these and adds them to _races-index.json. Future years without
// bundles still fall through to /race.html → /calendar/.
const ARCHIVE_MAX_YEAR = 2026;
function raceUrl(year: number | null, round: number | null): string | null {
  if (year == null || round == null) return null;
  if (year <= ARCHIVE_MAX_YEAR) return `/races/${year}/${round}/`;
  return `/race.html?round=${round}&year=${year}`;
}

// Show races newest-first
const racesDesc = [...driver.perRace].sort((a, b) =>
  (b.year - a.year) || ((b.round ?? 0) - (a.round ?? 0))
);
---

<div class="page">
  <a class="btn btn-ghost btn-sm" style="margin-bottom: 12px" href="/standings-drivers/">← Standings</a>

  <div class="panel driver-hero" style={`border-left-color: ${teamColor}`}>
    <div class="driver-hero-grid">
      {hasHeadshot ? (
        <img class="driver-hero-photo" src={`/${headshotPath}`} alt={fullName} loading="lazy" width="180" height="220" />
      ) : (
        <div class="driver-hero-photo silhouette" style={`--team-color: ${teamColor}`} aria-hidden="true">
          <svg viewBox="0 0 100 120" xmlns="http://www.w3.org/2000/svg">
            <path d="M50 12 C28 12 18 28 18 46 L18 60 L14 70 L14 82 L20 88 L20 120 L80 120 L80 88 L86 82 L86 70 L82 60 L82 46 C82 28 72 12 50 12 Z" fill={teamColor} />
          </svg>
          {(driver.code || driver.number) && (
            <span class="driver-hero-badge">
              {driver.code}{driver.code && driver.number && driver.number !== '\\N' ? ' · ' : ''}{driver.number && driver.number !== '\\N' ? `#${driver.number}` : ''}
            </span>
          )}
        </div>
      )}
      <div class="driver-hero-body">
        <div class="driver-hero-meta">
          <div class="t-eyebrow driver-hero-nationality">{driver.nationality || '-'}</div>
          {teamName && teamRef && (
            <div class="driver-hero-team">
              <a href={`/teams/${teamRef}/`} style={`color: ${teamColor}`}>{teamName}</a>
            </div>
          )}
          <h1 class="page-title driver-hero-name">{fullName}</h1>
          <div class="driver-hero-stats">
            {driver.code && <span class="t-mono">{driver.code}</span>}
            {driver.code && <span class="sep">·</span>}
            {driver.number && driver.number !== '\\N' && <span class="t-mono">#{driver.number}</span>}
            {driver.number && driver.number !== '\\N' && <span class="sep">·</span>}
            <span class="t-mono">{yearsLabel}</span>
            {driver.dob && <span class="sep">·</span>}
            {driver.dob && <span class="t-mono">b. {driver.dob}</span>}
          </div>
        </div>
        <div class="driver-hero-right">
        {showSeasonStat ? (
          <>
            <div class="t-eyebrow">{latestSeason!.year} Season</div>
            <div class="driver-hero-pos" style={`color: ${teamColor}`}>
              {latestSeason!.position != null ? `P${latestSeason!.position}` : '-'}
            </div>
            <div class="driver-hero-pts">
              {latestSeason!.points != null ? `${latestSeason!.points} pts` : '-'}
            </div>
          </>
        ) : (
          <>
            <div class="t-eyebrow">Seasons in F1</div>
            <div class={`driver-hero-wdc ${driver.career.championships > 0 ? 'is-champ' : ''}`}>
              {driver.career.seasons}
            </div>
            {driver.career.championships > 0 && (
              <div class="driver-hero-pts">{driver.career.championships} WDC</div>
            )}
          </>
        )}
        </div>
      </div>
    </div>
  </div>

  {customBio ? (
    <div class="driver-summary">
      {customBio.map(p => <p>{p}</p>)}
    </div>
  ) : driverSummary && (
    <p class="driver-summary">{driverSummary}</p>
  )}

  <div class="section-head"><h2>Career Stats</h2><div class="section-rule"></div></div>
  <div class="grid driver-career-grid">
    <div class="stat"><div class="stat-lbl">Seasons</div><div class="stat-val">{fmtNum(driver.career.seasons)}</div></div>
    <div class="stat"><div class="stat-lbl">Races</div><div class="stat-val">{fmtNum(driver.career.races)}</div></div>
    <div class="stat"><div class="stat-lbl">Wins</div><div class="stat-val">{fmtNum(driver.career.wins)}</div></div>
    <div class="stat"><div class="stat-lbl">Podiums</div><div class="stat-val">{fmtNum(driver.career.podiums)}</div></div>
    <div class="stat"><div class="stat-lbl">Poles</div><div class="stat-val">{fmtNum(driver.career.poles)}</div></div>
    <div class="stat"><div class="stat-lbl">Fastest Laps</div><div class="stat-val">{fmtNum(driver.career.fastestLaps)}</div></div>
    <div class={`stat ${driver.career.championships > 0 ? 'stat-accent' : ''}`}>
      <div class="stat-lbl">WDC</div>
      <div class="stat-val">{fmtNum(driver.career.championships)}</div>
    </div>
  </div>

  {driver.perSeason.length > 0 && (
    <>
      <div class="section-head"><h2>Season by Season</h2><div class="section-rule"></div></div>
      <div class="panel" style="padding: 0; overflow-x: auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>Year</th>
              <th>Team</th>
              <th class="right">Pos</th>
              <th class="right">Points</th>
              <th class="right">Wins</th>
              <th class="right">Races</th>
              <th class="right">Best</th>
            </tr>
          </thead>
          <tbody>
            {driver.perSeason.map(s => (
              <tr>
                <td class="t-mono">{s.year}</td>
                <td>{s.constructorRef && s.constructorName ? (
                  <a href={`/teams/${s.constructorRef}/`} class="inline-link">{s.constructorName}</a>
                ) : (s.constructorName || '-')}</td>
                <td class={`right ${s.position === 1 ? 'is-champ-cell' : ''}`}>{ord(s.position)}</td>
                <td class="right t-mono">{s.points != null ? s.points : '-'}</td>
                <td class="right t-mono">{s.wins}</td>
                <td class="right t-mono">{s.races}</td>
                <td class="right t-mono">{ord(s.bestFinish)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </>
  )}

  {racesDesc.length > 0 && (
    <>
      <div class="section-head"><h2>Race by Race</h2><div class="section-rule"></div></div>
      <div class="panel" style="padding: 0; overflow-x: auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>Year</th>
              <th>Race</th>
              <th>Team</th>
              <th class="right">Grid</th>
              <th class="right">Finish</th>
              <th class="right">Pts</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            {racesDesc.map(r => {
              const raceHref = raceUrl(r.year, r.round);
              return (
                <tr>
                  <td class="t-mono">{r.year}</td>
                  <td>{r.raceName && raceHref ? (
                    <a href={raceHref} class="inline-link">{r.raceName}</a>
                  ) : (r.raceName || '-')}</td>
                  <td>{r.constructorRef && r.constructorName ? (
                    <a href={`/teams/${r.constructorRef}/`} class="inline-link">{r.constructorName}</a>
                  ) : (r.constructorName || '-')}</td>
                  <td class="right t-mono">{fmtNum(r.grid)}</td>
                  <td class={`right t-mono ${r.position === 1 ? 'is-win-cell' : ''}`}>{r.positionText || ord(r.position)}</td>
                  <td class="right t-mono">{r.points || 0}</td>
                  <td>{r.status || '-'}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </>
  )}
</div>

<style>
  .driver-hero { display: block; padding: 20px; margin-bottom: 20px; border-left: 4px solid var(--accent); }
  .driver-hero-grid {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 20px;
    align-items: center;
  }
  .driver-hero-photo {
    width: 180px;
    height: 220px;
    object-fit: cover;
    border-radius: 4px;
    background: var(--bg-2);
    color: var(--fg-3);
  }
  .driver-hero-body {
    display: flex;
    align-items: center;
    gap: 20px;
    min-width: 0;
  }
  .driver-hero-meta { flex: 1; min-width: 0; }
  /* silhouette placeholder reuses global .silhouette class from app.css */
  .driver-hero-photo.silhouette { border-radius: 4px; }
  .driver-hero-badge {
    position: absolute; bottom: 8px; left: 50%; transform: translateX(-50%);
    background: rgba(0,0,0,0.6); color: var(--fg-2);
    font-family: var(--f-mono); font-size: 10px; letter-spacing: 0.1em;
    padding: 2px 6px; border-radius: 2px; white-space: nowrap; z-index: 2;
  }
  .driver-hero-nationality { color: var(--fg-3); margin-bottom: 2px; }
  .driver-hero-team { margin-bottom: 6px; font-family: var(--f-display); font-weight: 700; font-size: 13px; letter-spacing: 0.08em; text-transform: uppercase; }
  .driver-hero-team a { text-decoration: none; }
  .driver-hero-team a:hover { text-decoration: underline; }
  .driver-hero-name { margin: 0 0 8px 0; font-size: 56px; line-height: 1.05; }
  .driver-hero-stats { display: flex; gap: 10px; align-items: center; color: var(--fg-3); flex-wrap: wrap; }
  .driver-hero-stats .sep { color: var(--fg-4); }
  .driver-hero-right { text-align: right; min-width: 100px; }
  .driver-hero-pos {
    font-family: var(--f-display);
    font-weight: 800;
    font-size: 56px;
    line-height: 1;
  }
  .driver-hero-pts {
    font-family: var(--f-display);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--fg-3);
    margin-top: 2px;
  }
  .driver-hero-wdc {
    font-family: var(--f-display);
    font-weight: 800;
    font-size: 56px;
    line-height: 1;
    color: var(--fg-1);
  }
  .driver-hero-wdc.is-champ { color: var(--accent); }

  .driver-summary p { margin: 0 0 12px; }
  .driver-summary p:last-child { margin-bottom: 0; }

  .driver-career-grid { grid-template-columns: repeat(7, 1fr); }
  @media (max-width: 720px) {
    .driver-hero-name { font-size: 32px; }
    .driver-hero-grid { grid-template-columns: 100px 1fr; }
    .driver-hero-photo { width: 100px; height: 130px; }
    .driver-hero-body { flex-wrap: wrap; }
    .driver-hero-right { flex-basis: 100%; text-align: left; padding-top: 8px; border-top: 1px solid var(--line-1); }
    .driver-hero-pos, .driver-hero-wdc { font-size: 40px; }
    .driver-career-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .stat-accent { border-color: var(--accent); }
  .stat-accent .stat-lbl, .stat-accent .stat-val { color: var(--accent); }
</style>
