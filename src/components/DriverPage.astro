---
// Pure-Astro driver detail page. Server-rendered HTML, no React island, no
// client JS shipped — every byte is SEO content. Reuses the existing
// design-system classes (`panel`, `grid`, `stat`, `t-eyebrow`, `t-display`,
// `t-mono`, `section-head`, `page-title`) from css/app.css.

interface Props {
  driver: {
    driverRef: string;
    driverId: string;
    code: string | null;
    number: string | null;
    forename: string;
    surname: string;
    dob: string | null;
    nationality: string | null;
    url: string | null;
    career: {
      seasons: number;
      firstYear: number | null;
      lastYear: number | null;
      races: number;
      wins: number;
      podiums: number;
      poles: number;
      fastestLaps: number;
      championships: number;
    };
    perSeason: Array<{
      year: number;
      constructorRef: string | null;
      constructorName: string | null;
      position: number | null;
      points: number | null;
      wins: number;
      races: number;
      bestFinish: number | null;
    }>;
    perRace: Array<{
      year: number;
      round: number | null;
      raceName: string | null;
      date: string | null;
      constructorRef: string | null;
      constructorName: string | null;
      grid: number | null;
      position: number | null;
      positionText: string | null;
      points: number;
      fastestLapRank: number | null;
      status: string | null;
    }>;
  };
}

import { existsSync } from 'node:fs';
import { resolve } from 'node:path';

const { driver } = Astro.props;
const fullName = `${driver.forename} ${driver.surname}`;
const yearsLabel = driver.career.firstYear === driver.career.lastYear
  ? `${driver.career.firstYear}`
  : `${driver.career.firstYear}–${driver.career.lastYear}`;
const fmtNum = (n: number | null | undefined) => (n == null ? '—' : String(n));
const ord = (n: number | null) => (n == null ? '—' : `P${n}`);

// Headshot lookup — only ~32 modern drivers have a curated WebP in
// public/images/drivers/. For everyone else (most of the 862 drivers in
// the archive), fall back to a CSS-rendered silhouette placeholder.
const headshotPath = `images/drivers/${driver.driverRef}.webp`;
const hasHeadshot = existsSync(resolve(process.cwd(), 'public', headshotPath));

// /races/<y>/<r>/ pages exist for Ergast (1950-2024) + completed bundle rounds
// (2025 full, 2026 partial). build-archive.mjs emits those and adds them to
// _races-index.json. Future 2026+ rounds route via /race.html → /calendar/.
const ARCHIVE_MAX_YEAR = 2025;
function raceUrl(year: number | null, round: number | null): string | null {
  if (year == null || round == null) return null;
  if (year <= ARCHIVE_MAX_YEAR) return `/races/${year}/${round}/`;
  return `/race.html?round=${round}&year=${year}`;
}

// Show races newest-first
const racesDesc = [...driver.perRace].sort((a, b) =>
  (b.year - a.year) || ((b.round ?? 0) - (a.round ?? 0))
);
---

<div class="page">
  <a class="btn btn-ghost btn-sm" style="margin-bottom: 12px" href="/standings-drivers/">← Standings</a>

  <div class="panel driver-hero">
    <div class={`driver-hero-grid ${hasHeadshot ? 'has-headshot' : ''}`}>
      {hasHeadshot ? (
        <img class="driver-hero-photo" src={`/${headshotPath}`} alt={fullName} loading="lazy" width="180" height="220" />
      ) : (
        <div class="driver-hero-photo driver-hero-silhouette" aria-hidden="true">
          <svg viewBox="0 0 100 120" xmlns="http://www.w3.org/2000/svg">
            <circle cx="50" cy="35" r="20" fill="currentColor" opacity="0.25"/>
            <path d="M 18 120 Q 18 70 50 70 Q 82 70 82 120 Z" fill="currentColor" opacity="0.25"/>
          </svg>
        </div>
      )}
      <div class="driver-hero-meta">
        <div class="t-eyebrow driver-hero-team">
          {driver.nationality || '—'}
        </div>
        <h1 class="page-title driver-hero-name">{fullName}</h1>
        <div class="driver-hero-stats">
          {driver.code && <span class="t-mono">{driver.code}</span>}
          {driver.code && <span class="sep">·</span>}
          {driver.number && driver.number !== '\\N' && <span class="t-mono">#{driver.number}</span>}
          {driver.number && driver.number !== '\\N' && <span class="sep">·</span>}
          <span class="t-mono">{yearsLabel}</span>
          {driver.dob && <span class="sep">·</span>}
          {driver.dob && <span class="t-mono">b. {driver.dob}</span>}
        </div>
      </div>
      <div class="driver-hero-champ">
        <div class="t-eyebrow">Championships</div>
        <div class={`driver-hero-wdc ${driver.career.championships > 0 ? 'is-champ' : ''}`}>
          {driver.career.championships}
        </div>
      </div>
    </div>
  </div>

  <div class="section-head"><h2>Career Stats</h2><div class="section-rule"></div></div>
  <div class="grid driver-career-grid">
    <div class="stat"><div class="stat-lbl">Seasons</div><div class="stat-val">{fmtNum(driver.career.seasons)}</div></div>
    <div class="stat"><div class="stat-lbl">Races</div><div class="stat-val">{fmtNum(driver.career.races)}</div></div>
    <div class="stat"><div class="stat-lbl">Wins</div><div class="stat-val">{fmtNum(driver.career.wins)}</div></div>
    <div class="stat"><div class="stat-lbl">Podiums</div><div class="stat-val">{fmtNum(driver.career.podiums)}</div></div>
    <div class="stat"><div class="stat-lbl">Poles</div><div class="stat-val">{fmtNum(driver.career.poles)}</div></div>
    <div class="stat"><div class="stat-lbl">Fastest Laps</div><div class="stat-val">{fmtNum(driver.career.fastestLaps)}</div></div>
    <div class={`stat ${driver.career.championships > 0 ? 'stat-accent' : ''}`}>
      <div class="stat-lbl">WDC</div>
      <div class="stat-val">{fmtNum(driver.career.championships)}</div>
    </div>
  </div>

  {driver.perSeason.length > 0 && (
    <>
      <div class="section-head"><h2>Season by Season</h2><div class="section-rule"></div></div>
      <div class="panel" style="padding: 0; overflow-x: auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>Year</th>
              <th>Team</th>
              <th class="right">Pos</th>
              <th class="right">Points</th>
              <th class="right">Wins</th>
              <th class="right">Races</th>
              <th class="right">Best</th>
            </tr>
          </thead>
          <tbody>
            {driver.perSeason.map(s => (
              <tr>
                <td class="t-mono">{s.year}</td>
                <td>{s.constructorName || '—'}</td>
                <td class={`right ${s.position === 1 ? 'is-champ-cell' : ''}`}>{ord(s.position)}</td>
                <td class="right t-mono">{s.points != null ? s.points : '—'}</td>
                <td class="right t-mono">{s.wins}</td>
                <td class="right t-mono">{s.races}</td>
                <td class="right t-mono">{ord(s.bestFinish)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </>
  )}

  {racesDesc.length > 0 && (
    <>
      <div class="section-head"><h2>Race by Race</h2><div class="section-rule"></div></div>
      <div class="panel" style="padding: 0; overflow-x: auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>Year</th>
              <th>Race</th>
              <th>Team</th>
              <th class="right">Grid</th>
              <th class="right">Finish</th>
              <th class="right">Pts</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            {racesDesc.map(r => {
              const raceHref = raceUrl(r.year, r.round);
              return (
                <tr>
                  <td class="t-mono">{raceHref ? <a href={raceHref}>{r.year}</a> : r.year}</td>
                  <td>{raceHref ? <a href={raceHref}>{r.raceName || '—'}</a> : (r.raceName || '—')}</td>
                  <td>{r.constructorName || '—'}</td>
                  <td class="right t-mono">{fmtNum(r.grid)}</td>
                  <td class={`right t-mono ${r.position === 1 ? 'is-win-cell' : ''}`}>{r.positionText || ord(r.position)}</td>
                  <td class="right t-mono">{r.points || 0}</td>
                  <td>{r.status || '—'}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </>
  )}
</div>

<style>
  .driver-hero { padding: 20px; margin-bottom: 20px; border-left: 3px solid var(--accent); }
  .driver-hero-grid {
    display: grid;
    grid-template-columns: 180px 1fr auto;
    gap: 20px;
    align-items: center;
  }
  .driver-hero-photo {
    width: 180px;
    height: 220px;
    object-fit: cover;
    border-radius: 4px;
    background: var(--bg-2);
    color: var(--fg-3);
  }
  .driver-hero-silhouette {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .driver-hero-silhouette svg { width: 70%; height: 70%; }
  .driver-hero-team { color: var(--fg-3); margin-bottom: 6px; }
  .driver-hero-name { margin: 0 0 8px 0; font-size: 56px; line-height: 1.05; }
  .driver-hero-stats { display: flex; gap: 10px; align-items: center; color: var(--fg-3); flex-wrap: wrap; }
  .driver-hero-stats .sep { color: var(--fg-4); }
  .driver-hero-champ { text-align: right; }
  .driver-hero-wdc {
    font-family: var(--f-display);
    font-weight: 800;
    font-size: 56px;
    line-height: 1;
    color: var(--fg-1);
  }
  .driver-hero-wdc.is-champ { color: var(--accent); }

  .driver-career-grid { grid-template-columns: repeat(7, 1fr); }
  @media (max-width: 720px) {
    .driver-hero-name { font-size: 32px; }
    .driver-hero-grid { grid-template-columns: 120px 1fr; }
    .driver-hero-photo { width: 120px; height: 150px; }
    .driver-hero-champ { grid-column: 1 / -1; text-align: left; padding-top: 8px; border-top: 1px solid var(--line-1); }
    .driver-career-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .stat-accent { border-color: var(--accent); }
  .stat-accent .stat-lbl, .stat-accent .stat-val { color: var(--accent); }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  .data-table th, .data-table td {
    padding: 8px 12px;
    border-bottom: 1px solid var(--line-1);
    text-align: left;
  }
  .data-table th {
    font-family: var(--f-display);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-3);
    background: var(--bg-2);
    position: sticky;
    top: 0;
  }
  .data-table tr:last-child td { border-bottom: 0; }
  .data-table .right { text-align: right; }
  .data-table .is-champ-cell, .data-table .is-win-cell { color: var(--accent); font-weight: 700; }
</style>
