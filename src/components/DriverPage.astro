  }
  a.rr-tile:hover { border-color: var(--line-2); }
  a.rr-tile:hover.is-podium { border-top-color: var(--team-color); }
  .rr-tile.is-podium { border-top-color: var(--team-color); }
  .rr-tile.is-win { border-top-width: 3px; }

  /* Podium celebration: a light sheen sweeps across on a loop (gold for a win). */
  .rr-sheen {
    position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background: linear-gradient(115deg, transparent 38%, rgba(255,255,255,0.4) 50%, transparent 62%);
    background-size: 250% 100%; background-position: 175% 0;
  }
  .rr-tile.is-win .rr-sheen {
    background-image: linear-gradient(115deg, transparent 36%, rgba(255,209,90,0.55) 50%, transparent 64%);
  }
  @media (prefers-reduced-motion: no-preference) {
    .rr-tile.is-podium .rr-sheen { animation: rrSheen 3.4s ease-in-out infinite; }
    .rr-tile.is-win .rr-pos { animation: rrWinBounce 3.4s ease-in-out infinite; }
    a.rr-tile.is-podium:hover { transform: translateY(-1px); }
  }
  @keyframes rrSheen {
    0% { background-position: 175% 0; }
    55%, 100% { background-position: -175% 0; }
  }
  @keyframes rrWinBounce {
    0%, 62%, 100% { transform: translateY(0); }
    72% { transform: translateY(-3px); }
