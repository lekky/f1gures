  html.light .profile-facts .stat { box-shadow: 0 1px 2px rgba(20,22,30,.08), 0 8px 20px rgba(20,22,30,.10); }
  .profile-fact-sm { font-size: 20px; }

  /* ── 2026 Season strip + detail ─────────────────────────────── */
  .season-strip { grid-template-columns: repeat(6, 1fr); }
  .season-detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; align-items: start; }
  .season-pill { margin-left: 4px; }

  /* Race-by-race ribbon: wrapping tiles that grow sideways, not down. */
  .rr-ribbon { display: grid; grid-template-columns: repeat(auto-fill, minmax(92px, 1fr)); gap: 8px; }
  .rr-tile {
    position: relative; overflow: hidden; min-height: 84px;
    background: var(--bg-2); background-size: cover; background-position: center;
    border: 1px solid var(--line-1); border-top: 2px solid var(--line-2);
