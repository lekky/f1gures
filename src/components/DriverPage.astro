---
// Pure-Astro driver detail page. Server-rendered HTML, no React island, no
// client JS shipped - every byte is SEO content. Reuses the existing
// design-system classes (`panel`, `grid`, `stat`, `t-eyebrow`, `t-display`,
// `t-mono`, `section-head`, `page-title`) from css/app.css.

interface Props {
  driver: {
    driverRef: string;
    driverId: string;
    code: string | null;
    number: string | null;
    forename: string;
    surname: string;
    dob: string | null;
    nationality: string | null;
    url: string | null;
    career: {
      seasons: number;
      firstYear: number | null;
      lastYear: number | null;
      races: number;
      wins: number;
      podiums: number;
      poles: number;
      fastestLaps: number;
      championships: number;
    };
    perSeason: Array<{
      year: number;
      constructorRef: string | null;
      constructorName: string | null;
      position: number | null;
      points: number | null;
      wins: number;
      races: number;
      bestFinish: number | null;
    }>;
    perRace: Array<{
      year: number;
      round: number | null;
      raceName: string | null;
      date: string | null;
      country: string | null;
      flag: string | null;
      constructorRef: string | null;
      constructorName: string | null;
      grid: number | null;
      position: number | null;
      positionText: string | null;
      points: number;
      fastestLapRank: number | null;
      status: string | null;
    }>;
    teammates?: {
      quali: { wins: number; losses: number };
      race: { wins: number; losses: number };
      byMate: Array<{
        driverRef: string;
        name: string;
        surname: string;
        firstYear: number;
        lastYear: number;
        weekends: number;
        quali: { wins: number; losses: number };
        race: { wins: number; losses: number };
      }>;
    } | null;
  };
}

import { existsSync, readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import { buildDriverSummary } from '../lib/buildDriverSummary.js';
import { getDriverBio } from '../data/driverBios.js';
import { NATIONALITY } from '../lib/nationality.js';
import Flag from './Flag.astro';
import StatusIcon from './StatusIcon.astro';
import TriviaBoard from './islands/screens/TriviaBoard.jsx';
import CompareCta from './islands/CompareCta.jsx';
import { ARCHIVE_MAX_YEAR } from '../data/archiveMeta.js';
import { teamLogoPath } from '../lib/teamLogo.js';

const { driver } = Astro.props;
const fullName = `${driver.forename} ${driver.surname}`;
const customBio = getDriverBio(driver.driverRef);
const driverSummary = customBio ? null : buildDriverSummary(driver, new Date().getFullYear());
const yearsLabel = driver.career.firstYear === driver.career.lastYear
  ? `${driver.career.firstYear}`
  : `${driver.career.firstYear}–${driver.career.lastYear}`;
const fmtNum = (n: number | null | undefined) => (n == null ? '-' : String(n));
const ord = (n: number | null) => (n == null ? '-' : `P${n}`);
const hasNumber = !!(driver.number && driver.number !== '\\N');
const numberLabel = hasNumber ? driver.number : null;

// Headshot lookup - only ~32 modern drivers have a curated WebP in
// public/images/drivers/. For everyone else (most of the 862 drivers in
// the archive), fall back to a CSS-rendered silhouette placeholder.
const headshotPath = `images/drivers/${driver.driverRef}.webp`;
const hasHeadshot = existsSync(resolve(process.cwd(), 'public', headshotPath));

// Latest season - perSeason arrives newest-first from build-archive.mjs.
const latestSeason = driver.perSeason.length > 0 ? driver.perSeason[0] : null;

// Team colour: look up from the season JSON for the driver's latest year.
// Season JSONs exist for all years (generated from CSV for 1950–2019, hand-
// curated for 2020+). If the file is missing or the team isn't found, fall
// back to the site accent colour.
let teamColor = 'var(--accent)';
let teamRef = latestSeason?.constructorRef ?? null;
let teamName = latestSeason?.constructorName ?? null;

if (latestSeason?.year && teamRef) {
  try {
    const seasonPath = resolve(process.cwd(), 'public', 'data', `${latestSeason.year}.json`);
    const seasonData = JSON.parse(readFileSync(seasonPath, 'utf8'));
    const team = seasonData.teams?.find(
      (t: { id?: string; jolpicaId?: string; color?: string }) =>
        t.id === teamRef || t.jolpicaId === teamRef
    );
    if (team?.color) teamColor = team.color;
  } catch {
    // leave teamColor as accent fallback
  }
}

// Flag wash (design handoff "Option A" layout, real flag): the driver's actual
// national flag, pinned to the right of the info panel and dissolving toward the
// name via a left-fading mask, at low opacity. Resolved from the 2-letter
// country code (src/lib/nationality.js) → the lipis SVG set (public/images/
// flags/), which covers essentially every F1 nationality. Those SVGs ship
// `preserveAspectRatio="xMidYMid meet"`, so a plain `background-size: 100% 100%`
// would letterbox the flag into a centred strip — inline it as a data-URI with
// `preserveAspectRatio="none"` baked in so it fills the wash box.
const countryCode = driver.nationality ? (NATIONALITY[driver.nationality]?.country ?? null) : null;
const flagWashSrc = countryCode
  ? (() => {
      const abs = resolve(process.cwd(), 'public', `images/flags/${countryCode.toLowerCase()}.svg`);
      if (!existsSync(abs)) return null;
      let svg = readFileSync(abs, 'utf8');
      svg = /preserveAspectRatio=/.test(svg)
        ? svg.replace(/preserveAspectRatio="[^"]*"/, 'preserveAspectRatio="none"')
        : svg.replace(/<svg\b/, '<svg preserveAspectRatio="none"');
      return `data:image/svg+xml,${encodeURIComponent(svg)}`;
    })()
  : null;

// Show current-season treatment for drivers who raced this season or last
// (early-season builds run before everyone has a current-year row); show the
// career-focused treatment for retired drivers.
const isActive = (driver.career.lastYear ?? 0) >= new Date().getFullYear() - 1;
const showSeasonStat = isActive && latestSeason != null;
const seasonYear = latestSeason?.year ?? null;

// Current-season race rows (newest-first) drive the 2026 SEASON strip, the
// RACE BY RACE table and the FORM chart. fastestLapRank === 1 marks the FL,
// grid === 1 marks pole - both populated by build-archive.mjs.
const seasonRacesDesc = seasonYear
  ? [...driver.perRace]
      .filter(r => r.year === seasonYear)
      .sort((a, b) => (b.round ?? 0) - (a.round ?? 0))
  : [];
const seasonRacesAsc = [...seasonRacesDesc].sort((a, b) => (a.round ?? 0) - (b.round ?? 0));
const showSeasonDetail = showSeasonStat && seasonRacesDesc.length > 0;

const seasonStats = {
  points: latestSeason?.points ?? seasonRacesDesc.reduce((s, r) => s + (r.points || 0), 0),
  wins: seasonRacesDesc.filter(r => r.position === 1).length,
  podiums: seasonRacesDesc.filter(r => r.position != null && r.position <= 3).length,
  poles: seasonRacesDesc.filter(r => r.grid === 1).length,
  fastestLaps: seasonRacesDesc.filter(r => r.fastestLapRank === 1).length,
};

// Finishing-position line chart (FORM). Y axis is inverted - P1 at the top,
// worst finish at the bottom - so a rising line means better results. DNFs
// (no classified position) sit on the bottom baseline as red markers, off the
// line. Pure inline SVG, no client JS.
const FORM_W = 460;
const FORM_H = 210;
const FORM_PAD = { t: 14, r: 16, b: 26, l: 40 };
let formPath = '';
let formPoints: Array<{ x: number; y: number; round: number | null; pos: number; podium: boolean }> = [];
let formDnf: Array<{ x: number; y: number; round: number | null; label: string }> = [];
let formRoundLabels: Array<{ x: number; round: number | null }> = [];
let formTicks: Array<{ y: number; label: string }> = [];
let podiumBand: { y: number; h: number } | null = null;
if (seasonRacesAsc.length > 0) {
  const innerW = FORM_W - FORM_PAD.l - FORM_PAD.r;
  const innerH = FORM_H - FORM_PAD.t - FORM_PAD.b;
  const n = seasonRacesAsc.length;
  const positions = seasonRacesAsc.map(r => r.position).filter((p): p is number => p != null);
  const maxPos = Math.max(3, ...positions);
  // When there are DNFs, reserve an extra row at the bottom ("NC") so a
  // non-finish sits below the worst classified result, not on top of it.
  const hasDnf = seasonRacesAsc.some(r => r.position == null);
  const axisMax = maxPos + (hasDnf ? 1 : 0);
  const xFor = (i: number) => FORM_PAD.l + (n === 1 ? innerW / 2 : (i / (n - 1)) * innerW);
  const yFor = (pos: number) => (axisMax <= 1 ? FORM_PAD.t : FORM_PAD.t + ((pos - 1) / (axisMax - 1)) * innerH);
  seasonRacesAsc.forEach((r, i) => {
    const x = xFor(i);
    formRoundLabels.push({ x, round: r.round });
    if (r.position != null) {
      formPoints.push({ x, y: yFor(r.position), round: r.round, pos: r.position, podium: r.position <= 3 });
    } else {
      formDnf.push({ x, y: yFor(axisMax), round: r.round, label: r.positionText || 'DNF' });
    }
  });
  formPath = formPoints.map((p, i) => `${i === 0 ? 'M' : 'L'}${p.x.toFixed(1)} ${p.y.toFixed(1)}`).join(' ');
  // Faint podium band across the top (P1-P3).
  podiumBand = { y: yFor(1), h: yFor(Math.min(3, maxPos)) - yFor(1) };
  // Y-axis ticks: every position when the field is shallow, else 4 spread out,
  // plus a bottom "NC" row when any race was a non-finish.
  const tickPositions = maxPos <= 5
    ? Array.from({ length: maxPos }, (_, i) => i + 1)
    : [...new Set([1, Math.round(maxPos / 3), Math.round((2 * maxPos) / 3), maxPos])];
  formTicks = tickPositions.map(pos => ({ y: yFor(pos), label: `P${pos}` }));
  if (hasDnf) formTicks.push({ y: yFor(axisMax), label: 'NC' });
}

// /races/<y>/<r>/ pages exist for Ergast (1950-2024) + 2025 full bundle +
// 2026 completed AND upcoming rounds (via holding pages). build-archive.mjs
// emits all of these and adds them to _races-index.json. Future years without
// bundles still fall through to /race.html → /calendar/. ARCHIVE_MAX_YEAR is
// generated from the races index by build-archive.mjs (src/data/archiveMeta.js).
function raceUrl(year: number | null, round: number | null): string | null {
  if (year == null || round == null) return null;
  if (year <= ARCHIVE_MAX_YEAR) return `/races/${year}/${round}/`;
  return `/race.html?round=${round}&year=${year}`;
}

// Show races newest-first
const racesDesc = [...driver.perRace].sort((a, b) =>
  (b.year - a.year) || ((b.round ?? 0) - (a.round ?? 0))
);

// Max points for the standings-style proportional bars behind point cells.
const seasonMaxPoints = Math.max(1, ...driver.perSeason.map(s => s.points ?? 0));
const raceMaxPoints = Math.max(1, ...driver.perRace.map(r => r.points || 0));
const posClass = (n: number | null) => (n != null && n >= 1 && n <= 3 ? `pos pos-${n}` : 'pos');

// ── Mobile "bar + expand" rows ───────────────────────────────────
// Design handoff: "Mobile Driver Profile.html" (claude.ai/design, F1 Web App).
// On <=720px the two history tables swap for .belist rows — position badge,
// team-colour points bar with the value inside, tap-to-expand stat panel.
// Both DOM trees are always rendered; CSS toggles them (same architecture as
// the standings islands' .std-barlist / .std-fulltable pair).
type PerRace = (typeof driver.perRace)[number];
const isNumericFinish = (r: PerRace) =>
  r.position != null && (r.positionText == null || /^\d+$/.test(r.positionText));
// Ergast positionText codes for non-classified results → badge label.
const DNF_BADGE: Record<string, string> = { R: 'DNF', D: 'DSQ', W: 'WD', F: 'DNQ', E: 'EX', N: 'NC' };
const dnfBadge = (r: PerRace) => DNF_BADGE[r.positionText ?? ''] ?? 'DNF';
// Race rows grouped by season, newest-first (racesDesc is already sorted).
const racesByYear: Array<{ year: number; races: PerRace[] }> = [];
for (const r of racesDesc) {
  const g = racesByYear[racesByYear.length - 1];
  if (g && g.year === r.year) g.races.push(r);
  else racesByYear.push({ year: r.year, races: [r] });
}
const currentYear = new Date().getFullYear();
const barPct = (pts: number, max: number) => Math.max(4, Math.round((pts / max) * 100));
// Frontmatter helper: an inline `<=` in a JSX expression trips the Astro
// compiler (see CLAUDE.md), so the podium check lives here.
const bePodium = (n: number | null) => n != null && n >= 1 && n <= 3;
const gainLoss = (r: PerRace) =>
  isNumericFinish(r) && r.grid != null && r.grid > 0 && r.position != null ? r.grid - r.position : null;

// ── Career outcome waffle ────────────────────────────────────────
// One tile per career race, bucketed by outcome and sorted best→worst so the
// mosaic reads as a block of wins tapering to the cold corner of retirements.
// Pure static markup - no client JS. Buckets mirror StatusIcon's status kinds.
type WaffleKind = 'win' | 'podium' | 'points' | 'finished' | 'mech' | 'crash' | 'dsq';
const WAFFLE_ORDER: WaffleKind[] = ['win', 'podium', 'points', 'finished', 'mech', 'crash', 'dsq'];
const WAFFLE_LABEL: Record<WaffleKind, string> = {
  win: 'Win', podium: 'Podium', points: 'Points', finished: 'Finished',
  mech: 'DNF · mech', crash: 'DNF · crash', dsq: 'DSQ',
};
function waffleKind(r: Props['driver']['perRace'][number]): WaffleKind {
  const t = (r.status || '').toLowerCase();
  if (t.includes('disqualif')) return 'dsq';
  // Classified finish: a real numeric position (Ergast marks retirements with a
  // letter code in positionText - R, D, E, W, F, N).
  const classified = r.position != null && (r.positionText == null || /^\d+$/.test(r.positionText));
  if (classified) {
    if (r.position === 1) return 'win';
    if (r.position! <= 3) return 'podium';
    if ((r.points || 0) > 0) return 'points';
    return 'finished';
  }
  if (/(accident|collision|spun|crash|punctur|debris|contact|damage)/.test(t)) return 'crash';
  return 'mech';
}
const waffleTiles = driver.perRace.map(r => {
  const kind = waffleKind(r);
  const finish = r.position != null ? `P${r.position}` : (r.positionText || 'DNF');
  const title = `${(r.raceName || 'Race').replace(/ grand prix$/i, ' GP')} ${r.year} · ${finish}${r.status ? ` · ${r.status}` : ''}`;
  return { kind, title, href: raceUrl(r.year, r.round) };
});
const waffleRank: Record<WaffleKind, number> = Object.fromEntries(
  WAFFLE_ORDER.map((k, i) => [k, i])
) as Record<WaffleKind, number>;
const waffleSorted = [...waffleTiles].sort((a, b) => waffleRank[a.kind] - waffleRank[b.kind]);
const waffleCounts = WAFFLE_ORDER
  .map(k => ({ kind: k, label: WAFFLE_LABEL[k], count: waffleTiles.filter(t => t.kind === k).length }))
  .filter(c => c.count > 0);
const waffleTotal = waffleSorted.length;
const showWaffle = waffleTotal >= 3;

// ── Outcome mix by season (100% stacked) ─────────────────────────
// The same outcome buckets as the mosaic, but rolled per season and stacked to
// 100% — a timeline of how the year's races broke down. Hot colours (win →
// points) grow as the car/driver improve; the cold blues mark DNF-heavy years.
const outcomeByYear = new Map<number, Record<WaffleKind, number>>();
for (const r of driver.perRace) {
  const k = waffleKind(r);
  if (!outcomeByYear.has(r.year)) {
    outcomeByYear.set(r.year, { win: 0, podium: 0, points: 0, finished: 0, mech: 0, crash: 0, dsq: 0 });
  }
  outcomeByYear.get(r.year)![k] += 1;
}
// Primary constructor per season, for the row label between year and bar.
// A driver can switch teams mid-year (Schumacher 1991: Jordan → Benetton);
// keep the team they raced most that season.
const teamByYear = new Map<number, { ref: string | null; name: string | null; races: number }>();
for (const s of driver.perSeason) {
  const prev = teamByYear.get(s.year);
  if (!prev || (s.races ?? 0) > prev.races) {
    teamByYear.set(s.year, { ref: s.constructorRef, name: s.constructorName, races: s.races ?? 0 });
  }
}
const outcomeSeasons = [...outcomeByYear.entries()]
  .map(([year, counts]) => {
    const total = WAFFLE_ORDER.reduce((s, k) => s + counts[k], 0);
    return {
      year,
      total,
      team: teamByYear.get(year) ?? null,
      segments: WAFFLE_ORDER
        .map(k => ({ kind: k, count: counts[k], pct: total ? (counts[k] / total) * 100 : 0 }))
        .filter(seg => seg.count > 0),
    };
  })
  .filter(s => s.total > 0)
  // Newest season first, matching the Season by Season table below.
  .sort((a, b) => b.year - a.year);
const showOutcomeMix = outcomeSeasons.length >= 2;
// Pair the Career Mosaic and Season Outcomes side by side for shorter careers
// (both panels stay close in height); longer careers keep them full-width
// stacked so the tall season timeline doesn't leave dead space beside the
// mosaic.
const mosaicOutcomesSideBySide = showWaffle && showOutcomeMix && outcomeSeasons.length <= 10;

// Team-logo lookup for the race-by-race team cells uses the shared
// teamLogoPath (resolves any logo present in public/images/teams/).

// ── Teammate duels (Career Duel Meter) ───────────────────────────
// Roll every teammate battle into two verdict bars (qualifying + race), then
// break it down per rival. Data comes from build-archive's teammate index; the
// section only shows when there's a decided sample. Cap the per-rival list so a
// long career (Schumacher: 11 teammates) doesn't run away vertically.
const DUEL_MATE_CAP = 8;
const tm = driver.teammates ?? null;
const duelPct = (w: number, l: number) => {
  const n = w + l;
  return n > 0 ? Math.round((w / n) * 100) : 0;
};
const qualiTotal = tm ? tm.quali.wins + tm.quali.losses : 0;
const raceTotal = tm ? tm.race.wins + tm.race.losses : 0;
const showDuels = !!tm && (qualiTotal + raceTotal) >= 6;
const duelMates = tm ? tm.byMate.slice(0, DUEL_MATE_CAP) : [];
const duelMatesRest = tm ? tm.byMate.length - duelMates.length : 0;
const duelSurname = driver.surname;
---

<div class="page">
  <a class="btn btn-ghost btn-sm" style="margin-bottom: 12px" href="/standings-drivers/">← Standings</a>

  <div class="panel driver-hero" style={`--team-color: ${teamColor}; border-left-color: ${teamColor}`}>
    <div class="driver-hero-grid">
      <div class="driver-hero-portrait">
        <span class="t-eyebrow driver-hero-portrait-lbl">Driver Portrait</span>
        {numberLabel && <span class="driver-hero-watermark" aria-hidden="true">{numberLabel}</span>}
        {hasHeadshot ? (
          <img class="driver-hero-photo" src={`/${headshotPath}`} alt={fullName} loading="eager" width="180" height="220" />
        ) : (
          <div class="driver-hero-photo silhouette" aria-hidden="true">
            <svg viewBox="0 0 100 120" xmlns="http://www.w3.org/2000/svg">
              <path d="M50 12 C28 12 18 28 18 46 L18 60 L14 70 L14 82 L20 88 L20 120 L80 120 L80 88 L86 82 L86 70 L82 60 L82 46 C82 28 72 12 50 12 Z" fill={teamColor} />
            </svg>
          </div>
        )}
      </div>
      <div class="driver-hero-body">
        {flagWashSrc && (
          <div class="driver-hero-flagwash" style={`background-image: url(${flagWashSrc})`} aria-hidden="true"></div>
        )}
        {showSeasonStat && (
          <div class="driver-hero-corner" aria-hidden="true">
            <span class="driver-hero-corner-year">{seasonYear}</span>
            {latestSeason!.position != null && (
              <span class="driver-hero-corner-pos">P{latestSeason!.position}</span>
            )}
          </div>
        )}
        <div class="driver-hero-overline">
          <span class="driver-hero-nat">{driver.nationality || '-'}</span>
          {teamName && teamRef && (
            <a class="driver-hero-team" href={`/teams/${teamRef}/`}>{teamName}</a>
          )}
        </div>
        <h1 class="page-title driver-hero-name">{fullName}</h1>
        <div class="driver-hero-sub">
          {driver.code && <span class="t-mono">{driver.code}</span>}
          {driver.code && hasNumber && <span class="sep">·</span>}
          {hasNumber && <span class="t-mono">#{numberLabel}</span>}
          {(driver.code || hasNumber) && driver.nationality && <span class="sep">·</span>}
          {driver.nationality && <span class="t-mono">{driver.nationality}</span>}
        </div>
        <div class="driver-hero-headline">
          {showSeasonStat ? (
            <>
              <span class="driver-hero-big">{seasonStats.points}</span>
              <span class="driver-hero-big-lbl">Championship Points</span>
            </>
          ) : (
            <>
              <span class={`driver-hero-big ${driver.career.championships > 0 ? 'is-champ' : ''}`}>{driver.career.seasons}</span>
              <span class="driver-hero-big-lbl">
                {driver.career.championships > 0 ? `Seasons · ${driver.career.championships} WDC` : 'Seasons in F1'}
              </span>
            </>
          )}
        </div>
      </div>
    </div>
  </div>

  <CompareCta client:idle kind="driver" refId={driver.driverRef} name={fullName} teamColor={teamColor} />

  {/* Trigger the flag-wash entrance wipe only when the page is actually
      visible. The wash itself is CSS-visible without this; the script just
      adds the run-once animation so a frozen/hidden preview never traps it at
      its invisible first frame. Fires now if visible, else on first reveal. */}
  <script is:inline>
    (function () {
      function wipe() {
        var els = document.querySelectorAll('.driver-hero-flagwash, .team-hero-flagwash');
        for (var i = 0; i < els.length; i++) els[i].classList.add('is-wiping');
      }
      if (document.visibilityState === 'visible') { wipe(); }
      else {
        document.addEventListener('visibilitychange', function onVis() {
          if (document.visibilityState === 'visible') {
            wipe();
            document.removeEventListener('visibilitychange', onVis);
          }
        });
      }
    })();
  </script>

  <TriviaBoard client:visible />

  <div class="section-head section-head-band">
    <span class="section-head-mark" aria-hidden="true"></span>
    <h2>Profile</h2>
    <div class="section-rule"></div>
    <span class="t-eyebrow section-head-aside">{fullName}</span>
  </div>
  <div class="profile-grid">
    <div class="panel profile-bio" style={`border-left: 3px solid ${teamColor};`}>
      {customBio ? (
        customBio.map(p => <p>{p}</p>)
      ) : driverSummary ? (
        <p>{driverSummary}</p>
      ) : (
        <p>A full profile for {fullName} is coming soon.</p>
      )}
    </div>
    <div class="grid profile-facts">
      <div class="stat"><div class="stat-lbl">Number</div><div class="stat-val">{hasNumber ? `#${numberLabel}` : '-'}</div></div>
      <div class="stat"><div class="stat-lbl">Nationality</div><div class="stat-val profile-fact-sm">{driver.nationality || '-'}</div></div>
      <div class="stat"><div class="stat-lbl">Team</div><div class="stat-val profile-fact-sm">{teamName || '-'}</div></div>
      <div class="stat">
        <div class="stat-lbl">{showSeasonStat ? `${seasonYear} Pos` : 'Career'}</div>
        <div class="stat-val">{showSeasonStat ? (latestSeason!.position != null ? `P${latestSeason!.position}` : '-') : yearsLabel}</div>
      </div>
    </div>
  </div>

  {showSeasonDetail && (
    <>
      <div class="section-head section-head-band"><span class="section-head-mark" aria-hidden="true"></span><h2>{seasonYear} Season</h2><div class="section-rule"></div></div>
      <div class="grid season-strip">
        <div class="stat stat-accent">
          <div class="stat-lbl">Championship</div>
          <div class="stat-val">{latestSeason!.position != null ? `P${latestSeason!.position}` : '-'}</div>
        </div>
