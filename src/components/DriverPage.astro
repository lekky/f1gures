                      {numeric
                        ? <svg class="fl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true"><path d="M5 3v18"/><path d="M5 4h13l-2.5 4L18 12H5" fill="currentColor" stroke="none" opacity=".25"/><path d="M5 4h13l-2.5 4L18 12H5"/></svg>
                        : <span class="rd" aria-hidden="true"></span>}
                      {r.status || (numeric ? 'Finished' : 'Retired')}
                    </span>
                  );
                  return (
                  <div class={`berow ${open ? 'open' : ''}`} style={`--tc:${teamColor}`}>
                    <button class="behead" type="button" aria-expanded={open ? 'true' : 'false'}>
                      <span class={`be-pos ${numeric ? (podium ? `p${r.position}` : '') : 'dnf'}`}>
                        {numeric ? r.position : dnfBadge(r)}
                        <small>{numeric ? 'FIN' : 'OUT'}</small>
                      </span>
                      <span class="be-main">
                        <span class="be-who">
                          <span class="tcbar" aria-hidden="true"></span>
                          {(r.country || r.flag) && <span class="be-flag"><Flag cc={r.country} flag={r.flag} name={r.raceName} /></span>}
                          <span class="rname">{(r.raceName || '–').replace(' Grand Prix', ' GP')}</span>
                          <span class="sec">{r.constructorName || ''}</span>
                          <span class="chev" aria-hidden="true">▶</span>
                        </span>
                        <span class="be-track">
                          <span class={`be-fill ${zero ? 'zero' : ''}`} style={`width:${zero ? 100 : barPct(pts, raceMaxPoints)}%`}></span>
                          {zero ? statusTag : <span class="be-v">{pts}<small>PTS</small></span>}
                        </span>
                      </span>
                    </button>
                    <div class="be-panel"><div><div class="be-inner">
                      <div class="be-grid">
                        <div class="c"><div class="l">Grid</div><div class="n">{fmtNum(r.grid)}</div></div>
                        <div class="c"><div class="l">Finish</div><div class={`n ${podium ? 'tc' : ''}`}>{numeric ? r.position : dnfBadge(r)}</div></div>
                        <div class="c"><div class="l">Δ Pos</div><div class="n">{delta != null ? `${delta >= 0 ? '+' : ''}${delta}` : '–'}</div></div>
                        <div class="c"><div class="l">Points</div><div class="n tc">{pts}</div></div>
                      </div>
                      <div class="be-meta">
                        <div class="be-tags">
                          {statusTag}
                          {r.fastestLapRank === 1 && <span class="be-tag tc">FL</span>}
                        </div>
                        <span class="be-note">
                          Grid {fmtNum(r.grid)} → {numeric ? `P${r.position}` : dnfBadge(r)}
                          {delta != null && delta !== 0 && <span class={`delta ${delta > 0 ? 'up' : 'down'}`}> {delta > 0 ? '▲' : '▼'} {Math.abs(delta)}</span>}
                        </span>
                      </div>
                      {raceHref && <a class="be-profile" href={raceHref}>Race result →</a>}
                    </div></div></div>
                  </div>
                  );
                })}
              </div>
            </>
          ))}
        </div>
      </div>
    </>
  )}
</div>

{/* Tap-to-expand wiring for the mobile bar rows (.belist, <=720px). Rows
    toggle independently (design handoff behaviour); links inside still
    navigate. First row per list is server-rendered open, so the pattern
    reads without JS. */}
<script is:inline>
  document.addEventListener('click', function (e) {
    if (e.target.closest('a')) return;
    var head = e.target.closest('.behead');
    if (!head) return;
    var row = head.closest('.berow');
    row.classList.toggle('open');
    head.setAttribute('aria-expanded', row.classList.contains('open') ? 'true' : 'false');
  });
</script>

<style>
  /* ── Hero ───────────────────────────────────────────────────── */
  .driver-hero { display: block; padding: 0; margin-bottom: 24px; border-left: 4px solid var(--accent); overflow: hidden; }
  .driver-hero-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    align-items: stretch;
  }
  .driver-hero-portrait {
    position: relative;
    background:
      repeating-linear-gradient(135deg, var(--bg-3) 0 1px, transparent 1px 9px),
      var(--bg-2);
    border-right: 1px solid var(--line-1);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    min-height: 200px;
    overflow: hidden;
  }
  .driver-hero-portrait-lbl { position: absolute; top: 12px; left: 14px; color: var(--fg-4); z-index: 2; }
  .driver-hero-watermark {
    position: absolute;
    right: -8px;
    bottom: -36px;
    font-family: var(--f-display);
    font-weight: 800;
    font-size: 200px;
    line-height: 1;
    color: var(--team-color);
    opacity: 0.14;
    z-index: 1;
    pointer-events: none;
  }
  .driver-hero-photo {
    position: relative;
    z-index: 2;
    width: 180px;
    height: 220px;
    object-fit: cover;
    object-position: top center;
    background: transparent;
  }
  .driver-hero-photo.silhouette {
    display: flex; align-items: flex-end; justify-content: center;
  }
  .driver-hero-photo.silhouette svg { width: 150px; height: 200px; opacity: 0.45; }

  .driver-hero-body { position: relative; padding: 24px 28px; display: flex; flex-direction: column; justify-content: center; min-width: 0; overflow: hidden; }

  /* Flag wash — the driver's national flag stretched across the WHOLE hero,
     tinting everything (portrait texture + panel) via blend. An edge-emphasis
     mask pushes the flag's colour to the left and right edges and dissolves it
     out of the centre, so the name stays readable over a near-clean panel —
     e.g. Italy reads green (left) · clean (centre) · red (right).
     --wash-op is themed so the entrance animation's final opacity follows. */
  /* Reference "Option A": three national-colour bands pinned to the right 58%
     of the info panel, dissolving toward the name via a left-fading mask, at
     low opacity. Sits above the ghost number but below all text (z-index 2). */
  .driver-hero-flagwash {
    --wash-op: 0.3;
    position: absolute;
    inset: 0 0 0 auto;
    width: 58%;
    z-index: 1;
    opacity: var(--wash-op);
    background-repeat: no-repeat;
    background-position: center;
    background-size: 100% 100%;
    /* Light: multiply. Dark: screen so the flag reads over a dark card. */
    mix-blend-mode: screen;
    pointer-events: none;
    -webkit-mask: linear-gradient(90deg, transparent 0%, #000 78%);
            mask: linear-gradient(90deg, transparent 0%, #000 78%);
  }
  html.light .driver-hero-flagwash { --wash-op: 0.24; mix-blend-mode: multiply; }
  .driver-hero-corner,
  .driver-hero-overline,
  .driver-hero-name,
  .driver-hero-sub,
  .driver-hero-headline { position: relative; z-index: 2; }
  /* Entrance: fade + slide in from the right (reference `washIn`), but ONLY as
     a progressive enhancement while the page is visible. The resting state
     above is already visible; a from-invisible `both`-fill animation would get
     stuck at its invisible first frame whenever the timeline is frozen (a
     backgrounded tab / embedded preview reporting the page hidden). So it lives
     in a run-once `.is-wiping` class toggled by the inline script — if that
     never runs, the wash still shows. */
  @media (prefers-reduced-motion: no-preference) {
    .driver-hero-flagwash.is-wiping {
      animation: driverWashIn 1.1s 0.05s both cubic-bezier(0.18, 0.7, 0.16, 1);
    }
  }
  @keyframes driverWashIn {
    from { opacity: 0; transform: translateX(70px); }
    to   { opacity: var(--wash-op); transform: none; }
  }

  .driver-hero-corner { position: absolute; top: 18px; right: 24px; text-align: right; line-height: 1; }
  .driver-hero-corner-year { display: block; font-family: var(--f-mono); font-size: 11px; letter-spacing: 0.18em; color: var(--fg-4); }
  .driver-hero-corner-pos { display: block; font-family: var(--f-display); font-weight: 800; font-size: 52px; color: var(--team-color); opacity: 0.85; }
  .driver-hero-overline { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; flex-wrap: wrap; }
  .driver-hero-nat { font-family: var(--f-mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--fg-3); }
  .driver-hero-team {
    font-family: var(--f-display); font-weight: 700; font-size: 13px;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--team-color);
    text-decoration: none;
  }
  .driver-hero-team:hover { text-decoration: underline; }
  .driver-hero-name { margin: 0 0 6px 0; font-size: 60px; line-height: 0.98; }
  .driver-hero-sub { display: flex; gap: 10px; align-items: center; color: var(--fg-3); flex-wrap: wrap; margin-bottom: 18px; }
  .driver-hero-sub .sep { color: var(--fg-4); }
  .driver-hero-headline { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; }
  .driver-hero-big { font-family: var(--f-display); font-weight: 800; font-size: 60px; line-height: 1; color: var(--team-color); }
  .driver-hero-big.is-champ { color: var(--accent); }
  .driver-hero-big-lbl { font-family: var(--f-display); font-weight: 600; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--fg-3); }

  /* ── Profile ────────────────────────────────────────────────── */
  .section-head-aside { margin-left: auto; color: var(--fg-4); }
  .profile-grid { display: grid; grid-template-columns: 1fr 340px; gap: 16px; margin-bottom: 8px; align-items: start; }
  .profile-bio { padding: 18px 20px; }
  .profile-bio p { margin: 0 0 12px; color: var(--fg-2); max-width: none; text-wrap: pretty; }
  .profile-bio p:last-child { margin-bottom: 0; }
  .profile-facts { grid-template-columns: repeat(2, 1fr); }
  .profile-facts .stat { box-shadow: 0 1px 2px rgba(0,0,0,.06), 0 6px 16px rgba(0,0,0,.08); }
  html.light .profile-facts .stat { box-shadow: 0 1px 2px rgba(20,22,30,.08), 0 8px 20px rgba(20,22,30,.10); }
  .profile-fact-sm { font-size: 20px; }

  /* ── 2026 Season strip + detail ─────────────────────────────── */
  .season-strip { grid-template-columns: repeat(6, 1fr); }
  .season-detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; align-items: start; }
  .season-pill { margin-left: 4px; }

  /* Race-by-race cards: round header · flag band · body. Cards grow
     sideways, not down. Flag is contained to a band (not a full-bleed
     panel background), keeping the surface calm and on-system. */
  .rr-ribbon { display: grid; grid-template-columns: repeat(auto-fill, minmax(96px, 1fr)); gap: 8px; }
  .rr-card {
    position: relative; display: flex; flex-direction: column; overflow: hidden;
    background: var(--bg-2); border: 1px solid var(--line-1);
    color: inherit; text-decoration: none; transition: border-color var(--mo);
  }
  a.rr-card:hover { border-color: var(--line-3); }
  a.rr-card:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

  .rr-head { display: flex; align-items: center; padding: 5px 8px 4px; }
  /* --fg-3 (not --fg-4) so the round label clears WCAG AA on the card in both themes. */
  .rr-round { font-size: 10px; color: var(--fg-3); letter-spacing: 0.06em; line-height: 1; }

  /* Flag band. The GP name rides a bottom-weighted scrim so white text clears
     WCAG AA (>=4.5:1) even over an all-white flag, in both themes. A theme-safe
     --bg-3 fills the band when a race has no flag asset. */
  .rr-flag {
    position: relative; height: 34px; padding: 4px 7px;
    background-color: var(--bg-3); background-size: cover; background-position: center;
    display: flex; flex-direction: column; justify-content: flex-end;
    border-bottom: 2px solid var(--team-color);
  }
  .rr-card.is-p1 .rr-flag { border-bottom-color: var(--gold); }
  .rr-card.is-p2 .rr-flag { border-bottom-color: var(--silver); }
  .rr-card.is-p3 .rr-flag { border-bottom-color: var(--bronze); }
  .rr-flag::before {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(180deg, rgba(6,8,12,0) 0%, rgba(6,8,12,0.55) 38%, rgba(6,8,12,0.92) 100%);
  }
  .rr-name {
    position: relative; z-index: 1; font-size: 12px; font-weight: 700; line-height: 1.05;
    color: #fff; text-shadow: 0 1px 2px rgba(0,0,0,0.6);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .rr-body { display: flex; flex-direction: column; gap: 4px; padding: 7px 8px; }
  .rr-line { display: flex; align-items: baseline; justify-content: space-between; gap: 6px; }
  .rr-pos { font-size: 20px; font-weight: 700; line-height: 1; color: var(--fg-1); }
  /* Podium tint via color-mix toward --fg-1 keeps the medal hue while lifting
     every finish to AA in both themes (raw medal hex fails as text on white).
     The pure medal colour still reads on the band rule above. */
  .rr-card.is-p1 .rr-pos { color: color-mix(in srgb, var(--gold) 60%, var(--fg-1)); }
  .rr-card.is-p2 .rr-pos { color: color-mix(in srgb, var(--silver) 60%, var(--fg-1)); }
  .rr-card.is-p3 .rr-pos { color: color-mix(in srgb, var(--bronze) 60%, var(--fg-1)); }
  .rr-card.is-dnf .rr-pos { color: var(--neg); font-size: 13px; }
  .rr-pts { font-size: 10px; color: var(--fg-3); white-space: nowrap; }
  .rr-pts-u { color: var(--fg-3); }
  .rr-badges { display: flex; flex-wrap: wrap; gap: 4px; }
  .rr-badges .season-pill { margin-left: 0; }

  .form-panel { padding: 16px 16px 12px; display: flex; flex-direction: column; }
  .form-chart { display: block; width: 100%; height: auto; }
  .form-axis-lbl { font-family: var(--f-mono); font-size: 9px; fill: var(--fg-4); letter-spacing: 0.05em; }
  .form-caption { margin-top: 6px; color: var(--fg-4); }

  /* ── Career grid ────────────────────────────────────────────── */
  .driver-career-grid { grid-template-columns: repeat(7, 1fr); }
  .stat-accent { border-color: var(--accent); }
  .stat-accent .stat-lbl, .stat-accent .stat-val { color: var(--accent); }

  /* ── Standings-style history tables ─────────────────────────── */
  .hist-tbl td.center { text-align: center; }
  .hist-tbl .pos { margin: 0 auto; }
  .hist-pts-td { position: relative; text-align: right; }
  .hist-pts-val { position: relative; z-index: 1; font-family: var(--f-display); font-weight: 800; font-size: 15px; color: var(--fg-1); font-variant-numeric: tabular-nums; }
  .hist-dnf { font-family: var(--f-mono); font-size: 12px; color: var(--fg-3); }

  /* Race + team cells: country flag / team logo alongside the name */
  .race-cell { display: inline-flex; align-items: center; gap: 8px; min-width: 0; }
  .race-flag { flex-shrink: 0; display: inline-flex; }
  .race-flag :global(.flag-img) { width: 20px; height: 15px; border-radius: 1px; display: block; }
  .team-logo-sm { width: 20px; height: 20px; object-fit: contain; border-radius: 2px; background: #fff; padding: 1px; flex-shrink: 0; }
  .status-cell { display: inline-flex; align-items: center; gap: 7px; }

  /* ── Career outcome waffle ──────────────────────────────────── */
  /* Outcome ramp defined as scoped custom properties so both themes stay in
     parity (no hardcoded hex reaching the DOM) - remapped for light below.
     Win reuses the F1 accent red; the rest are a legend-driven semantic ramp.
     Shared by the Career Mosaic tiles and the Season Outcomes stacked bars. */
  .outcome-ramp {
    --w-win: var(--gold);        /* gold */
    --w-podium: #c9cdd6;         /* silver */
    --w-points: #e8722e;         /* orange */
    --w-finished: #62656e;       /* grey */
    --w-mech: var(--accent);     /* red — DNF (mechanical) */
    --w-crash: #a8102a;          /* deep red — DNF (crash) */
    --w-dsq: #6e1420;            /* maroon — DSQ */
  }
  html.light .outcome-ramp {
    --w-win: #cf9a1f;            /* deeper gold for contrast on light */
    --w-podium: #aab0bb;         /* silver */
    --w-points: #d8611f;         /* orange */
    --w-finished: #797c85;       /* grey */
    --w-crash: #9e0f26;          /* deep red */
    --w-dsq: #6e1420;            /* maroon */
  }
  .waffle-panel { padding: 18px 20px 16px; }
  .waffle-head { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
  .waffle-head-mark { width: 4px; height: 15px; background: var(--gold); border-radius: 1px; flex-shrink: 0; }
  .waffle-head-title { font-family: var(--f-display); font-weight: 700; font-size: 13px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--fg-1); }
  .waffle-head-count { margin-left: auto; font-size: 12px; color: var(--fg-4); letter-spacing: 0.06em; }
  .waffle-blurb { margin: 0 0 14px; color: var(--fg-3); font-size: 13px; line-height: 1.5; text-wrap: pretty; }

  .waffle-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, var(--tile, 18px));
    gap: 4px;
  }
  .waffle-tile {
    display: block;
    aspect-ratio: 1;
    border-radius: 2px;
    background: var(--fg-4);
    text-decoration: none;
    transition: transform .1s ease, outline-color .1s ease;
    outline: 1px solid transparent;
    outline-offset: 1px;
  }
  a.waffle-tile { cursor: pointer; }
  .waffle-tile:hover { transform: scale(1.28); outline-color: var(--line-3); z-index: 1; }
  a.waffle-tile:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; z-index: 1; }
  .w-win { background: var(--w-win); }
  .w-podium { background: var(--w-podium); }
  .w-points { background: var(--w-points); }
  .w-finished { background: var(--w-finished); }
  .w-mech { background: var(--w-mech); }
  .w-crash { background: var(--w-crash); }
  .w-dsq { background: var(--w-dsq); }

  .waffle-legend { display: flex; flex-wrap: wrap; gap: 8px 18px; margin-top: 16px; margin-bottom: 16px; }
  .waffle-key { display: inline-flex; align-items: center; gap: 7px; }
  .waffle-swatch { width: 13px; height: 13px; border-radius: 2px; flex-shrink: 0; }
  .waffle-key-lbl { font-size: 12px; color: var(--fg-2); }
  .waffle-key-count { font-size: 12px; color: var(--fg-4); font-variant-numeric: tabular-nums; }

  /* ── Season outcomes (100% stacked, shares .outcome-ramp) ───────── */
  /* Career Mosaic + Season Outcomes pairing. .mo-stack renders them full-width
     stacked (long careers); .mo-grid puts them side by side (short careers). */
  .mo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px 24px; align-items: start; }
  .mo-grid > .mo-col { min-width: 0; }
  .outcome-panel { padding: 18px 20px 18px; }
  .outcome-head { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
  .outcome-head-mark { width: 4px; height: 15px; background: var(--gold); border-radius: 1px; flex-shrink: 0; }
  .outcome-head-title { font-family: var(--f-display); font-weight: 700; font-size: 13px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--fg-1); }
  .outcome-head-aside { margin-left: auto; font-size: 12px; color: var(--fg-4); letter-spacing: 0.06em; }
  /* One shared grid (rows use display:contents) so the team column is a single
     track sized to the widest team name across every season — every bar then
     starts at the same x, regardless of a row having a logo or a short name. */
  .outcome-grid { display: grid; grid-template-columns: 40px max-content 1fr; align-items: center; column-gap: 10px; row-gap: 8px; }
  .outcome-row { display: contents; }
  .outcome-year { font-size: 13px; color: var(--fg-3); text-align: right; letter-spacing: 0.02em; }
  .outcome-team { min-width: 0; gap: 7px; font-size: 12px; }
  .outcome-team .team-logo-sm { width: 18px; height: 18px; }
  .outcome-team-name { min-width: 0; max-width: 120px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--fg-2); }
  .outcome-bar { display: flex; height: 24px; border: 1px solid var(--line-1); overflow: hidden; background: var(--bg-3); }
  .outcome-seg { height: 100%; min-width: 0; transition: filter .12s ease; }
  .outcome-row:hover .outcome-seg { filter: brightness(1.08); }
  .outcome-seg.w-win { background: var(--w-win); }
  .outcome-seg.w-podium { background: var(--w-podium); }
  .outcome-seg.w-points { background: var(--w-points); }
  .outcome-seg.w-finished { background: var(--w-finished); }
  .outcome-seg.w-mech { background: var(--w-mech); }
  .outcome-seg.w-crash { background: var(--w-crash); }
  .outcome-seg.w-dsq { background: var(--w-dsq); }

  /* ── Teammate duels (Career Duel Meter) ─────────────────────────
     Team colour lands on the "me" bar fill; the teammate side is a neutral
     slate (--line-3), never a second bright hue. Text on the bright fill uses
     the constant near-black ink token so it clears contrast on every team
     colour in both themes; text on the slate uses --fg-1 (flips per theme). */
  .duel-panel { --duel-them: var(--line-3); padding: 20px 22px 18px; }
  .duel-head { display: flex; align-items: center; gap: 10px; padding-bottom: 14px; margin-bottom: 18px; border-bottom: 1px solid var(--line-1); }
  .duel-head-mark { width: 4px; height: 15px; background: var(--team-color); flex-shrink: 0; }
  .duel-head-title { font-family: var(--f-display); font-weight: 800; font-size: 15px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--fg-1); }
  .duel-head-sub { margin-left: auto; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--fg-4); }

  .duel-bar-block { margin-bottom: 20px; }
  .duel-labels { display: flex; justify-content: space-between; align-items: baseline; gap: 8px; margin-bottom: 6px; }
  .duel-name { font-family: var(--f-display); font-weight: 800; font-size: 14px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--fg-2); }
  /* Team-tinted *text* mixed toward the theme's fg so it clears AA on white
     (pure team hex as text fails for orange/cyan/green teams) — keeps the hue.
     Bar fills below stay pure team colour, which is allowed. */
  .duel-name .n { color: color-mix(in srgb, var(--team-color) 55%, var(--fg-1)); }
  .duel-mode { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--fg-3); }
  .duel-them { font-family: var(--f-display); font-weight: 600; font-size: 14px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--fg-3); }
