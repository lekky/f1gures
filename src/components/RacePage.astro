---
// Pure server-rendered race detail page. Hero + results table + qualifying
// table + sprint table (where applicable) + nav to prev/next race. No
// React island, no client JS.

interface Props {
  race: {
    raceId: string;
    year: number;
    round: number;
    name: string;
    date: string | null;
    time: string | null;
    url: string | null;
    circuit: {
      circuitRef: string;
      name: string;
      location: string;
      country: string;
      countryName: string;
      flag: string;
    } | null;
    pole: string | null;
    fastest: string | null;
    fastestLapTime: string | null;
    winner: string | null;
    results: Array<{
      position: number | null;
      positionText: string | null;
      driverRef: string | null;
      driverName: string | null;
      code: string | null;
      constructorRef: string | null;
      constructorName: string | null;
      constructorColor: string | null;
      grid: number | null;
      points: number;
      laps: number | null;
      time: string | null;
      status: string | null;
      fastestLapTime: string | null;
      fastestLapRank: number | null;
    }>;
    qualifying: Array<{
      position: number | null;
      driverRef: string | null;
      driverName: string | null;
      code: string | null;
      constructorRef: string | null;
      constructorName: string | null;
      q1: string | null;
      q2: string | null;
      q3: string | null;
    }>;
    sprint: Array<{
      position: number | null;
      positionText: string | null;
      driverRef: string | null;
      driverName: string | null;
      code: string | null;
      constructorRef: string | null;
      constructorName: string | null;
      grid: number | null;
      points: number;
      time: string | null;
      status: string | null;
    }> | boolean | null;
    prev: { year: number; round: number; name: string } | null;
    next: { year: number; round: number; name: string } | null;
  };
}

import { existsSync, readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import RaceResultsBody from './RaceResultsBody.astro';
import RaceUpcomingBody from './RaceUpcomingBody.astro';
import MobileBarRows from './MobileBarRows.astro';
import Flag from './Flag.astro';
import TriviaBoard from './islands/screens/TriviaBoard.jsx';

const { race } = Astro.props;
// Upcoming holding pages carry sprint as a boolean flag; completed sprint
// weekends carry the sprint *results* array - both mean "sprint weekend".
const isSprintWeekend = race.sprint === true || (Array.isArray(race.sprint) && race.sprint.length > 0);
// Big hero treatment: uppercase short name (strip "Grand Prix") + a red period,
// matching the calendar's next-race hero. Full name stays in <title>/breadcrumb.
const displayName = race.name.replace(/ Grand Prix$/i, '');

// Flag wash (mirrors the driver/team heroes): the host country's flag pinned to
// the right of the hero, dissolving toward the name. race.circuit.country is an
// ISO alpha-2 code → the lipis SVG set, inlined as a data-URI with
// preserveAspectRatio="none" so it fills the wash box instead of letterboxing.
const washCc = race.circuit?.country ? race.circuit.country.toLowerCase() : null;
const flagWashSrc = washCc
  ? (() => {
      const abs = resolve(process.cwd(), 'public', `images/flags/${washCc}.svg`);
      if (!existsSync(abs)) return null;
      let svg = readFileSync(abs, 'utf8');
      svg = /preserveAspectRatio=/.test(svg)
        ? svg.replace(/preserveAspectRatio="[^"]*"/, 'preserveAspectRatio="none"')
        : svg.replace(/<svg\b/, '<svg preserveAspectRatio="none"');
      return `data:image/svg+xml,${encodeURIComponent(svg)}`;
    })()
  : null;
---

<div class="page race-detail">
  <a class="btn btn-ghost btn-sm" style="margin-bottom: 12px" href="/calendar/">← Calendar</a>

  <div class="panel race-hero">
    {flagWashSrc && (
      <div class="race-hero-flagwash" style={`background-image: url(${flagWashSrc})`} aria-hidden="true"></div>
    )}
    <div class="race-hero-meta">
      <div class="t-eyebrow race-hero-round">
        Round {String(race.round).padStart(2, '0')} · {race.year}{isSprintWeekend ? ' · Sprint Weekend' : ''}
      </div>
      <h1 class="page-title race-hero-name">{displayName}<span class="race-hero-dot">.</span></h1>
      <div class="race-hero-stats">
        {race.circuit && (
          <a class="t-mono race-hero-circuit-link" href={`/circuits/${race.circuit.circuitRef}/`}>
            <Flag cc={race.circuit.country} flag={race.circuit.flag} name={race.circuit.countryName} /> {race.circuit.name}
          </a>
        )}
        {race.circuit && race.date && <span class="sep">·</span>}
        {race.date && <span class="t-mono">{race.date}</span>}
      </div>
    </div>
  </div>

  {/* Trigger the flag-wash entrance wipe only when the page is visible, so a
      frozen/hidden preview never traps it at its invisible first frame. The
      wash is CSS-visible without this. */}
  <script is:inline>
    (function () {
      function wipe() {
        var els = document.querySelectorAll('.race-hero-flagwash');
        for (var i = 0; i < els.length; i++) els[i].classList.add('is-wiping');
      }
      if (document.visibilityState === 'visible') { wipe(); }
      else {
        document.addEventListener('visibilitychange', function onVis() {
          if (document.visibilityState === 'visible') {
            wipe();
            document.removeEventListener('visibilitychange', onVis);
          }
        });
      }
    })();
  </script>

  <TriviaBoard client:visible />

  {race.results.length > 0
    ? <RaceResultsBody race={race} />
    : <RaceUpcomingBody race={race} />}

  <div class="race-nav">
    {race.prev ? (
      <a class="btn btn-ghost btn-sm race-nav-prev" href={`/races/${race.prev.year}/${race.prev.round}/`}>
        ← {race.prev.name} {race.prev.year}
      </a>
    ) : <span></span>}
    {race.next ? (
      <a class="btn btn-ghost btn-sm race-nav-next" href={`/races/${race.next.year}/${race.next.round}/`}>
        {race.next.name} {race.next.year} →
      </a>
    ) : <span></span>}
  </div>
</div>

<MobileBarRows />

<style is:global>
  /* This block is global so rules also style elements rendered by the
     RaceResultsBody and RaceUpcomingBody child components - Astro's default
     scoped styles don't cross component boundaries, and splitting these rules
     across three components would duplicate hero/podium styling. Class names
     here are race-page specific (race-hero-*, race-upcoming-*, session-*, etc.)
     so global scope doesn't conflict with other pages. */
  race-countdown { display: block; }

  .race-hero { position: relative; overflow: hidden; padding: 28px 24px; margin-bottom: 20px; border-left: 3px solid var(--accent); }
  .race-hero-meta { position: relative; z-index: 1; }
  /* Flag wash: host-country flag pinned to the right, dissolving toward the
     name (mirrors the driver/team heroes). Below the meta content (z-index 1). */
  .race-hero-flagwash {
    --wash-op: 0.26;
    position: absolute;
    inset: 0 0 0 auto;
    /* Narrower than the other heroes: the race panel is much wider/taller, so
       58% reads oversized here. */
    width: 42%;
    z-index: 0;
    opacity: var(--wash-op);
    background-repeat: no-repeat;
    background-position: center;
    background-size: 100% 100%;
    mix-blend-mode: screen;
    pointer-events: none;
    -webkit-mask: linear-gradient(90deg, transparent 0%, #000 78%);
            mask: linear-gradient(90deg, transparent 0%, #000 78%);
  }
  html.light .race-hero-flagwash { --wash-op: 0.2; mix-blend-mode: multiply; }
  @media (prefers-reduced-motion: no-preference) {
    .race-hero-flagwash.is-wiping { animation: raceWashIn 1.1s 0.05s both cubic-bezier(0.18, 0.7, 0.16, 1); }
  }
  @keyframes raceWashIn {
    from { opacity: 0; transform: translateX(70px); }
    to   { opacity: var(--wash-op); transform: none; }
  }
  .race-hero-round { color: var(--accent); margin-bottom: 8px; }
  .race-hero-name { margin: 0 0 10px 0; font-size: 84px; line-height: 0.92; text-transform: uppercase; letter-spacing: -0.01em; }
  .race-hero-dot { color: var(--accent); }
  .race-hero-stats { display: flex; gap: 10px; align-items: center; color: var(--fg-3); flex-wrap: wrap; }
  .race-hero-stats .sep { color: var(--fg-4); }
  /* Underline affordance comes from the canonical inline-link block in app.css;
     keep the local hover colour bump (ambient -> fg-1) for extra feedback. */
  .race-hero-circuit-link:hover { color: var(--fg-1); }
  /* Base podium-step classes below are still used by RaceUpcomingBody's
     historic-podium block (the hero's own inline podium was removed). */
  .podium-step {
    border-left: 3px solid var(--line-1);
    padding: 0 14px;
  }
  .podium-1 { border-left-color: var(--accent); }
  .podium-2 { border-left-color: var(--fg-2); }
  .podium-3 { border-left-color: var(--fg-3); }
  .podium-pos { font-family: var(--f-display); font-weight: 800; font-size: 20px; }
  .podium-name { font-weight: 600; font-size: 14px; }
  .podium-team { font-size: 12px; color: var(--fg-3); }
  /* `.podium-name a` / `.podium-team a` link affordance: canonical
     inline-link block in app.css. */

  @media (max-width: 720px) {
    .race-hero-name { font-size: 44px; }
  }

  .code-tag { font-size: 10px; color: var(--fg-3); margin-left: 6px; }

  .race-nav { display: flex; justify-content: space-between; gap: 12px; margin-top: 16px; }

  /* Band headers on the race detail page need breathing room above (the global
     .section-head-band resets margin-top to 0 for the home bands). Scoped via
     .race-detail so it doesn't touch other pages' .page wrappers. */
  .race-detail .section-head-band { margin-top: 30px; }

  /* ── Intro row: race summary card + key links ───────────────── */
  .race-intro { display: grid; grid-template-columns: 1fr 300px; gap: 16px; margin-bottom: 8px; align-items: start; }
  .race-summary-card { padding: 18px 20px; }
  .race-summary-card p { margin: 0; color: var(--fg-2); font-size: 14px; line-height: 1.6; max-width: none; text-wrap: pretty; }
  .race-keylinks-card { padding: 16px 18px; }
  .race-keylinks-title { display: block; color: var(--fg-4); margin-bottom: 12px; }
  .race-keylinks-card ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px; }
  .race-keylinks-card li { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .race-keylinks-lbl { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--fg-4); }
  .race-keylinks-card .inline-link { font-size: 13px; }

  /* ── Podium spacing ─────────────────────────────────────────── */
  .race-podium { margin-bottom: 8px; }

  /* ── Standings-styled results tables ────────────────────────── */
  .tbl-collapsible { padding: 0; overflow-x: auto; }
  .tbl-collapsible[data-collapsed="true"] .rr-extra { display: none; }
  .tbl-expand { margin: 10px 0 4px; }
  .rr-tbl .pos { margin: 0 auto; }
  .rr-name-inner { min-width: 220px; }
  .rr-face { width: 26px; height: 26px; border-radius: 50%; object-fit: cover; background: var(--bg-3); flex-shrink: 0; }
  .rr-flag { flex-shrink: 0; display: inline-flex; }
  .rr-flag :global(.flag-img) { width: 20px; height: 15px; border-radius: 1px; display: block; }
  .rr-name { font-weight: 600; color: var(--fg-1); white-space: nowrap; }
  .std-name-id:hover .rr-name { color: var(--accent); }
  .rr-code { font-size: 10px; color: var(--fg-3); flex-shrink: 0; }
  .rr-team-cell { display: inline-flex; align-items: center; gap: 8px; min-width: 0; }
  .rr-team-cell .team-logo-sm { width: 20px; height: 20px; object-fit: contain; border-radius: 2px; background: #fff; padding: 1px; flex-shrink: 0; }
  .rr-team { color: inherit; text-decoration: none; }
  .rr-team:hover { color: var(--accent); }
  .rr-pts { font-family: var(--f-display); font-weight: 800; font-size: 15px; color: var(--fg-1); font-variant-numeric: tabular-nums; }
  .rr-fl { color: var(--fg-2); font-size: 12px; }
  .status-cell { display: inline-flex; align-items: center; gap: 7px; }
  .rr-status-lbl { color: var(--fg-3); font-size: 12px; }

  @media (max-width: 720px) {
    .race-intro { grid-template-columns: 1fr; }
  }

  .race-upcoming-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 20px;
  }

  .race-upcoming-next { padding: 20px; }
  .next-session-headline {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 6px;
    margin-bottom: 16px;
  }
  .next-session-label {
    font-size: 14px;
    color: var(--fg-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }
  .next-session-countdown {
    font-family: var(--f-display);
    font-weight: 800;
    font-size: 32px;
    line-height: 1.1;
    color: var(--fg-1);
  }

  .session-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  .session-table th {
    font-family: var(--f-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-align: right;
    padding: 0 0 8px;
    border-bottom: 1px solid var(--line-1);
    white-space: nowrap;
  }
  .session-table th.session-you-head { color: var(--accent); font-weight: 700; }
  .session-table th.session-track-head { color: var(--fg-3); font-weight: 400; }
  .session-table td {
    padding: 8px 0;
    border-bottom: 1px solid var(--line-1);
  }
  .session-table tr:last-child td { border-bottom: 0; }
  .session-table .session-label { color: var(--fg-2); }
  /* Your local time - the prominent column. */
  .session-table .session-you {
    text-align: right;
    color: var(--fg-1);
    font-weight: 700;
    width: 108px;
    white-space: nowrap;
  }
  /* Track local time - secondary, dimmed. */
  .session-table .session-track {
    text-align: right;
    color: var(--fg-3);
    width: 96px;
    white-space: nowrap;
  }
  .session-table tr.is-next .session-label,
  .session-table tr.is-next .session-you {
    color: var(--accent);
  }
  .session-table tr.is-next td { border-left: 3px solid var(--accent); padding-left: 8px; }
  .session-table tr.is-next td:not(:first-child) { border-left: 0; padding-left: 0; }
  .tz-foot {
    margin: 10px 0 0;
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.03em;
    color: var(--fg-3);
  }

  @media (max-width: 720px) {
    .race-upcoming-grid { grid-template-columns: 1fr; }
  }

  .race-upcoming-history { padding: 20px; }
  .race-upcoming-podium {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 12px;
    margin-bottom: 16px;
  }
  .race-upcoming-podium .podium-step {
    border-left: 3px solid var(--line-1);
    padding: 4px 12px;
  }
  .race-upcoming-podium .podium-step .podium-pos {
    font-family: var(--f-display);
    font-weight: 800;
    font-size: 16px;
  }
  .race-upcoming-podium .podium-step .podium-name {
    font-weight: 600;
    font-size: 14px;
  }
  .race-upcoming-podium .podium-step .podium-team {
    font-size: 12px;
    color: var(--fg-3);
  }
  /* `.podium-name a` / `.podium-team a` link affordance: canonical
     inline-link block in app.css. */
  .race-upcoming-podium .podium-step.podium-1 { border-left-color: var(--accent); }
  .race-upcoming-podium .podium-step.podium-2 { border-left-color: var(--fg-2); }
  .race-upcoming-podium .podium-step.podium-3 { border-left-color: var(--fg-3); }
  .race-upcoming-history-link {
    display: inline-block;
    margin-top: 6px;
    font-size: 13px;
  }
  .race-upcoming-firsttime {
    margin: 12px 0 16px;
    color: var(--fg-2);
    font-size: 14px;
    line-height: 1.5;
  }
</style>
