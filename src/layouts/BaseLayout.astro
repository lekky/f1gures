---
// BaseLayout - shared <head> + Chrome wrapper for every page.
// Ports the boilerplate from the legacy *.html files and shell.jsx <Chrome>.
//
// Props:
//   title           - full <title> tag value (already includes "| f1gures")
//   description     - meta description (~150-160 chars)
//   canonicalPath   - leading slash, e.g. "/standings-drivers/" - origin is added
//   ogType          - og:type, defaults to "website"
//   ogImage         - og:image URL, defaults to /images/og-default.png
//   jsonLd          - optional schema.org object, serialised into a <script type="application/ld+json"> block
//   breadcrumb      - optional array of { name, path } for BreadcrumbList JSON-LD
//   robots          - meta robots, defaults to "index, follow, max-image-preview:large"

import Chrome from '../components/Chrome.astro';
import { publicAssetHash } from '../lib/assetHash.js';
import currentSeason from '../data/currentSeason.js';

const appCssHash = publicAssetHash('css/app.css');
const siteCssHash = publicAssetHash('css/site.css');
const currentSeasonYear = String(currentSeason.seasonYear || '');

export interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  ogType?: string;
  ogImage?: string;
  ogImageAlt?: string;
  publishedTime?: string;
  jsonLd?: unknown;
  breadcrumb?: { name: string; path: string }[];
  robots?: string;
}

const {
  title,
  description,
  canonicalPath,
  ogType = 'website',
  ogImage = '/images/og-default.png',
  ogImageAlt,
  publishedTime,
  jsonLd,
  breadcrumb,
  robots = 'index, follow, max-image-preview:large',
} = Astro.props;

const resolvedOgImageAlt = ogImageAlt || title;

const ORIGIN = 'https://f1gures.app';
const canonical = ORIGIN + canonicalPath;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : ORIGIN + ogImage;

// Combine breadcrumb + jsonLd into a single flat graph. If the page already
// passed a `{ '@graph': [...] }` wrapper, spread its entries so we don't
// end up with @graph nested inside @graph (technically valid but rejected
// by some validators and harder for Google to parse).
const graph: unknown[] = [];
if (jsonLd) {
  if (typeof jsonLd === 'object' && jsonLd !== null && Array.isArray((jsonLd as any)['@graph'])) {
    for (const item of (jsonLd as any)['@graph']) graph.push(item);
  } else {
    graph.push(jsonLd);
  }
}
if (breadcrumb && breadcrumb.length > 0) {
  graph.push({
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumb.map((b, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: b.name,
      item: ORIGIN + b.path,
    })),
  });
}
---
<!doctype html>
<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
  <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
  <meta name="robots" content={robots} />
  <link rel="canonical" href={canonical} />

  <meta property="og:site_name" content="f1gures" />
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={resolvedOgImageAlt} />
  <meta property="og:locale" content="en_GB" />

  {publishedTime && <meta property="article:published_time" content={publishedTime} />}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@f1gures" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />
  <meta name="twitter:image:alt" content={resolvedOgImageAlt} />

  <link rel="icon" href="/favicon.png" sizes="256x256" type="image/png" />
  <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
  <link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://api.jolpi.ca" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700;800&family=Barlow:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700;800&family=Barlow:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700;800&family=Barlow:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" /></noscript>

  <link rel="stylesheet" href={`/css/app.css?v=${appCssHash}`} />
  <link rel="stylesheet" href={`/css/site.css?v=${siteCssHash}`} />

  {graph.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify(graph.length === 1 ? { '@context': 'https://schema.org', ...(graph[0] as object) } : { '@context': 'https://schema.org', '@graph': graph })}></script>
  )}

  <!-- Pre-hydration theme: read localStorage and set html.light *before* CSS
       paints, to avoid a dark→light flash on every page load. Inlined per Astro
       docs - `is:inline` opts out of bundling so it actually runs synchronously
       in <head>. -->
  <script is:inline>
    (function () {
      try {
        var saved = localStorage.getItem('f1-theme') || 'light';
        if (saved === 'light') document.documentElement.classList.add('light');
      } catch (e) {}
    })();
  </script>

  <!-- Pre-hydration year guard: if the visitor has picked a non-current
       season via the year picker, hide year-aware island content before
       paint so they don't see the SSR'd current-season data flash before
       the historic bundle finishes loading. The year-aware islands clear
       the class on mount once they've taken over rendering. -->
  <script is:inline define:vars={{ currentSeasonYear }}>
    (function () {
      // Mirror readYearPref() in yearAwareData.js: the `?year=` URL param
      // wins over the stored preference. Checking only localStorage let a
      // shared/linked `/?year=1998` URL flash the current season before the
      // historic bundle swapped in.
      var y = null;
      try { y = localStorage.getItem('f1-year'); } catch (e) {}
      try {
        var u = new URLSearchParams(window.location.search).get('year');
        if (u) y = u;
      } catch (e) {}
      if (y && y !== 'current' && y !== currentSeasonYear) {
        document.documentElement.classList.add('year-pending');
      }
    })();
  </script>
  <style is:inline>
    html.year-pending [data-year-aware] { visibility: hidden; }
    /* Thin top progress bar shown only while a picked season's bundle loads.
       Starts trickling toward 88% via CSS the moment the year-pending class
       is present (before hydration); yearAwareData.js drives it to 100% and
       fades it once the bundle lands. */
    #year-load-bar {
      position: fixed; top: 0; left: 0; height: 3px; width: 0;
      background: var(--accent); z-index: 9999;
      opacity: 0; pointer-events: none;
    }
    html.year-pending #year-load-bar {
      opacity: 1; width: 88%;
      transition: width 8s cubic-bezier(0.06, 0.7, 0.1, 1);
    }
  </style>

  {import.meta.env.PROD && (
    <>
      <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-17WG173FST"></script>
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-17WG173FST');
        // Buy Me a Coffee widget is injected async, so listen at the document
        // level. Donation completes off-site — this captures intent (the click).
        document.addEventListener('click', function (e) {
          if (e.target.closest && e.target.closest('#bmc-wbtn')) {
            gtag('event', 'donate_click', { source: 'bmc_widget' });
          }
        });
      </script>
    </>
  )}
</head>
<body>
  <div id="year-load-bar" aria-hidden="true"></div>
  <Chrome>
    <slot />
  </Chrome>

  <!-- Buy Me a Coffee floating widget. Restyled in css/app.css. Don't display:none - breaks the modal.
       `is:inline` is required: without it Astro bundles the tag and the BMC loader stops injecting #bmc-wbtn. -->
  <script is:inline data-name="BMC-Widget" data-cfasync="false" src="https://cdnjs.buymeacoffee.com/1.0.0/widget.prod.min.js" data-id="f1gures" data-description="Support me on Buy me a coffee!" data-message="" data-color="#FF5F5F" data-position="Right" data-x_margin="18" data-y_margin="18"></script>
</body>
</html>
