# Cache policy for the mobile-app data feed (/data/app/v1/*).
# Committed static file — Astro copies public/ verbatim into dist/, and the
# feed JSON below this directory is generated by scripts/build-app-feed.mjs.
#
# manifest.json is the freshness probe the apps poll, so it stays near-live;
# season/content files are content-hashed in the manifest and only re-fetched
# when their hash moves, so a short TTL + SWR is plenty.
<IfModule mod_headers.c>
  <FilesMatch "\.json$">
    Header set Cache-Control "public, max-age=300, stale-while-revalidate=3600"
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
  <FilesMatch "^manifest\.json$">
    Header set Cache-Control "public, max-age=60, stale-while-revalidate=300"
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>
