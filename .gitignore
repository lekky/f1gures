node_modules/
.playwright-mcp/
.claude/settings.local.json
.claude/worktrees/
.superpowers/
.env

# Block stray screenshots/photos at repo root, but allow site assets
/*.png
/*.jpg
/*.jpeg

# Astro
dist/
.astro/

# FastF1 session cache (scripts/fetch-stints.py) — tens of MB of blobs
.fastf1-cache/

# Generated by scripts/build-archive.mjs (npm run prebuild)
public/data/archive/
# Generated by scripts/sync-current-season.mjs (npm run prebuild) — copy of
# the highest-numbered public/data/<year>.json bundle so the listing-page
# islands can import it at build time.
src/data/currentSeason.json
# Per-year season bundles 1950-2019 are also CSV-generated. Hand-curated
# 2020-2025 bundles stay tracked.
public/data/19[0-9][0-9].json
public/data/20[01][0-9].json

# Generated by scripts/build-app-feed.mjs (npm run prebuild) — the versioned
# mobile-app data feed. The static public/data/app/.htaccess stays tracked.
public/data/app/v1/

# Generated OG images (rebuilt by prebuild)
/public/images/og/

# Generated by scripts/fetch-weather.mjs (nightly via prebuild)
src/data/weather-next.json

# Generated by scripts/build-climate.mjs (npm run build:climate)
src/data/climate/

# Generated by scripts/build-htaccess.mjs (npm run prebuild) — Apache
# rewrite rules for legacy ?id= URLs, rebuilt from _driver-codes.json.
public/.htaccess

